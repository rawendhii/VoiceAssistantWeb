{
  "manifest_version": 3,
  "name": "Voice Assistant Browser Controller",
  "version": "1.0.0",
  "description": "Controls supported websites from the Symfony voice assistant.",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://localhost/*",
    "https://127.0.0.1/*",
    "https://voiceassistant.local:8000/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://www.google.com/*",
    "https://google.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://mail.google.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*",
      "https://localhost/*",
      "https://127.0.0.1/*",
      "https://voiceassistant.local:8000/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://localhost/*",
        "https://127.0.0.1/*",
        "https://voiceassistant.local:8000/*"
      ],
      "js": [
        "content-app.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.google.com/*",
        "https://google.com/*",
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://mail.google.com/*"
      ],
      "js": [
        "content-page.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}