{% extends 'base.html.twig' %}

{% block title %}Admin - Voice Assistant{% endblock %}

{% block body %}
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <img
                    src="{{ asset('assets/images/assistant-vocal-logo.png') }}"
                    alt="Assistant Vocal logo"
                    class="admin-brand-logo"
                >

                <span>
                    Assistant<br>Vocal
                </span>
            </div>

            <div class="admin-subtitle">Back Office</div>

            <nav class="admin-nav">
                <a href="{{ path('admin_dashboard') }}" class="admin-link {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
                    <i data-lucide="layout-dashboard"></i>
                    <span>Dashboard</span>
                </a>

                <a href="{{ path('admin_users') }}" class="admin-link {{ app.request.attributes.get('_route') starts with 'admin_users' ? 'active' : '' }}">
                    <i data-lucide="users"></i>
                    <span>Users</span>
                </a>

                <a href="{{ path('admin_roles') }}" class="admin-link {{ app.request.attributes.get('_route') starts with 'admin_roles' ? 'active' : '' }}">
                    <i data-lucide="shield"></i>
                    <span>Roles</span>
                </a>

                <a href="{{ path('admin_managed_files') }}" class="admin-link {{ app.request.attributes.get('_route') starts with 'admin_managed_files' ? 'active' : '' }}">
                    <i data-lucide="folder"></i>
                    <span>Managed Files</span>
                </a>

                <a href="{{ path('admin_voice_commands') }}" class="admin-link {{ app.request.attributes.get('_route') starts with 'admin_voice_commands' ? 'active' : '' }}">
                    <i data-lucide="mic"></i>
                    <span>Voice Commands</span>
                </a>

                <a href="{{ path('admin_command_history') }}" class="admin-link {{ app.request.attributes.get('_route') starts with 'admin_command_history' ? 'active' : '' }}">
                    <i data-lucide="history"></i>
                    <span>Command History</span>
                </a>
            </nav>

            <div class="admin-sidebar-footer">
                <a href="{{ path('app_logout') }}" class="admin-link logout-link">
                    <i data-lucide="log-out"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <main class="admin-main">
           <div class="admin-topbar">
    <div class="admin-topbar-left">
        <div class="admin-topbar-icon">
            <i data-lucide="shield-check"></i>
        </div>

        <div>
            <div class="admin-topbar-title">Administration</div>
            <div class="admin-topbar-subtitle">
                Manage users, roles, files, and voice commands
            </div>
        </div>
    </div>

    <div class="admin-topbar-right">
        <div class="admin-topbar-status">
            <span></span>
            Secure
        </div>

        <div class="admin-topbar-user">
            <div class="admin-user-avatar">
                {% if app.user %}
                    {{ app.user.fullName|slice(0, 1)|upper }}
                {% else %}
                    A
                {% endif %}
            </div>

            <div class="admin-user-meta">
                <strong>
                    {% if app.user %}
                        {{ app.user.fullName }}
                    {% else %}
                        Admin
                    {% endif %}
                </strong>
                <span>Back Office</span>
            </div>
        </div>
    </div>
</div>

            <div class="admin-content">
                <div id="flash-container">
                    {% for message in app.flashes('success') %}
                        <div class="flash flash-success">{{ message }}</div>
                    {% endfor %}

                    {% for message in app.flashes('error') %}
                        <div class="flash flash-error">{{ message }}</div>
                    {% endfor %}
                </div>

                {% block admin_content %}{% endblock %}
            </div>
        </main>
    </div>

    <style>
        :root {
            --admin-bg: #f4f7fb;
            --admin-surface: #ffffff;
            --admin-navy: #071126;
            --admin-navy-2: #0f172a;
            --admin-blue: #2563eb;
            --admin-blue-dark: #1d4ed8;
            --admin-cyan: #38bdf8;
            --admin-text: #0f172a;
            --admin-muted: #64748b;
            --admin-border: #e2e8f0;
            --admin-danger: #dc2626;
            --admin-radius: 22px;
            --admin-shadow: 0 18px 45px rgba(15, 23, 42, 0.10);
        }

        .admin-shell {
            min-height: 100vh;
            background:
                radial-gradient(circle at 85% 5%, rgba(37, 99, 235, 0.10), transparent 32%),
                radial-gradient(circle at 35% 95%, rgba(56, 189, 248, 0.08), transparent 34%),
                linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
        }

        .admin-sidebar {
            width: 270px;
            padding: 26px 18px;
            background:
                radial-gradient(circle at 30% 8%, rgba(56, 189, 248, 0.20), transparent 28%),
                radial-gradient(circle at 80% 90%, rgba(37, 99, 235, 0.18), transparent 34%),
                linear-gradient(180deg, #071126 0%, #0f172a 52%, #111827 100%);
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 18px 0 50px rgba(15, 23, 42, 0.18);
            overflow-x: hidden;
        }

        .admin-sidebar::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background:
                linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.08) 22%, transparent 38%);
            transform: translateX(-130%);
            animation: adminSidebarSweep 8s ease-in-out infinite;
        }

        .admin-brand {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 8px;
            color: #ffffff;
        }

        .admin-brand-logo {
            width: 66px;
            height: 66px;
            flex: 0 0 auto;
            border-radius: 20px;
            object-fit: cover;
            box-shadow:
                0 0 0 8px rgba(37, 99, 235, 0.14),
                0 16px 34px rgba(37, 99, 235, 0.35),
                0 0 32px rgba(56, 189, 248, 0.35);
        }

        .admin-brand span {
            display: block;
            color: #ffffff;
            font-size: 28px;
            line-height: 1.05;
            font-weight: 950;
            letter-spacing: -0.04em;
        }

        .admin-subtitle {
            position: relative;
            z-index: 1;
            margin-bottom: 30px;
            padding-left: 82px;
            color: #cbd5e1;
            font-size: 14px;
            font-weight: 700;
        }

        .admin-nav {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .admin-link {
            min-height: 58px;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 15px 16px;
            border-radius: 18px;
            color: #e5e7eb;
            background: rgba(255, 255, 255, 0.065);
            border: 1px solid rgba(255, 255, 255, 0.08);
            font-size: 16px;
            font-weight: 850;
            text-decoration: none;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
            transition:
                transform 180ms ease,
                background 180ms ease,
                border-color 180ms ease,
                box-shadow 180ms ease;
        }

        .admin-link svg {
            width: 22px;
            height: 22px;
            color: #93c5fd;
            transition: transform 180ms ease, color 180ms ease;
        }

        .admin-link:hover {
            transform: translateX(4px);
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(147, 197, 253, 0.24);
            box-shadow:
                inset 0 1px 0 rgba(255, 255, 255, 0.08),
                0 14px 28px rgba(0, 0, 0, 0.16);
        }

        .admin-link:hover svg {
            transform: scale(1.08);
            color: #bfdbfe;
        }

        .admin-link.active {
            color: #ffffff;
            background:
                radial-gradient(circle at 24% 20%, rgba(56, 189, 248, 0.26), transparent 34%),
                linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
            border-color: rgba(147, 197, 253, 0.42);
            box-shadow:
                0 18px 36px rgba(37, 99, 235, 0.34),
                inset 0 1px 0 rgba(255, 255, 255, 0.18);
        }

        .admin-link.active svg {
            color: #ffffff;
        }

        .admin-sidebar-footer {
            position: relative;
            z-index: 1;
            margin-top: auto;
            padding-top: 22px;
        }

        .logout-link {
            background: rgba(220, 38, 38, 0.16);
            border-color: rgba(248, 113, 113, 0.22);
        }

        .logout-link:hover {
            background: rgba(220, 38, 38, 0.26);
        }

        .admin-main {
            margin-left: 270px;
            width: calc(100% - 270px);
            background: transparent;
        }

        .admin-topbar {
        .admin-topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    min-height: 88px;
    padding: 14px 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    background:
        radial-gradient(circle at 12% 20%, rgba(37, 99, 235, 0.08), transparent 28%),
        rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(226, 232, 240, 0.9);
    box-shadow: 0 12px 32px rgba(15, 23, 42, 0.055);
}

.admin-topbar-left,
.admin-topbar-right {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
}

.admin-topbar-icon {
    width: 50px;
    height: 50px;
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    border-radius: 18px;
    color: #ffffff;
    background:
        radial-gradient(circle at 35% 25%, rgba(125, 211, 252, 0.8), transparent 34%),
        linear-gradient(135deg, #2563eb, #1d4ed8);
    box-shadow:
        0 0 0 7px rgba(37, 99, 235, 0.10),
        0 14px 28px rgba(37, 99, 235, 0.22);
}

.admin-topbar-icon svg {
    width: 23px;
    height: 23px;
}

.admin-topbar-title {
    color: #0f172a;
    font-size: 24px;
    line-height: 1.05;
    font-weight: 950;
    letter-spacing: -0.04em;
}

.admin-topbar-subtitle {
    margin-top: 4px;
    color: #64748b;
    font-size: 13px;
    line-height: 1.3;
    font-weight: 750;
}

.admin-topbar-status {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 13px;
    border-radius: 999px;
    color: #166534;
    background: #dcfce7;
    border: 1px solid #86efac;
    font-size: 13px;
    font-weight: 950;
    white-space: nowrap;
}

.admin-topbar-status span {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: #22c55e;
    box-shadow:
        0 0 0 6px rgba(34, 197, 94, 0.10),
        0 0 16px rgba(34, 197, 94, 0.8);
    animation: adminTopbarStatusPulse 1.6s ease-in-out infinite;
}

.admin-topbar-user {
    min-height: 54px;
    display: inline-flex;
    align-items: center;
    gap: 11px;
    padding: 7px 13px 7px 7px;
    border-radius: 999px;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    color: #334155;
    box-shadow:
        0 12px 28px rgba(15, 23, 42, 0.07),
        inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.admin-user-avatar {
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: #ffffff;
    background: linear-gradient(135deg, #2563eb, #38bdf8);
    font-size: 15px;
    font-weight: 950;
    box-shadow: 0 10px 22px rgba(37, 99, 235, 0.24);
}

.admin-user-meta {
    display: grid;
    gap: 2px;
}

.admin-user-meta strong {
    color: #0f172a;
    font-size: 14px;
    line-height: 1.1;
    font-weight: 950;
    white-space: nowrap;
}

.admin-user-meta span {
    color: #64748b;
    font-size: 12px;
    line-height: 1.1;
    font-weight: 750;
}

@keyframes adminTopbarStatusPulse {
    0%, 100% {
        transform: scale(1);
        opacity: 0.75;
    }

    50% {
        transform: scale(1.18);
        opacity: 1;
    }
}
        .admin-content {
            padding: 30px;
        }

        .admin-content > * {
            animation: adminContentRise 420ms ease both;
        }

        .flash {
            border-radius: 18px;
            border-width: 1px;
            box-shadow: 0 14px 32px rgba(15, 23, 42, 0.08);
        }

        @keyframes adminSidebarSweep {
            0%, 42% {
                transform: translateX(-130%);
            }

            66%, 100% {
                transform: translateX(130%);
            }
        }

        @keyframes adminContentRise {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.001ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.001ms !important;
                scroll-behavior: auto !important;
            }
        }

        @media (max-width: 900px) {
            .admin-sidebar {
                position: relative;
                width: 100%;
                height: auto;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                box-shadow: 0 18px 38px rgba(15, 23, 42, 0.16);
            }

            .admin-main {
                margin-left: 0;
                width: 100%;
            }

           .admin-topbar {
    min-height: 76px;
    height: auto;
    padding: 14px 18px;
    gap: 12px;
    flex-wrap: wrap;
}

.admin-topbar-left,
.admin-topbar-right {
    width: 100%;
    justify-content: space-between;
}

.admin-topbar-status {
    display: none;
}

            .admin-content {
                padding: 18px;
            }
        }

        @media (max-width: 720px) {
            .admin-topbar-icon {
    width: 44px;
    height: 44px;
    border-radius: 16px;
}

.admin-topbar-title {
    font-size: 20px;
}

.admin-topbar-subtitle {
    font-size: 12px;
}

.admin-user-meta span {
    display: none;
}
            .admin-brand span {
                font-size: 24px;
            }

            .admin-subtitle {
                padding-left: 0;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.lucide) {
                lucide.createIcons();
            }
        });
    </script>
{% endblock %}