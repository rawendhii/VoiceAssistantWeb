{% extends 'front/layout.html.twig' %}

{% block front_content %}
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:12px;">
        <div>
            <h1 style="margin:0;">Edit File</h1>
            <p style="margin:6px 0 0; color:#6b7280;">Update your selected file.</p>
        </div>

        <a href="{{ path('front_files') }}" class="btn btn-secondary">Back to list</a>
    </div>

    <div class="card" style="max-width:700px;">
       <form method="post" action="{{ path('front_files_update', {id: file.id}) }}">
    <input type="hidden" name="_token" value="{{ csrf_token('update_front_file_' ~ file.id) }}">

    <label for="fileName">File Name</label>
    <input id="fileName" type="text" name="fileName" value="{{ file.fileName }}" required>

    <label for="filePath">File Path</label>
    <input id="filePath" type="text" name="filePath" value="{{ file.filePath }}" required>

    <label for="fileType">File Type</label>
    <input id="fileType" type="text" name="fileType" value="{{ file.fileType }}" required>

    <button type="submit" class="btn">Update File</button>
</form>
    </div>
{% endblock %}