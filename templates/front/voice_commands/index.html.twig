{% extends 'front/layout.html.twig' %}

{% block front_content %}
<div style="max-width:1100px; margin:0 auto;">

    <div style="margin-bottom:24px;">
        <h1 style="margin:0; color:#111827; font-size:32px;">Voice Commands</h1>
        <p style="margin:8px 0 0; color:#6b7280; line-height:1.6;">
            These are the active commands that the assistant can understand and execute. 
            You can press <strong>Space</strong> anywhere in the user area to speak.
        </p>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:16px; margin-bottom:22px;">
        <div class="card" style="padding:20px; border-radius:16px;">
            <span style="display:block; color:#6b7280; font-size:14px; margin-bottom:6px;">Active Commands</span>
            <strong style="font-size:30px; color:#111827;">{{ commands|length }}</strong>
        </div>

        <div class="card" style="padding:20px; border-radius:16px;">
            <span style="display:block; color:#6b7280; font-size:14px; margin-bottom:6px;">Shortcut</span>
            <strong style="font-size:22px; color:#111827;">Space</strong>
        </div>

       
    </div>

    <div class="card" style="padding:24px; border-radius:18px; margin-bottom:22px;">
        <h3 style="margin:0 0 10px; color:#111827;">How to use the assistant</h3>
        <p style="margin:0; color:#6b7280; line-height:1.7;">
            Press <strong>Space</strong>, speak naturally, and wait for the assistant response.
            For sensitive actions such as deleting a file, the assistant will ask for confirmation before continuing.
        </p>
    </div>

    <div class="card" style="padding:24px; border-radius:18px;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:18px;">
            <div>
                <h3 style="margin:0; color:#111827;">Available Commands</h3>
                <p style="margin:6px 0 0; color:#6b7280;">
                    The assistant can understand natural phrases related to these commands.
                </p>
            </div>
        </div>

        <div style="overflow-x:auto;">
            <table>
                <thead>
                    <tr>
                        <th style="width:70px;">ID</th>
                        <th>Label</th>
                        <th>Keyword</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                {% for command in commands %}
                    <tr>
                        <td>{{ command.id }}</td>
                        <td>
                            <strong style="color:#111827;">{{ command.label }}</strong>
                        </td>
                        <td>
                            <span style="display:inline-block; padding:6px 10px; border-radius:999px; background:#eef2ff; color:#3730a3; font-size:13px; font-weight:700;">
                                {{ command.keyword }}
                            </span>
                        </td>
                        <td style="color:#4b5563;">
                            {{ command.description ?: 'No description provided.' }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align:center; color:#6b7280; padding:24px;">
                            No active voice commands found.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}