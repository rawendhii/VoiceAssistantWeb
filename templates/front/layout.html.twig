{% extends 'base.html.twig' %}

{% block title %}Front - Voice Assistant{% endblock %}

{% block body %}
    <div class="front-shell">
        <aside class="front-sidebar" aria-label="User navigation">
            <div class="front-brand">Assistant Vocal</div>
            <div class="front-subtitle">Accessible Front Office</div>

            <nav class="front-nav">
                <a href="{{ path('front_home') }}"
                   class="front-link {{ app.request.attributes.get('_route') == 'front_home' ? 'active' : '' }}">
                    <i data-lucide="house"></i>
                    <span>Home</span>
                </a>

                <a href="{{ path('front_voice_commands') }}"
                   class="front-link {{ app.request.attributes.get('_route') == 'front_voice_commands' ? 'active' : '' }}">
                    <i data-lucide="mic"></i>
                    <span>Voice Commands</span>
                </a>

                <a href="{{ path('front_youtube_assistant') }}"
                   class="front-link {{ app.request.attributes.get('_route') == 'front_youtube_assistant' ? 'active' : '' }}">
                    <i data-lucide="play-circle"></i>
                    <span>YouTube Assistant</span>
                </a>

                <a href="{{ path('front_files') }}"
                   class="front-link {{ app.request.attributes.get('_route') starts with 'front_files' ? 'active' : '' }}">
                    <i data-lucide="folder"></i>
                    <span>My Files</span>
                </a>

                <a href="{{ path('front_profile') }}"
                   class="front-link {{ app.request.attributes.get('_route') starts with 'front_profile' ? 'active' : '' }}">
                    <i data-lucide="user"></i>
                    <span>Profile</span>
                </a>
            </nav>

            <div class="front-sidebar-footer">
                <a href="{{ path('app_logout') }}" class="front-link logout-link">
                    <i data-lucide="log-out"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <main class="front-main">
            <div class="front-topbar">
                <div class="front-topbar-title">Accessible User Area</div>
                <div class="front-topbar-user">
                    {% if app.user %}
                        {{ app.user.fullName }}
                    {% endif %}
                </div>
            </div>

            <div class="front-content">
                <div id="flash-container" aria-live="polite" aria-atomic="true">
                    {% for message in app.flashes('success') %}
                        <div class="flash flash-success js-speak-on-load">{{ message }}</div>
                    {% endfor %}

                    {% for message in app.flashes('error') %}
                        <div class="flash flash-error js-speak-on-load">{{ message }}</div>
                    {% endfor %}
                </div>

                <div id="globalVoiceAnnouncements" class="sr-only" aria-live="assertive" aria-atomic="true"></div>

                {% block front_content %}{% endblock %}
            </div>
        </main>
    </div>

    <div id="globalVoiceAssistant" class="global-voice-widget" aria-live="polite">
        <div class="global-voice-info">
            <div id="globalVoiceBadge" class="global-voice-badge">Idle</div>
            <div>
                <strong>Voice Assistant</strong>
                <span id="globalVoiceText">Press Space to speak</span>
            </div>
        </div>

        <button id="globalVoiceButton" type="button" class="global-voice-button" aria-pressed="false">
            Start
        </button>
    </div>

    <style>
        .global-voice-widget {
            position: fixed;
            right: 24px;
            bottom: 24px;
            z-index: 9999;
            width: min(420px, calc(100vw - 48px));
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.18);
            padding: 14px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
        }

        .global-voice-info {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .global-voice-info strong {
            display: block;
            color: #111827;
            font-size: 14px;
            margin-bottom: 3px;
        }

        .global-voice-info span {
            display: block;
            color: #6b7280;
            font-size: 13px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 240px;
        }

        .global-voice-badge {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            background: #f3f4f6;
            color: #374151;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 800;
            flex-shrink: 0;
        }

        .global-voice-badge.listening {
            background: #dcfce7;
            color: #166534;
        }

        .global-voice-badge.processing {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .global-voice-badge.error {
            background: #fee2e2;
            color: #991b1b;
        }

        .global-voice-button {
            border: none;
            border-radius: 12px;
            background: #2563eb;
            color: #ffffff;
            padding: 11px 16px;
            font-size: 14px;
            font-weight: 800;
            cursor: pointer;
            min-width: 82px;
        }

        .global-voice-button:hover {
            background: #1d4ed8;
        }

        .global-voice-button.listening {
            background: #dc2626;
        }

        .global-voice-button.listening:hover {
            background: #b91c1c;
        }

        @media (max-width: 720px) {
            .global-voice-widget {
                right: 12px;
                bottom: 12px;
                width: calc(100vw - 24px);
            }

            .global-voice-info span {
                max-width: 160px;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        let globalAssistantWebsiteTab = null;

        function speakText(text) {
            if (!('speechSynthesis' in window) || !text) {
                return;
            }

            window.speechSynthesis.cancel();

            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'en-US';
            utterance.rate = 1;
            utterance.pitch = 1;
            utterance.volume = 1;

            window.speechSynthesis.speak(utterance);
        }

        function announceText(text) {
            const region = document.getElementById('globalVoiceAnnouncements');

            if (region) {
                region.textContent = text;
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const flashes = document.querySelectorAll('.flash');
            const speakableFlashes = document.querySelectorAll('.js-speak-on-load');

            if (speakableFlashes.length > 0) {
                const messages = Array.from(speakableFlashes)
                    .map(function (el) {
                        return el.textContent.trim();
                    })
                    .filter(Boolean);

                if (messages.length > 0) {
                    setTimeout(function () {
                        speakText(messages.join('. '));
                    }, 300);
                }
            }

            if (flashes.length > 0) {
                setTimeout(function () {
                    flashes.forEach(function (flash) {
                        flash.classList.add('hide');

                        setTimeout(function () {
                            flash.remove();
                        }, 500);
                    });
                }, 4000);
            }

            if (window.lucide) {
                lucide.createIcons();
            }

            const voiceButton = document.getElementById('globalVoiceButton');
            const voiceText = document.getElementById('globalVoiceText');
            const voiceBadge = document.getElementById('globalVoiceBadge');

            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

            let recognition = null;
            let isListening = false;
            let hasSpeechSupport = !!SpeechRecognition;

            function isTypingTarget(target) {
                if (!target) {
                    return false;
                }

                const tagName = target.tagName ? target.tagName.toLowerCase() : '';

                return (
                    tagName === 'input' ||
                    tagName === 'textarea' ||
                    tagName === 'select' ||
                    target.isContentEditable
                );
            }

            function isHelpCommand(text) {
                const normalized = text.toLowerCase().trim();

                return (
                    normalized === 'help' ||
                    normalized === 'voice help' ||
                    normalized === 'show commands' ||
                    normalized === 'available commands' ||
                    normalized === 'what can i say' ||
                    normalized === 'what can i do' ||
                    normalized.includes('what can i say') ||
                    normalized.includes('show me commands') ||
                    normalized.includes('help me')
                );
            }

            function looksLikeWebsiteCommand(text) {
                const normalized = text.toLowerCase().trim();

                const pageOnlyCommands = [
                    'play',
                    'play it',
                    'play video',
                    'play the video',
                    'pause',
                    'pause it',
                    'pause video',
                    'pause the video',
                    'stop',
                    'stop it',
                    'stop video',
                    'stop the video',
                    'mute',
                    'unmute',
                    'volume up',
                    'volume down',
                    'results',
                    'read results',
                    'next',
                    'previous',
                    'open first video',
                    'open second video',
                    'open third video',
                    'open this video',
                    'open the video'
                ];

                if (pageOnlyCommands.includes(normalized)) {
                    return false;
                }

                const hasWebsiteName =
                    normalized.includes('youtube') ||
                    normalized.includes('google') ||
                    normalized.includes('facebook');

                const hasWebsiteAction =
                    normalized.includes('open') ||
                    normalized.includes('go to') ||
                    normalized.includes('visit') ||
                    normalized.includes('launch') ||
                    normalized.includes('search') ||
                    normalized.includes('find') ||
                    normalized.includes('look up') ||
                    normalized.includes('look for') ||
                    normalized.includes('google');

                const impliesYoutubeSearch =
                    normalized.includes('video') &&
                    (
                        normalized.includes('search') ||
                        normalized.includes('find') ||
                        normalized.includes('look up') ||
                        normalized.includes('look for')
                    );

                return (hasWebsiteName && hasWebsiteAction) || impliesYoutubeSearch;
            }

            function setVoiceState(state, text) {
                voiceText.textContent = text;

                voiceBadge.classList.remove('listening', 'processing', 'error');
                voiceButton.classList.remove('listening');

                if (state === 'listening') {
                    voiceBadge.textContent = 'Live';
                    voiceBadge.classList.add('listening');
                    voiceButton.classList.add('listening');
                    voiceButton.textContent = 'Stop';
                    voiceButton.setAttribute('aria-pressed', 'true');
                    isListening = true;
                    return;
                }

                if (state === 'processing') {
                    voiceBadge.textContent = 'Work';
                    voiceBadge.classList.add('processing');
                    voiceButton.textContent = 'Start';
                    voiceButton.setAttribute('aria-pressed', 'false');
                    isListening = false;
                    return;
                }

                if (state === 'error') {
                    voiceBadge.textContent = 'Error';
                    voiceBadge.classList.add('error');
                    voiceButton.textContent = 'Start';
                    voiceButton.setAttribute('aria-pressed', 'false');
                    isListening = false;
                    return;
                }

                voiceBadge.textContent = 'Idle';
                voiceButton.textContent = 'Start';
                voiceButton.setAttribute('aria-pressed', 'false');
                isListening = false;
            }

            function setAssistantResult(text, speak = true, state = 'idle') {
                setVoiceState(state, text);
                announceText(text);

                if (speak) {
                    speakText(text);
                }
            }

            function openWebsiteInSingleTab(data) {
                const websiteName = data.websiteName || data.website || 'the website';

                if ((data.website || '').toLowerCase() === 'youtube' && data.action === 'search' && data.query) {
                    let youtubeAssistantUrl = '{{ path('front_youtube_assistant') }}?q=' + encodeURIComponent(data.query);

                    if (data.resultPosition) {
                        youtubeAssistantUrl += '&autoplay=' + encodeURIComponent(data.resultPosition);
                    }

                    window.location.href = youtubeAssistantUrl;
                    return;
                }

                const queryText = data.query ? ' for "' + data.query + '"' : '';
                const actionText = data.action === 'search'
                    ? 'searching ' + websiteName + queryText
                    : 'opening ' + websiteName;

                const message =
                    'I found a supported web command. I am ' + actionText +
                    ' in one separate browser tab. Your voice assistant will stay available here.';

                setAssistantResult(message, true, 'idle');

                if (globalAssistantWebsiteTab && !globalAssistantWebsiteTab.closed) {
                    globalAssistantWebsiteTab.location.href = data.url;
                    globalAssistantWebsiteTab.focus();
                    return;
                }

                globalAssistantWebsiteTab = window.open(data.url, 'voice_assistant_external_site');

                if (!globalAssistantWebsiteTab) {
                    setAssistantResult(
                        'The browser blocked the external tab. Please allow pop-ups for this website, then repeat your command.',
                        true,
                        'error'
                    );
                }
            }

            function sendGlobalVoiceCommand(text) {
                if (isHelpCommand(text)) {
                    const helpMessage =
                        'Here are some commands you can say: open profile, edit profile, change password, show my files, go home, log out, search YouTube for a topic, search Google for a topic, or find news on Facebook. ' +
    'On the YouTube Assistant page, you can say results, next, open second video, play, pause, stop it, volume up, or volume down. ' +
    'The web assistant can only show files stored in the web application. To create, rename, edit, delete, or manage files on your computer, use the desktop assistant module.';
                    setAssistantResult(helpMessage, true, 'idle');
                    return;
                }

                if (typeof window.handlePageVoiceCommand === 'function') {
                    const pageHandled = window.handlePageVoiceCommand(text);

                    if (pageHandled === true) {
                        return;
                    }
                }

                const endpoint = looksLikeWebsiteCommand(text)
                    ? '{{ path('api_voice_interpret') }}'
                    : '{{ path('voice_execute') }}';

                console.log('GLOBAL VOICE ENDPOINT:', endpoint);

                setAssistantResult('Processing your command: ' + text, false, 'processing');

                fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ text: text })
                })
                    .then(function (response) {
                        return response.json();
                    })
                    .then(function (data) {
                        console.log('GLOBAL VOICE RESPONSE:', data);

                        if (data.success && data.intent === 'WEBSITE_ACTION' && data.url) {
                            openWebsiteInSingleTab(data);
                            return;
                        }

                        if (!data.success) {
                            const failMessage =
                                (data.message || 'I could not match that command.') +
                                ' Try saying "what can I say" for help.';

                            setAssistantResult(failMessage, true, 'error');
                            return;
                        }

                        const spokenReply =
                            (data.execution && data.execution.speech) ||
                            data.speech ||
                            data.message ||
                            'Command completed successfully.';

                        setAssistantResult(spokenReply, true, 'idle');

                        if (data.execution && data.execution.redirect) {
                            setTimeout(function () {
                                window.location.href = data.execution.redirect;
                            }, 1400);
                        }
                    })
                    .catch(function () {
                        setAssistantResult(
                            'A connection error happened while processing your command. Please check the server and try again.',
                            true,
                            'error'
                        );
                    });
            }

            function startListening() {
                if (window.speechSynthesis) {
                    window.speechSynthesis.cancel();
                }

                if (!hasSpeechSupport) {
                    setAssistantResult('Voice recognition is not supported in this browser. Please use Google Chrome.', true, 'error');
                    return;
                }

                if (!recognition) {
                    recognition = new SpeechRecognition();
                    recognition.lang = 'en-US';
                    recognition.interimResults = false;
                    recognition.continuous = false;

                    recognition.onstart = function () {
                        setVoiceState('listening', 'Listening now. Speak your command.');
                        announceText('Listening now. Speak your command.');
                    };

                    recognition.onend = function () {
                        if (isListening) {
                            setVoiceState('idle', 'Press Space to speak');
                        }
                    };

                    recognition.onerror = function (event) {
                        console.error('SPEECH RECOGNITION ERROR:', event.error, event);

                        let message = 'Voice recognition error: ' + event.error + '. Please try again.';

                        if (event.error === 'not-allowed') {
                            message = 'Microphone permission was denied. Please allow microphone access and try again.';
                        } else if (event.error === 'no-speech') {
                            message = 'I did not hear anything. Press Space or Start and speak your command.';
                        } else if (event.error === 'audio-capture') {
                            message = 'No microphone was found. Please check your microphone.';
                        } else if (event.error === 'network') {
                            message = 'Speech recognition needs a network connection. Please check your internet and try again.';
                        } else if (event.error === 'aborted') {
                            message = 'Listening was interrupted. Please press Start and try again.';
                        } else if (event.error === 'service-not-allowed') {
                            message = 'Speech recognition service is not allowed in this browser.';
                        }

                        setAssistantResult(message, true, 'error');
                    };

                    recognition.onresult = function (event) {
                        const text = event.results[0][0].transcript.trim();

                        setVoiceState('processing', 'Processing: ' + text);

                        sendGlobalVoiceCommand(text);
                    };
                }

                try {
                    recognition.start();
                } catch (error) {
                    setAssistantResult('The microphone is already starting. Please wait a moment.', true, 'error');
                }
            }

            function stopListening() {
                if (recognition && isListening) {
                    recognition.stop();
                    setAssistantResult('Listening stopped. Press Space when you want to speak again.', true, 'idle');
                }
            }

            function toggleListening() {
                if (isListening) {
                    stopListening();
                } else {
                    startListening();
                }
            }

            voiceButton.addEventListener('click', function () {
                toggleListening();
            });

            document.addEventListener('keydown', function (event) {
                if (event.code === 'Space' && !event.ctrlKey && !event.altKey && !event.shiftKey && !event.metaKey) {
                    if (isTypingTarget(event.target)) {
                        return;
                    }

                    event.preventDefault();
                    toggleListening();
                }
            });

            if (!hasSpeechSupport) {
                setAssistantResult('Voice recognition is not supported in this browser. Please use Google Chrome.', false, 'error');
            } else {
                setVoiceState('idle', 'Press Space to speak');
            }
        });
    </script>
{% endblock %}