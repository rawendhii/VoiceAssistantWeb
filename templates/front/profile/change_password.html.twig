{% extends 'front/layout.html.twig' %}

{% block front_content %}
<h2 style="margin-bottom:20px;">Change Password</h2>

<form method="post" class="card" style="max-width:500px;margin:auto;padding:25px;border-radius:12px;"
      onsubmit="return confirmChangePassword()">

    <div style="margin-bottom:15px;">
        <label>Current Password</label>
        <input type="password" name="currentPassword" required class="input">
    </div>

    <div style="margin-bottom:15px;">
        <label>New Password</label>
        <input type="password" name="newPassword" required class="input">
    </div>

    <div style="margin-bottom:20px;">
        <label>Confirm Password</label>
        <input type="password" name="confirmPassword" required class="input">
    </div>

    <button type="submit" class="btn btn-primary" style="width:100%;">
        Update Password
    </button>
</form>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function confirmChangePassword() {
    const ok = confirm("Are you sure you want to change your password?");
    if (ok) {
        announceText("Changing your password");
        speakText("Changing your password");
    }
    return ok;
}
</script>
{% endblock %}