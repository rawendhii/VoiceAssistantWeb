{% extends 'front/layout.html.twig' %}

{% block front_content %}
<div class="profile-wrapper">

    

    <!-- Info -->
    <div class="card">
        <div class="info-row">
            <div>
                <span>Full Name</span>
                <strong>{{ user.fullName }}</strong>
            </div>

            <div>
                <span>Email</span>
                <strong>{{ user.email }}</strong>
            </div>

            <div>
                <span>Role</span>
                <strong class="badge">{{ user.role.name }}</strong>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="card actions">
        <a href="{{ path('front_profile_edit') }}" class="btn btn-primary">
            Edit Profile
        </a>
        <a href="{{ path('front_profile_change_password') }}" class="btn btn-secondary">
            Change Password
        </a>
    </div>

    <!-- Danger -->
    <div class="card danger">
        <h4>Danger Zone</h4>
        <p>Deleting your account is permanent and cannot be undone.</p>

        <a href="{{ path('front_profile_delete') }}" class="btn btn-danger">
            Delete Account
        </a>
    </div>

</div>
{% endblock %}