{% extends 'front/layout.html.twig' %}

{% block front_content %}
    <main class="profile-page">
        <section class="profile-hero">
            <div class="profile-hero-bg" aria-hidden="true">
                <span class="profile-orb profile-orb-one"></span>
                <span class="profile-orb profile-orb-two"></span>
            </div>

            <div class="profile-hero-content">
                <div class="profile-avatar-large">
                    {{ user.fullName|slice(0, 1)|upper }}
                </div>

                <div>
                    <span class="profile-kicker">
                        <i data-lucide="user-round"></i>
                        User Profile
                    </span>

                    <h1>{{ user.fullName }}</h1>
                    <p>{{ user.email }}</p>
                </div>
            </div>
        </section>

        <section class="profile-grid">
            <article class="profile-card">
                <div class="profile-card-icon">
                    <i data-lucide="id-card"></i>
                </div>

                <div>
                    <span>Full Name</span>
                    <strong>{{ user.fullName }}</strong>
                </div>
            </article>

            <article class="profile-card">
                <div class="profile-card-icon">
                    <i data-lucide="mail"></i>
                </div>

                <div>
                    <span>Email Address</span>
                    <strong>{{ user.email }}</strong>
                </div>
            </article>

            <article class="profile-card">
                <div class="profile-card-icon">
                    <i data-lucide="shield-check"></i>
                </div>

                <div>
                    <span>Role</span>
                    <strong class="profile-role-pill">{{ user.role.name }}</strong>
                </div>
            </article>
        </section>

        <section class="profile-action-card">
            <div class="profile-section-header">
                <div>
                    <span class="section-label">Account actions</span>
                    <h2>Manage your account</h2>
                    <p>
                        Update your profile information or change your password securely.
                    </p>
                </div>

                <div class="profile-section-icon">
                    <i data-lucide="settings"></i>
                </div>
            </div>

            <div class="profile-actions">
                <a href="{{ path('front_profile_edit') }}" class="profile-btn profile-btn-primary">
                    <i data-lucide="pencil"></i>
                    Edit Profile
                </a>

                <a href="{{ path('front_profile_change_password') }}" class="profile-btn profile-btn-secondary">
                    <i data-lucide="key-round"></i>
                    Change Password
                </a>
            </div>
        </section>

        <section class="profile-danger-card">
            <div class="profile-section-header">
                <div>
                    <span class="danger-label">Danger zone</span>
                    <h2>Delete your account</h2>
                    <p>
                        Deleting your account is permanent. All related data will be removed.
                    </p>
                </div>

                <div class="danger-icon">
                    <i data-lucide="triangle-alert"></i>
                </div>
            </div>

            <a href="{{ path('front_profile_delete') }}" class="profile-btn profile-btn-danger">
                <i data-lucide="trash-2"></i>
                Delete Account
            </a>
        </section>
    </main>

    <style>
        .profile-page,
        .profile-page * {
            box-sizing: border-box;
        }

        .profile-page {
            max-width: 1080px;
            margin: 0 auto;
            display: grid;
            gap: 22px;
            color: #0f172a;
        }

        .profile-hero {
            position: relative;
            overflow: hidden;
            border-radius: 28px;
            min-height: 240px;
            background:
                radial-gradient(circle at 78% 30%, rgba(37, 99, 235, 0.24), transparent 34%),
                linear-gradient(135deg, #071126 0%, #111827 52%, #172554 100%);
            border: 1px solid rgba(148, 163, 184, 0.22);
            box-shadow: 0 24px 70px rgba(15, 23, 42, 0.20);
        }

        .profile-hero::before {
            content: "";
            position: absolute;
            inset: -50%;
            background:
                conic-gradient(
                    from 0deg,
                    transparent,
                    rgba(59, 130, 246, 0.22),
                    transparent,
                    rgba(56, 189, 248, 0.16),
                    transparent,
                    rgba(96, 165, 250, 0.18),
                    transparent
                );
            filter: blur(80px);
            opacity: 0.72;
            animation: profileAurora 18s linear infinite;
        }

        .profile-hero-bg {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .profile-orb {
            position: absolute;
            border-radius: 999px;
            filter: blur(12px);
            opacity: 0.45;
            mix-blend-mode: screen;
        }

        .profile-orb-one {
            width: 220px;
            height: 220px;
            right: 12%;
            top: 10%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.95), transparent 66%);
            animation: profileFloatOne 8s ease-in-out infinite;
        }

        .profile-orb-two {
            width: 160px;
            height: 160px;
            left: 8%;
            bottom: -42px;
            background: radial-gradient(circle, rgba(14, 165, 233, 0.8), transparent 68%);
            animation: profileFloatTwo 10s ease-in-out infinite;
        }

        .profile-hero-content {
            position: relative;
            z-index: 1;
            min-height: 240px;
            display: flex;
            align-items: center;
            gap: 24px;
            padding: clamp(26px, 4vw, 46px);
        }

        .profile-avatar-large {
            width: 104px;
            height: 104px;
            flex: 0 0 auto;
            display: grid;
            place-items: center;
            border-radius: 30px;
            color: #ffffff;
            background:
                radial-gradient(circle at 35% 25%, rgba(125, 211, 252, 0.95), transparent 34%),
                linear-gradient(135deg, #2563eb, #1d4ed8);
            font-size: 42px;
            font-weight: 950;
            box-shadow:
                0 0 0 10px rgba(37, 99, 235, 0.18),
                0 22px 46px rgba(37, 99, 235, 0.38);
        }

        .profile-kicker,
        .section-label,
        .danger-label {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            width: max-content;
            padding: 7px 12px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 950;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .profile-kicker {
            color: #bfdbfe;
            background: rgba(37, 99, 235, 0.18);
            border: 1px solid rgba(147, 197, 253, 0.24);
            margin-bottom: 14px;
        }

        .profile-kicker svg {
            width: 15px;
            height: 15px;
        }

        .profile-hero h1 {
            margin: 0;
            color: #ffffff;
            font-size: clamp(38px, 5vw, 64px);
            line-height: 0.98;
            letter-spacing: -0.065em;
            font-weight: 950;
        }

        .profile-hero p {
            margin: 12px 0 0;
            color: #cbd5e1;
            font-size: 18px;
            line-height: 1.5;
            font-weight: 650;
        }

        .profile-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

        .profile-card,
        .profile-action-card,
        .profile-danger-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
        }

        .profile-card {
            min-height: 122px;
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 22px;
        }

        .profile-card-icon,
        .profile-section-icon,
        .danger-icon {
            flex: 0 0 auto;
            width: 56px;
            height: 56px;
            display: grid;
            place-items: center;
            border-radius: 18px;
        }

        .profile-card-icon,
        .profile-section-icon {
            color: #2563eb;
            background: #eff6ff;
            border: 1px solid #dbeafe;
        }

        .profile-card-icon svg,
        .profile-section-icon svg,
        .danger-icon svg {
            width: 26px;
            height: 26px;
        }

        .profile-card span {
            display: block;
            margin-bottom: 6px;
            color: #64748b;
            font-size: 13px;
            font-weight: 900;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .profile-card strong {
            display: block;
            color: #0f172a;
            font-size: 17px;
            line-height: 1.3;
            font-weight: 950;
            word-break: break-word;
        }

        .profile-role-pill {
            width: max-content;
            padding: 8px 13px;
            border-radius: 999px;
            background: #eff6ff;
            color: #1d4ed8 !important;
            border: 1px solid #dbeafe;
            font-size: 14px !important;
        }

        .profile-action-card,
        .profile-danger-card {
            padding: 26px;
        }

        .profile-section-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 18px;
            margin-bottom: 22px;
        }

        .section-label {
            color: #2563eb;
            background: #eff6ff;
            border: 1px solid #dbeafe;
            margin-bottom: 10px;
        }

        .danger-label {
            color: #991b1b;
            background: #fee2e2;
            border: 1px solid #fecaca;
            margin-bottom: 10px;
        }

        .profile-section-header h2 {
            margin: 0;
            color: #0f172a;
            font-size: clamp(26px, 2.8vw, 40px);
            line-height: 1.08;
            letter-spacing: -0.045em;
            font-weight: 950;
        }

        .profile-section-header p {
            margin: 10px 0 0;
            color: #64748b;
            font-size: 16px;
            line-height: 1.6;
            font-weight: 650;
        }

        .danger-icon {
            color: #dc2626;
            background: #fee2e2;
            border: 1px solid #fecaca;
        }

        .profile-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .profile-btn {
            min-height: 52px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            padding: 0 18px;
            border-radius: 16px;
            text-decoration: none;
            font-size: 15px;
            font-weight: 950;
            transition: 180ms ease;
        }

        .profile-btn svg {
            width: 19px;
            height: 19px;
        }

        .profile-btn:hover {
            transform: translateY(-2px);
        }

        .profile-btn-primary {
            color: #ffffff;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            box-shadow: 0 16px 34px rgba(37, 99, 235, 0.28);
        }

        .profile-btn-secondary {
            color: #1d4ed8;
            background: #eff6ff;
            border: 1px solid #dbeafe;
        }

        .profile-btn-danger {
            color: #ffffff;
            background: linear-gradient(135deg, #dc2626, #b91c1c);
            box-shadow: 0 16px 34px rgba(220, 38, 38, 0.20);
        }

        @keyframes profileAurora {
            to {
                transform: rotate(360deg);
            }
        }

        @keyframes profileFloatOne {
            0%, 100% {
                transform: translate3d(0, 0, 0) scale(1);
            }

            50% {
                transform: translate3d(-38px, 28px, 0) scale(1.12);
            }
        }

        @keyframes profileFloatTwo {
            0%, 100% {
                transform: translate3d(0, 0, 0) scale(1);
            }

            50% {
                transform: translate3d(48px, -22px, 0) scale(1.14);
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.001ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.001ms !important;
                scroll-behavior: auto !important;
            }
        }

        @media (max-width: 960px) {
            .profile-grid {
                grid-template-columns: 1fr;
            }

            .profile-hero-content {
                align-items: flex-start;
                flex-direction: column;
            }
        }

        @media (max-width: 640px) {
            .profile-page {
                gap: 16px;
            }

            .profile-hero,
            .profile-card,
            .profile-action-card,
            .profile-danger-card {
                border-radius: 22px;
            }

            .profile-avatar-large {
                width: 88px;
                height: 88px;
                border-radius: 26px;
                font-size: 36px;
            }

            .profile-hero h1 {
                font-size: 38px;
            }

            .profile-section-header {
                flex-direction: column;
            }

            .profile-btn {
                width: 100%;
            }
        }
    </style>
{% endblock %}