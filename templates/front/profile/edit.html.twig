{% extends 'front/layout.html.twig' %}

{% block front_content %}
<div style="max-width:620px; margin:50px auto; padding:0 16px;">

    <div style="background:white; border-radius:18px; padding:34px; box-shadow:0 12px 30px rgba(15,23,42,0.10);">
        <div style="text-align:center; margin-bottom:28px;">
            <div style="width:64px; height:64px; border-radius:50%; background:#dbeafe; color:#1d4ed8; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:22px; font-weight:800;">
                PR
            </div>

            <h1 style="margin:0; color:#111827;">Edit Profile</h1>
            <p style="margin:10px 0 0; color:#6b7280;">
                Update your personal information below.
            </p>
        </div>

        {% for message in app.flashes('error') %}
            <div style="background:#fee2e2; color:#991b1b; padding:12px 14px; border-radius:10px; margin-bottom:16px; font-weight:600;">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div style="background:#dcfce7; color:#166534; padding:12px 14px; border-radius:10px; margin-bottom:16px; font-weight:600;">
                {{ message }}
            </div>
        {% endfor %}

        <form method="post" onsubmit="return confirmUpdateProfile()">
            <div style="margin-bottom:16px;">
                <label for="fullName" style="display:block; margin-bottom:8px; font-weight:700; color:#374151;">
                    Full Name
                </label>
                <input
                    id="fullName"
                    type="text"
                    name="fullName"
                    value="{{ user.fullName }}"
                    required
                    class="input"
                    placeholder="Enter your full name"
                    style="width:100%; padding:13px 14px; border:1px solid #d1d5db; border-radius:10px; font-size:15px;"
                >
            </div>

            <div style="margin-bottom:22px;">
                <label for="email" style="display:block; margin-bottom:8px; font-weight:700; color:#374151;">
                    Email Address
                </label>
                <input
                    id="email"
                    type="email"
                    name="email"
                    value="{{ user.email }}"
                    required
                    class="input"
                    placeholder="Enter your email address"
                    style="width:100%; padding:13px 14px; border:1px solid #d1d5db; border-radius:10px; font-size:15px;"
                >
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%; padding:14px; border-radius:10px; font-size:16px; font-weight:700;">
                Save Changes
            </button>
        </form>

        <div style="text-align:center; margin-top:20px;">
            <a href="{{ path('front_profile') }}" style="color:#6b7280; text-decoration:none; font-weight:600;">
                Back to Profile
            </a>
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function confirmUpdateProfile() {
    const ok = confirm("Are you sure you want to update your profile?");
    if (ok) {
        announceText("Updating your profile");
        speakText("Updating your profile");
    }
    return ok;
}
</script>
{% endblock %}