{% extends 'front/layout.html.twig' %}

{% block front_content %}
    <main class="profile-edit-page">
        <section class="profile-edit-card">
            <div class="profile-edit-bg" aria-hidden="true">
                <span class="profile-orb profile-orb-one"></span>
                <span class="profile-orb profile-orb-two"></span>
            </div>

            <header class="profile-edit-header">
                <div class="profile-edit-avatar">
                    {{ user.fullName|slice(0, 1)|upper }}
                </div>

                <span class="profile-kicker">
                    <i data-lucide="user-pen"></i>
                    Profile Settings
                </span>

                <h1>Edit Profile</h1>

                <p>
                    Update your personal information below.
                </p>
            </header>

            {% for message in app.flashes('error') %}
                <div class="profile-alert profile-alert-error">
                    <i data-lucide="triangle-alert"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            {% for message in app.flashes('success') %}
                <div class="profile-alert profile-alert-success">
                    <i data-lucide="circle-check"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}

            <form method="post" onsubmit="return confirmUpdateProfile()" class="profile-edit-form">
                <div class="profile-form-group">
                    <label for="fullName">Full Name</label>

                    <div class="profile-input-wrap">
                        <i data-lucide="id-card"></i>

                        <input
                            id="fullName"
                            type="text"
                            name="fullName"
                            value="{{ user.fullName }}"
                            required
                            class="profile-input"
                            placeholder="Enter your full name"
                        >
                    </div>
                </div>

                <div class="profile-form-group">
                    <label for="email">Email Address</label>

                    <div class="profile-input-wrap">
                        <i data-lucide="mail"></i>

                        <input
                            id="email"
                            type="email"
                            name="email"
                            value="{{ user.email }}"
                            required
                            class="profile-input"
                            placeholder="Enter your email address"
                        >
                    </div>
                </div>

                <button type="submit" class="profile-submit-btn">
                    <i data-lucide="save"></i>
                    Save Changes
                </button>
            </form>

            <div class="profile-back-row">
                <a href="{{ path('front_profile') }}">
                    <i data-lucide="arrow-left"></i>
                    Back to Profile
                </a>
            </div>
        </section>
    </main>

    <style>
        .profile-edit-page,
        .profile-edit-page * {
            box-sizing: border-box;
        }

        .profile-edit-page {
            max-width: 720px;
            margin: 0 auto;
            color: #0f172a;
        }

        .profile-edit-card {
            position: relative;
            overflow: hidden;
            border-radius: 30px;
            padding: clamp(26px, 4vw, 40px);
            background: #ffffff;
            border: 1px solid #e2e8f0;
            box-shadow: 0 24px 70px rgba(15, 23, 42, 0.12);
        }

        .profile-edit-card::before {
            content: "";
            position: absolute;
            inset: 0;
            height: 210px;
            background:
                radial-gradient(circle at 78% 30%, rgba(37, 99, 235, 0.24), transparent 34%),
                linear-gradient(135deg, #071126 0%, #111827 52%, #172554 100%);
            pointer-events: none;
        }

        .profile-edit-card::after {
            content: "";
            position: absolute;
            top: -45%;
            left: -45%;
            width: 190%;
            height: 420px;
            background:
                conic-gradient(
                    from 0deg,
                    transparent,
                    rgba(59, 130, 246, 0.22),
                    transparent,
                    rgba(56, 189, 248, 0.16),
                    transparent,
                    rgba(96, 165, 250, 0.18),
                    transparent
                );
            filter: blur(80px);
            opacity: 0.72;
            animation: profileEditAurora 18s linear infinite;
            pointer-events: none;
        }

        .profile-edit-bg {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .profile-orb {
            position: absolute;
            border-radius: 999px;
            filter: blur(12px);
            opacity: 0.38;
            mix-blend-mode: screen;
        }

        .profile-orb-one {
            width: 190px;
            height: 190px;
            right: 9%;
            top: 4%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.95), transparent 66%);
            animation: profileEditFloatOne 8s ease-in-out infinite;
        }

        .profile-orb-two {
            width: 130px;
            height: 130px;
            left: 9%;
            top: 70px;
            background: radial-gradient(circle, rgba(14, 165, 233, 0.8), transparent 68%);
            animation: profileEditFloatTwo 10s ease-in-out infinite;
        }

        .profile-edit-header,
        .profile-alert,
        .profile-edit-form,
        .profile-back-row {
            position: relative;
            z-index: 1;
        }

        .profile-edit-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .profile-edit-avatar {
            width: 92px;
            height: 92px;
            display: grid;
            place-items: center;
            margin: 0 auto 18px;
            border-radius: 28px;
            color: #ffffff;
            background:
                radial-gradient(circle at 35% 25%, rgba(125, 211, 252, 0.95), transparent 34%),
                linear-gradient(135deg, #2563eb, #1d4ed8);
            font-size: 38px;
            font-weight: 950;
            box-shadow:
                0 0 0 10px rgba(37, 99, 235, 0.18),
                0 22px 46px rgba(37, 99, 235, 0.38);
        }

        .profile-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            width: max-content;
            padding: 7px 12px;
            margin-bottom: 14px;
            border-radius: 999px;
            color: #bfdbfe;
            background: rgba(37, 99, 235, 0.18);
            border: 1px solid rgba(147, 197, 253, 0.24);
            font-size: 11px;
            font-weight: 950;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .profile-kicker svg {
            width: 15px;
            height: 15px;
        }

        .profile-edit-header h1 {
            margin: 0;
            color: #ffffff;
            font-size: clamp(36px, 5vw, 56px);
            line-height: 0.98;
            letter-spacing: -0.06em;
            font-weight: 950;
        }

        .profile-edit-header p {
            margin: 12px 0 0;
            color: #cbd5e1;
            font-size: 17px;
            line-height: 1.5;
            font-weight: 650;
        }

        .profile-alert {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 16px;
            margin-bottom: 16px;
            border-radius: 16px;
            font-weight: 800;
            line-height: 1.4;
        }

        .profile-alert svg {
            width: 20px;
            height: 20px;
            flex: 0 0 auto;
        }

        .profile-alert-error {
            color: #991b1b;
            background: #fee2e2;
            border: 1px solid #fecaca;
        }

        .profile-alert-success {
            color: #166534;
            background: #dcfce7;
            border: 1px solid #86efac;
        }

        .profile-edit-form {
            display: grid;
            gap: 18px;
            margin-top: 28px;
        }

        .profile-form-group {
            display: grid;
            gap: 8px;
        }

        .profile-form-group label {
            color: #334155;
            font-size: 14px;
            font-weight: 900;
        }

        .profile-input-wrap {
            min-height: 60px;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 16px;
            border-radius: 18px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            transition: 180ms ease;
        }

        .profile-input-wrap:focus-within {
            background: #ffffff;
            border-color: #93c5fd;
            box-shadow:
                0 0 0 4px rgba(37, 99, 235, 0.10),
                0 14px 30px rgba(15, 23, 42, 0.07);
        }

        .profile-input-wrap svg {
            width: 22px;
            height: 22px;
            color: #2563eb;
            flex: 0 0 auto;
        }

        .profile-input {
            width: 100%;
            min-height: 56px;
            border: 0;
            outline: 0;
            background: transparent;
            color: #0f172a;
            font-size: 16px;
            font-weight: 750;
        }

        .profile-input::placeholder {
            color: #94a3b8;
        }

        .profile-submit-btn {
            min-height: 58px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            margin-top: 6px;
            border: 0;
            border-radius: 18px;
            color: #ffffff;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            box-shadow: 0 18px 38px rgba(37, 99, 235, 0.30);
            font-size: 16px;
            font-weight: 950;
            cursor: pointer;
            transition: 180ms ease;
        }

        .profile-submit-btn svg {
            width: 20px;
            height: 20px;
        }

        .profile-submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 22px 44px rgba(37, 99, 235, 0.38);
        }

        .profile-back-row {
            display: flex;
            justify-content: center;
            margin-top: 22px;
        }

        .profile-back-row a {
            min-height: 46px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 0 14px;
            border-radius: 999px;
            color: #1d4ed8;
            background: #eff6ff;
            border: 1px solid #dbeafe;
            text-decoration: none;
            font-size: 14px;
            font-weight: 900;
            transition: 180ms ease;
        }

        .profile-back-row a:hover {
            transform: translateY(-2px);
            background: #dbeafe;
        }

        .profile-back-row svg {
            width: 17px;
            height: 17px;
        }

        @keyframes profileEditAurora {
            to {
                transform: rotate(360deg);
            }
        }

        @keyframes profileEditFloatOne {
            0%, 100% {
                transform: translate3d(0, 0, 0) scale(1);
            }

            50% {
                transform: translate3d(-34px, 26px, 0) scale(1.12);
            }
        }

        @keyframes profileEditFloatTwo {
            0%, 100% {
                transform: translate3d(0, 0, 0) scale(1);
            }

            50% {
                transform: translate3d(38px, -18px, 0) scale(1.14);
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.001ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.001ms !important;
                scroll-behavior: auto !important;
            }
        }

        @media (max-width: 640px) {
            .profile-edit-card {
                border-radius: 24px;
                padding: 24px 18px;
            }

            .profile-edit-avatar {
                width: 82px;
                height: 82px;
                border-radius: 24px;
                font-size: 34px;
            }

            .profile-edit-header h1 {
                font-size: 38px;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        function confirmUpdateProfile() {
            const ok = confirm("Are you sure you want to update your profile?");

            if (ok) {
                if (typeof announceText === 'function') {
                    announceText("Updating your profile");
                }

                if (typeof speakText === 'function') {
                    speakText("Updating your profile");
                }
            }

            return ok;
        }

        document.addEventListener('DOMContentLoaded', function () {
            if (window.lucide) {
                lucide.createIcons();
            }
        });
    </script>
{% endblock %}