{% extends 'front/layout.html.twig' %}

{% block front_content %}
<div style="max-width:560px; margin:60px auto; padding:0 16px;">

    <div style="background:white; border-radius:18px; padding:34px; text-align:center; box-shadow:0 12px 30px rgba(15,23,42,0.10); border:1px solid #fecaca;">
        <div style="width:64px; height:64px; border-radius:50%; background:#fee2e2; color:#991b1b; display:flex; align-items:center; justify-content:center; margin:0 auto 16px; font-size:22px; font-weight:800;">
            DEL
        </div>

        <h1 style="margin:0; color:#991b1b;">Delete Account</h1>

        <p style="margin:16px 0 0; color:#6b7280; line-height:1.7;">
            This action is permanent. Once your account is deleted, your profile, files, and command history may be removed permanently.
        </p>

        <div style="margin:24px 0; padding:16px; background:#fff7f7; border:1px solid #fecaca; border-radius:12px; text-align:left;">
            <strong style="display:block; color:#991b1b; margin-bottom:8px;">
                Before deleting your account:
            </strong>
            <p style="margin:0; color:#7f1d1d; line-height:1.6;">
                Make sure you no longer need access to your files or voice command history. This operation cannot be undone.
            </p>
        </div>

        <form method="post" onsubmit="return confirmDeleteAccount()">
            <input type="hidden" name="_token" value="{{ csrf_token('delete-account') }}">

            <button type="submit" class="btn btn-danger" style="width:100%; padding:14px; border-radius:10px; font-size:16px; font-weight:700;">
                Yes, Delete My Account
            </button>
        </form>

        <a href="{{ path('front_profile') }}" style="display:block; margin-top:18px; color:#6b7280; text-decoration:none; font-weight:600;">
            Cancel and Return to Profile
        </a>
    </div>

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function confirmDeleteAccount() {
    const ok = confirm("Final confirmation: delete your account permanently?");
    if (ok) {
        announceText("Deleting your account");
        speakText("Deleting your account");
    }
    return ok;
}
</script>
{% endblock %}