{% extends 'front/layout.html.twig' %}

{% block front_content %}
    <main class="delete-account-page">
        <section class="delete-account-card">
            <div class="delete-bg" aria-hidden="true">
                <span class="delete-orb delete-orb-one"></span>
                <span class="delete-orb delete-orb-two"></span>
            </div>

            <header class="delete-header">
                <div class="delete-icon">
                    <i data-lucide="triangle-alert"></i>
                </div>

                <span class="delete-kicker">
                    <i data-lucide="shield-alert"></i>
                    Critical Account Action
                </span>

                <h1>Delete Account</h1>

                <p>
                    This action is permanent. Once your account is deleted, your profile,
                    files, and command history may be removed permanently.
                </p>
            </header>

            <div class="delete-warning-box">
                <div class="delete-warning-icon">
                    <i data-lucide="info"></i>
                </div>

                <div>
                    <strong>Before deleting your account</strong>
                    <p>
                        Make sure you no longer need access to your files or voice command history.
                        This operation cannot be undone.
                    </p>
                </div>
            </div>

            <form method="post" onsubmit="return confirmDeleteAccount()" class="delete-form">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-account') }}">

                <button type="submit" class="delete-submit-btn">
                    <i data-lucide="trash-2"></i>
                    Yes, Delete My Account
                </button>
            </form>

            <a href="{{ path('front_profile') }}" class="delete-cancel-link">
                <i data-lucide="arrow-left"></i>
                Cancel and Return to Profile
            </a>
        </section>
    </main>

    <style>
        .delete-account-page,
        .delete-account-page * {
            box-sizing: border-box;
        }

        .delete-account-page {
            max-width: 660px;
            margin: 0 auto;
            color: #0f172a;
        }

        .delete-account-card {
            position: relative;
            overflow: hidden;
            border-radius: 30px;
            padding: clamp(26px, 4vw, 40px);
            background: #ffffff;
            border: 1px solid #fecaca;
            box-shadow: 0 24px 70px rgba(15, 23, 42, 0.12);
        }

        .delete-account-card::before {
            content: "";
            position: absolute;
            inset: 0;
            height: 230px;
            background:
                radial-gradient(circle at 78% 30%, rgba(220, 38, 38, 0.24), transparent 34%),
                linear-gradient(135deg, #2b0707 0%, #450a0a 52%, #7f1d1d 100%);
            pointer-events: none;
        }

        .delete-account-card::after {
            content: "";
            position: absolute;
            top: -45%;
            left: -45%;
            width: 190%;
            height: 440px;
            background:
                conic-gradient(
                    from 0deg,
                    transparent,
                    rgba(248, 113, 113, 0.22),
                    transparent,
                    rgba(251, 146, 60, 0.16),
                    transparent,
                    rgba(220, 38, 38, 0.18),
                    transparent
                );
            filter: blur(80px);
            opacity: 0.72;
            animation: deleteAurora 18s linear infinite;
            pointer-events: none;
        }

        .delete-bg {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .delete-orb {
            position: absolute;
            border-radius: 999px;
            filter: blur(12px);
            opacity: 0.36;
            mix-blend-mode: screen;
        }

        .delete-orb-one {
            width: 190px;
            height: 190px;
            right: 9%;
            top: 4%;
            background: radial-gradient(circle, rgba(248, 113, 113, 0.95), transparent 66%);
            animation: deleteFloatOne 8s ease-in-out infinite;
        }

        .delete-orb-two {
            width: 130px;
            height: 130px;
            left: 9%;
            top: 76px;
            background: radial-gradient(circle, rgba(251, 146, 60, 0.72), transparent 68%);
            animation: deleteFloatTwo 10s ease-in-out infinite;
        }

        .delete-header,
        .delete-warning-box,
        .delete-form,
        .delete-cancel-link {
            position: relative;
            z-index: 1;
        }

        .delete-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .delete-icon {
            width: 92px;
            height: 92px;
            display: grid;
            place-items: center;
            margin: 0 auto 18px;
            border-radius: 28px;
            color: #ffffff;
            background:
                radial-gradient(circle at 35% 25%, rgba(254, 202, 202, 0.95), transparent 34%),
                linear-gradient(135deg, #dc2626, #991b1b);
            box-shadow:
                0 0 0 10px rgba(220, 38, 38, 0.18),
                0 22px 46px rgba(220, 38, 38, 0.34);
        }

        .delete-icon svg {
            width: 42px;
            height: 42px;
        }

        .delete-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            width: max-content;
            padding: 7px 12px;
            margin-bottom: 14px;
            border-radius: 999px;
            color: #fecaca;
            background: rgba(220, 38, 38, 0.18);
            border: 1px solid rgba(254, 202, 202, 0.28);
            font-size: 11px;
            font-weight: 950;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .delete-kicker svg {
            width: 15px;
            height: 15px;
        }

        .delete-header h1 {
            margin: 0;
            color: #ffffff;
            font-size: clamp(36px, 5vw, 56px);
            line-height: 0.98;
            letter-spacing: -0.06em;
            font-weight: 950;
        }

        .delete-header p {
            max-width: 520px;
            margin: 12px auto 0;
            color: #fee2e2;
            font-size: 17px;
            line-height: 1.55;
            font-weight: 650;
        }

        .delete-warning-box {
            display: flex;
            gap: 14px;
            align-items: flex-start;
            margin-top: 28px;
            margin-bottom: 22px;
            padding: 18px;
            border-radius: 20px;
            background: #fff7f7;
            border: 1px solid #fecaca;
        }

        .delete-warning-icon {
            width: 46px;
            height: 46px;
            flex: 0 0 auto;
            display: grid;
            place-items: center;
            border-radius: 16px;
            color: #dc2626;
            background: #fee2e2;
            border: 1px solid #fecaca;
        }

        .delete-warning-icon svg {
            width: 22px;
            height: 22px;
        }

        .delete-warning-box strong {
            display: block;
            color: #991b1b;
            font-size: 16px;
            font-weight: 950;
            margin-bottom: 7px;
        }

        .delete-warning-box p {
            margin: 0;
            color: #7f1d1d;
            font-size: 15px;
            line-height: 1.6;
            font-weight: 650;
        }

        .delete-form {
            margin-top: 18px;
        }

        .delete-submit-btn {
            min-height: 58px;
            width: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            border: 0;
            border-radius: 18px;
            color: #ffffff;
            background: linear-gradient(135deg, #dc2626, #991b1b);
            box-shadow: 0 18px 38px rgba(220, 38, 38, 0.28);
            font-size: 16px;
            font-weight: 950;
            cursor: pointer;
            transition: 180ms ease;
        }

        .delete-submit-btn svg {
            width: 20px;
            height: 20px;
        }

        .delete-submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 22px 44px rgba(220, 38, 38, 0.36);
        }

        .delete-cancel-link {
            min-height: 46px;
            width: max-content;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin: 22px auto 0;
            padding: 0 14px;
            border-radius: 999px;
            color: #64748b;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            text-decoration: none;
            font-size: 14px;
            font-weight: 900;
            transition: 180ms ease;
        }

        .delete-cancel-link:hover {
            transform: translateY(-2px);
            color: #1d4ed8;
            background: #eff6ff;
            border-color: #dbeafe;
        }

        .delete-cancel-link svg {
            width: 17px;
            height: 17px;
        }

        @keyframes deleteAurora {
            to {
                transform: rotate(360deg);
            }
        }

        @keyframes deleteFloatOne {
            0%, 100% {
                transform: translate3d(0, 0, 0) scale(1);
            }

            50% {
                transform: translate3d(-34px, 26px, 0) scale(1.12);
            }
        }

        @keyframes deleteFloatTwo {
            0%, 100% {
                transform: translate3d(0, 0, 0) scale(1);
            }

            50% {
                transform: translate3d(38px, -18px, 0) scale(1.14);
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.001ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.001ms !important;
                scroll-behavior: auto !important;
            }
        }

        @media (max-width: 640px) {
            .delete-account-card {
                border-radius: 24px;
                padding: 24px 18px;
            }

            .delete-icon {
                width: 82px;
                height: 82px;
                border-radius: 24px;
            }

            .delete-icon svg {
                width: 36px;
                height: 36px;
            }

            .delete-header h1 {
                font-size: 38px;
            }

            .delete-warning-box {
                flex-direction: column;
            }

            .delete-cancel-link {
                width: 100%;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        function confirmDeleteAccount() {
            const ok = confirm("Final confirmation: delete your account permanently?");

            if (ok) {
                if (typeof announceText === 'function') {
                    announceText("Deleting your account");
                }

                if (typeof speakText === 'function') {
                    speakText("Deleting your account");
                }
            }

            return ok;
        }

        document.addEventListener('DOMContentLoaded', function () {
            if (window.lucide) {
                lucide.createIcons();
            }
        });
    </script>
{% endblock %}