{% extends 'front/layout.html.twig' %}

{% block front_content %}
    <div class="voice-hero">
        <div>
            <span class="voice-eyebrow">Accessible Voice Assistant</span>
            <h1 class="voice-title">Control the web platform with your voice</h1>
            <p class="voice-subtitle">
                Use the microphone button or press <strong>Space</strong> to speak a web-safe command.
                The assistant can navigate inside the platform, search supported websites, and give spoken feedback.
            </p>
        </div>
    </div>

    <div class="voice-grid">
        <section class="voice-main-card">
            <div class="voice-card-header">
                <div>
                    <h2>Voice Control Panel</h2>
                    <p>
                        Designed for accessibility: fewer clicks, clear spoken feedback, and simple keyboard interaction.
                    </p>
                </div>

                <div id="voiceStateBadge" class="voice-badge voice-badge-idle">
                    Idle
                </div>
            </div>

            <button
                id="voiceToggleBtn"
                class="voice-button"
                type="button"
                aria-pressed="false"
                aria-describedby="voiceHelpText"
            >
                <span id="voiceToggleBtnText">Start Listening</span>
            </button>

            <p id="voiceHelpText" class="voice-help">
                Shortcut: press Space to start or stop listening. The shortcut is disabled while typing in a form field.
            </p>

            <div class="voice-status-grid">
                <div class="voice-status-card">
                    <span>Listening Status</span>
                    <strong id="listeningStatus" aria-live="polite" aria-atomic="true">
                        Voice assistant is idle.
                    </strong>
                </div>

                <div class="voice-status-card">
                    <span>Recognised Speech</span>
                    <strong id="recognizedText" aria-live="polite" aria-atomic="true">
                        Nothing recognised yet.
                    </strong>
                </div>

                <div class="voice-status-card voice-status-card-wide">
                    <span>Assistant Response</span>
                    <strong id="voiceResult" aria-live="assertive" aria-atomic="true">
                        Waiting for your command.
                    </strong>
                </div>
            </div>
        </section>

        <aside class="voice-side">
            <div class="voice-info-card">
                <h3>How this web assistant works</h3>
                <ol>
                    <li>Press the main button or press Space.</li>
                    <li>Speak clearly after the listening message.</li>
                    <li>The assistant validates the command before executing it.</li>
                    <li>External websites open in one reusable browser tab to avoid tab spam.</li>
                    <li>The assistant remains active in this original tab.</li>
                </ol>
            </div>

            <div class="voice-info-card">
                <h3>Accessibility focus</h3>
                <p>
                    The web version is designed for safe web navigation and assisted browsing. It does not execute local
                    computer actions such as creating, deleting, or modifying files.
                </p>
            </div>

            <div class="voice-info-card">
                <h3>Keyboard shortcut</h3>
                <div class="shortcut-display">
                    <span>Space</span>
                </div>
                <p>
                    One large key makes the interaction easier for users with reduced hand mobility.
                </p>
            </div>

            <div class="voice-info-card">
                <h3>Supported examples</h3>
                <div class="command-list">
                    <span>Help</span>
                    <span>What can I say?</span>
                    <span>Open profile</span>
                    <span>Show my files</span>
                    <span>Go home</span>
                    <span>Log out</span>
                    <span>Open YouTube</span>
                    <span>Search Google for Symfony</span>
                    <span>Find music on YouTube</span>
                    <span>Find football news on Facebook</span>
                </div>
            </div>
        </aside>
    </div>

    <style>
        .voice-hero {
            background: linear-gradient(135deg, #eef6ff 0%, #ffffff 70%);
            border: 1px solid #e5e7eb;
            border-radius: 22px;
            padding: 30px;
            margin-bottom: 24px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
        }

        .voice-eyebrow {
            display: inline-block;
            margin-bottom: 10px;
            padding: 6px 12px;
            border-radius: 999px;
            background: #dbeafe;
            color: #1d4ed8;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.02em;
            text-transform: uppercase;
        }

        .voice-title {
            margin: 0;
            color: #111827;
            font-size: 34px;
            line-height: 1.15;
        }

        .voice-subtitle {
            max-width: 780px;
            margin: 12px 0 0;
            color: #6b7280;
            line-height: 1.7;
            font-size: 16px;
        }

        .voice-grid {
            display: grid;
            grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.8fr);
            gap: 22px;
            align-items: start;
        }

        .voice-main-card,
        .voice-info-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.07);
        }

        .voice-main-card {
            padding: 28px;
        }

        .voice-card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            margin-bottom: 24px;
        }

        .voice-card-header h2,
        .voice-info-card h3 {
            margin: 0 0 8px;
            color: #111827;
        }

        .voice-card-header p,
        .voice-info-card p,
        .voice-info-card li {
            color: #6b7280;
            line-height: 1.6;
        }

        .voice-badge {
            min-width: 86px;
            text-align: center;
            padding: 8px 12px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 800;
        }

        .voice-badge-idle {
            background: #f3f4f6;
            color: #374151;
        }

        .voice-badge-listening {
            background: #dcfce7;
            color: #166534;
        }

        .voice-badge-processing {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .voice-badge-error {
            background: #fee2e2;
            color: #991b1b;
        }

        .voice-button {
            width: 100%;
            min-height: 76px;
            border: none;
            border-radius: 18px;
            background: #2563eb;
            color: #ffffff;
            font-size: 22px;
            font-weight: 800;
            cursor: pointer;
            transition: transform 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
            box-shadow: 0 14px 30px rgba(37, 99, 235, 0.25);
        }

        .voice-button:hover {
            background: #1d4ed8;
            transform: translateY(-1px);
        }

        .voice-button.listening {
            background: #dc2626;
            box-shadow: 0 14px 30px rgba(220, 38, 38, 0.22);
        }

        .voice-button.listening:hover {
            background: #b91c1c;
        }

        .voice-help {
            margin: 14px 0 22px;
            color: #6b7280;
            font-size: 14px;
        }

        .voice-status-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
        }

        .voice-status-card {
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 16px;
            background: #f9fafb;
        }

        .voice-status-card-wide {
            grid-column: 1 / -1;
        }

        .voice-status-card span {
            display: block;
            color: #6b7280;
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .voice-status-card strong {
            display: block;
            color: #111827;
            font-size: 15px;
            line-height: 1.6;
            word-break: break-word;
        }

        .voice-side {
            display: grid;
            gap: 18px;
        }

        .voice-info-card {
            padding: 22px;
        }

        .voice-info-card ol {
            margin: 10px 0 0;
            padding-left: 22px;
        }

        .shortcut-display {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 120px;
            padding: 12px 18px;
            border-radius: 14px;
            background: #111827;
            color: #ffffff;
            font-size: 18px;
            font-weight: 800;
            margin: 8px 0 12px;
        }

        .command-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 12px;
        }

        .command-list span {
            display: inline-block;
            padding: 8px 12px;
            border-radius: 999px;
            background: #f3f4f6;
            color: #374151;
            font-size: 14px;
            font-weight: 700;
        }

        @media (max-width: 900px) {
            .voice-grid {
                grid-template-columns: 1fr;
            }

            .voice-title {
                font-size: 28px;
            }

            .voice-card-header {
                flex-direction: column;
            }

            .voice-status-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('voiceToggleBtn');
            const toggleBtnText = document.getElementById('voiceToggleBtnText');
            const listeningStatus = document.getElementById('listeningStatus');
            const recognizedText = document.getElementById('recognizedText');
            const voiceResult = document.getElementById('voiceResult');
            const voiceStateBadge = document.getElementById('voiceStateBadge');

            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

            let recognition = null;
            let isListening = false;
            let hasSpeechSupport = !!SpeechRecognition;
            let assistantWebsiteTab = null;

            function isTypingTarget(target) {
                if (!target) {
                    return false;
                }

                const tagName = target.tagName ? target.tagName.toLowerCase() : '';

                return (
                    tagName === 'input' ||
                    tagName === 'textarea' ||
                    tagName === 'select' ||
                    target.isContentEditable
                );
            }

            function isHelpCommand(text) {
                const normalized = text.toLowerCase().trim();

                return (
                    normalized === 'help' ||
                    normalized === 'voice help' ||
                    normalized === 'show commands' ||
                    normalized === 'available commands' ||
                    normalized === 'what can i say' ||
                    normalized === 'what can i do' ||
                    normalized.includes('what can i say') ||
                    normalized.includes('show me commands') ||
                    normalized.includes('help me')
                );
            }

            function looksLikeWebsiteCommand(text) {
                const normalized = text.toLowerCase();

                return (
                    normalized.includes('youtube') ||
                    normalized.includes('google') ||
                    normalized.includes('facebook')
                );
            }

            function setListeningState(listening) {
                isListening = listening;
                toggleBtn.setAttribute('aria-pressed', listening ? 'true' : 'false');
                toggleBtn.classList.toggle('listening', listening);
                toggleBtnText.textContent = listening ? 'Stop Listening' : 'Start Listening';
                listeningStatus.textContent = listening ? 'Listening now. Speak your command.' : 'Voice assistant is idle.';

                voiceStateBadge.textContent = listening ? 'Listening' : 'Idle';
                voiceStateBadge.classList.remove('voice-badge-idle', 'voice-badge-listening', 'voice-badge-processing', 'voice-badge-error');
                voiceStateBadge.classList.add(listening ? 'voice-badge-listening' : 'voice-badge-idle');
            }

            function setAssistantStatus(message, speak = true, badgeState = 'idle') {
                voiceResult.textContent = message;
                announceText(message);

                voiceStateBadge.classList.remove('voice-badge-idle', 'voice-badge-listening', 'voice-badge-processing', 'voice-badge-error');

                if (badgeState === 'processing') {
                    voiceStateBadge.textContent = 'Processing';
                    voiceStateBadge.classList.add('voice-badge-processing');
                } else if (badgeState === 'error') {
                    voiceStateBadge.textContent = 'Error';
                    voiceStateBadge.classList.add('voice-badge-error');
                } else if (badgeState === 'listening') {
                    voiceStateBadge.textContent = 'Listening';
                    voiceStateBadge.classList.add('voice-badge-listening');
                } else {
                    voiceStateBadge.textContent = 'Idle';
                    voiceStateBadge.classList.add('voice-badge-idle');
                }

                if (speak) {
                    speakText(message);
                }
            }
function openWebsiteInSingleTab(data) {
    const websiteName = data.websiteName || data.website || 'the website';

    if ((data.website || '').toLowerCase() === 'youtube' && data.action === 'search' && data.query) {
        window.location.href = '{{ path('front_youtube_assistant') }}?q=' + encodeURIComponent(data.query);
        return;
    }

    const queryText = data.query ? ' for "' + data.query + '"' : '';
    const actionText = data.action === 'search'
        ? 'searching ' + websiteName + queryText
        : 'opening ' + websiteName;

    const message =
        'I found a supported web command. I am ' + actionText +
        ' in one separate browser tab. Your voice assistant will stay available here.';

    setAssistantStatus(message, true, 'idle');

    if (assistantWebsiteTab && !assistantWebsiteTab.closed) {
        assistantWebsiteTab.location.href = data.url;
        assistantWebsiteTab.focus();
        return;
    }

    assistantWebsiteTab = window.open(data.url, 'voice_assistant_external_site');

    if (!assistantWebsiteTab) {
        setAssistantStatus(
            'The browser blocked the external tab. Please allow pop-ups for this website, then repeat your command.',
            true,
            'error'
        );
    }
}
                
            function sendVoiceCommand(text) {
               if (isHelpCommand(text)) {
    const helpMessage =
        'Here are some commands you can say: open profile, show my files, go home, log out, open YouTube, search Google for a topic, or find videos on YouTube. ' +
        'This web assistant only performs safe web actions and does not modify local computer files.';

    setAssistantStatus(helpMessage, true, 'idle');
    return;
}

                const endpoint = looksLikeWebsiteCommand(text)
                    ? '{{ path('api_voice_interpret') }}'
                    : '{{ path('voice_execute') }}';

                console.log('VOICE ENDPOINT:', endpoint);

                setAssistantStatus('Processing your command: ' + text, false, 'processing');

                fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ text: text })
                })
                    .then(function (response) {
                        return response.json();
                    })
                    .then(function (data) {
    console.log('VOICE RESPONSE:', data);

    if (data.success && data.intent === 'WEBSITE_ACTION' && data.url) {
        openWebsiteInSingleTab(data);
        return;
    }

    if (!data.success) {
        const failMessage =
            (data.message || 'I could not match that to a supported web action.') +
            ' You can say "what can I say" to hear available commands.';

        setAssistantStatus(failMessage, true, 'error');
        return;
    }

    const spokenReply =
        (data.execution && data.execution.speech) ||
        data.message ||
        'Command completed successfully.';

    setAssistantStatus(spokenReply, true, 'idle');

    if (data.execution && data.execution.redirect) {
        setTimeout(function () {
            window.location.href = data.execution.redirect;
        }, 1400);
    }
})
                    .catch(function () {
                        setAssistantStatus(
                            'A connection error happened while processing your command. Please check the server and try again.',
                            true,
                            'error'
                        );
                    });
            }

            function startListening() {
                if (!hasSpeechSupport) {
                    setAssistantStatus('Voice recognition is not supported in this browser. Please use Google Chrome.', true, 'error');
                    return;
                }

                if (!recognition) {
                    recognition = new SpeechRecognition();
                    recognition.lang = 'en-US';
                    recognition.interimResults = false;
                    recognition.continuous = false;

                    recognition.onstart = function () {
                        setListeningState(true);
                        voiceResult.textContent = 'Listening now. Please speak your command.';
                        announceText('Listening now. Please speak your command.');
                    };

                    recognition.onend = function () {
                        setListeningState(false);
                    };

                    recognition.onerror = function (event) {
                        setListeningState(false);

                        let message = 'A voice recognition error happened. Please try again.';

                        if (event.error === 'not-allowed') {
                            message = 'Microphone permission was denied. Please allow microphone access and try again.';
                        } else if (event.error === 'no-speech') {
                            message = 'I did not hear anything. Press Space or Start Listening and speak your command.';
                        } else if (event.error === 'audio-capture') {
                            message = 'No microphone was found. Please check your microphone.';
                        } else if (event.error === 'network') {
                            message = 'Speech recognition needs a network connection. Please check your internet and try again.';
                        }

                        setAssistantStatus(message, true, 'error');
                    };

                    recognition.onresult = function (event) {
                        const text = event.results[0][0].transcript.trim();
                        recognizedText.textContent = text;

                        sendVoiceCommand(text);
                    };
                }

                try {
                    recognition.start();
                } catch (error) {
                    setAssistantStatus('The microphone is already starting. Please wait a moment.', true, 'error');
                }
            }

            function stopListening() {
                if (recognition && isListening) {
                    recognition.stop();
                    setAssistantStatus('Listening stopped. Press Space when you want to speak again.', true, 'idle');
                }
            }

            function toggleListening() {
                if (isListening) {
                    stopListening();
                } else {
                    startListening();
                }
            }

            toggleBtn.addEventListener('click', function () {
                toggleListening();
            });

            document.addEventListener('keydown', function (event) {
                if (event.code === 'Space' && !event.ctrlKey && !event.altKey && !event.shiftKey && !event.metaKey) {
                    if (isTypingTarget(event.target)) {
                        return;
                    }

                    event.preventDefault();
                    toggleListening();
                }
            });

            if (!hasSpeechSupport) {
                setAssistantStatus('Voice recognition is not supported in this browser. Please use Google Chrome.', false, 'error');
            } else {
                setAssistantStatus('Voice assistant ready. Press the main button or press Space.', true, 'idle');
            }
        });
    </script>
{% endblock %}