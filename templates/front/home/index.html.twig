{% extends 'front/layout.html.twig' %}
{% block front_content %}
    <main class="voice-page" aria-label="Accessible voice assistant interface">
        <div class="voice-bg-motion" aria-hidden="true">
            <span class="orb orb-one"></span>
            <span class="orb orb-two"></span>
            <span class="orb orb-three"></span>
            <span class="mesh-line mesh-line-one"></span>
            <span class="mesh-line mesh-line-two"></span>
            <span class="mesh-line mesh-line-three"></span>
        </div>

        <section class="voice-shell">
            <header class="voice-header">
                <span class="voice-eyebrow">
                    <span></span>
                    Accessible Voice Assistant
                </span>

                <h1 class="voice-title">
                    <span>Voice</span>
                    <span>Assistant</span>
                </h1>

                <p class="voice-subtitle">
                    Tap once. Speak naturally. Let the interface move with you.
                </p>
            </header>

            <section class="voice-stage" aria-label="Voice control panel">
                <div class="voice-status-orbit">
                    <div id="voiceStateBadge" class="voice-badge voice-badge-idle">
                        Idle
                    </div>
                </div>

                <button
                    id="voiceToggleBtn"
                    class="voice-button"
                    type="button"
                    aria-pressed="false"
                    aria-describedby="voiceHelpText"
                    aria-label="Start or stop voice listening"
                >
                    <span class="voice-energy-ring ring-one" aria-hidden="true"></span>
                    <span class="voice-energy-ring ring-two" aria-hidden="true"></span>
                    <span class="voice-energy-ring ring-three" aria-hidden="true"></span>

                    <span class="voice-particles" aria-hidden="true">
                        {% for i in 1..28 %}
                            <span style="--i: {{ i }}"></span>
                        {% endfor %}
                    </span>

                    <span class="voice-waveform" aria-hidden="true">
                        {% for i in 1..64 %}
                            <span style="--i: {{ i }}"></span>
                        {% endfor %}
                    </span>

                    <span class="voice-core">
                        <span class="voice-core-glow" aria-hidden="true"></span>

                        <svg class="voice-mic-icon" viewBox="0 0 64 64" aria-hidden="true">
                            <path d="M32 39c6.1 0 11-4.9 11-11V17c0-6.1-4.9-11-11-11S21 10.9 21 17v11c0 6.1 4.9 11 11 11Z"/>
                            <path d="M15 27v1c0 9.4 7.6 17 17 17s17-7.6 17-17v-1"/>
                            <path d="M32 45v11"/>
                            <path d="M23 56h18"/>
                        </svg>
                    </span>

                    <span id="voiceToggleBtnText" class="voice-button-text">
                        Start Listening
                    </span>
                </button>

                <div class="voice-main-copy">
                    <h2 id="listeningStatus" aria-live="polite" aria-atomic="true">
                        Ready to listen
                    </h2>

                    <p id="voiceHelpText">
                        Press the glowing microphone or hit Space.
                    </p>
                </div>

                <div class="voice-language-pill">
                    <span class="voice-language-icon" aria-hidden="true">◉</span>
                    <label class="sr-only" for="voiceLanguageSelect">Voice Language</label>
                    <select id="voiceLanguageSelect" class="voice-language-select" aria-label="Voice recognition language">
                        <option value="en-US">English</option>
                        <option value="fr-FR">Français</option>
                        <option value="ar-TN">العربية / Tunisian Arabic</option>
                        <option value="ar-SA">العربية الفصحى</option>
                        <option value="es-ES">Español</option>
                        <option value="it-IT">Italiano</option>
                        <option value="de-DE">Deutsch</option>
                    </select>
                </div>
            </section>

            <section class="voice-response-card" aria-label="Assistant response">
                <span class="voice-response-pulse" aria-hidden="true"></span>

                <div class="voice-response-content">
                    <span class="voice-response-label">Live assistant response</span>
                    <strong id="voiceResult" aria-live="assertive" aria-atomic="true">
                        Ready for your command.
                    </strong>
                </div>
            </section>

            <section class="voice-dynamic-grid" aria-label="Voice assistant information">
                <article class="voice-info-card card-one">
                    <span class="voice-info-icon" aria-hidden="true">01</span>
                    <div>
                        <h3>Speak</h3>
                        <p>One large tap starts listening.</p>
                    </div>
                </article>

                <article class="voice-info-card card-two">
                    <span class="voice-info-icon" aria-hidden="true">02</span>
                    <div>
                        <h3>Control</h3>
                        <p>Open pages, search, scroll, and send commands.</p>
                    </div>
                </article>

                <article class="voice-info-card card-three">
                    <span class="voice-info-icon" aria-hidden="true">03</span>
                    <div>
                        <h3>Confirm</h3>
                        <p>Important actions wait for approval.</p>
                    </div>
                </article>
            </section>

            <section class="voice-system-status" aria-label="System status">
                <div class="voice-status-card">
                    <span>Extension</span>
                    <strong id="extensionStatus" aria-live="polite" aria-atomic="true">
                        Checking connection...
                    </strong>
                </div>

                <div class="voice-status-card">
                    <span>Speech</span>
                    <strong id="recognizedText" aria-live="polite" aria-atomic="true">
                        Nothing recognised yet.
                    </strong>
                </div>

                <div class="voice-status-card">
                    <span>Page</span>
                    <strong id="controlledPageStatus" aria-live="polite" aria-atomic="true">
                        No browser page connected yet.
                    </strong>
                </div>
            </section>
        </section>
    </main>
<style>
    :root {
        --v-bg: #030614;
        --v-card: rgba(9, 16, 38, 0.72);
        --v-border: rgba(155, 192, 255, 0.18);
        --v-text: #f8fbff;
        --v-muted: #b5c3dc;
        --v-soft: #7988a5;
        --v-blue: #4d8dff;
        --v-blue-2: #78b1ff;
        --v-cyan: #56f0ff;
        --v-purple: #9c6bff;
        --v-red: #ff6b7a;
    }

    .voice-page,
    .voice-page * {
        box-sizing: border-box;
    }

  .voice-page {
    position: relative;
    min-height: calc(100vh - 118px);
    height: auto;
    padding: 8px;
    overflow: visible;
    color: var(--v-text);
    background:
        radial-gradient(circle at 50% 20%, rgba(77, 141, 255, 0.22), transparent 34%),
        radial-gradient(circle at 20% 80%, rgba(156, 107, 255, 0.12), transparent 28%),
        radial-gradient(circle at 85% 70%, rgba(86, 240, 255, 0.10), transparent 26%),
        linear-gradient(145deg, #02040e 0%, #071126 50%, #02040e 100%);
}
    .voice-bg-motion {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
        z-index: 0;
    }

    .voice-bg-motion::before {
        content: "";
        position: absolute;
        inset: -45%;
        background:
            conic-gradient(
                from 0deg,
                transparent,
                rgba(77, 141, 255, 0.18),
                transparent,
                rgba(86, 240, 255, 0.12),
                transparent,
                rgba(156, 107, 255, 0.14),
                transparent
            );
        animation: auroraSpin 18s linear infinite;
        filter: blur(70px);
        opacity: 0.7;
    }

    .orb {
        position: absolute;
        width: 220px;
        height: 220px;
        border-radius: 999px;
        filter: blur(14px);
        opacity: 0.3;
        mix-blend-mode: screen;
    }

    .orb-one {
        left: 8%;
        top: 10%;
        background: radial-gradient(circle, rgba(77, 141, 255, 0.95), transparent 66%);
        animation: floatOrbOne 9s ease-in-out infinite;
    }

    .orb-two {
        right: 8%;
        bottom: 10%;
        background: radial-gradient(circle, rgba(86, 240, 255, 0.75), transparent 68%);
        animation: floatOrbTwo 11s ease-in-out infinite;
    }

    .orb-three {
        left: 48%;
        bottom: -10%;
        background: radial-gradient(circle, rgba(156, 107, 255, 0.65), transparent 68%);
        animation: floatOrbThree 13s ease-in-out infinite;
    }

    .mesh-line {
        position: absolute;
        width: 160%;
        height: 1px;
        left: -30%;
        background: linear-gradient(90deg, transparent, rgba(120, 177, 255, 0.45), transparent);
        opacity: 0.12;
        transform: rotate(-9deg);
    }

    .mesh-line-one { top: 22%; animation: scanLine 5.5s ease-in-out infinite; }
    .mesh-line-two { top: 48%; animation: scanLine 7s ease-in-out infinite reverse; }
    .mesh-line-three { top: 74%; animation: scanLine 6.5s ease-in-out infinite; }

   .voice-shell {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: calc(100vh - 140px);
    height: auto;
    display: grid;
    grid-template-rows: auto auto auto auto auto;
    justify-items: center;
    align-content: start;
    gap: 8px;
    padding: 14px 18px 24px;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
        rgba(4, 9, 24, 0.78);
    backdrop-filter: blur(18px);
    box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 24px 70px rgba(0, 0, 0, 0.42);
    overflow: visible;
}

    .voice-shell::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.08) 18%, transparent 34%),
            radial-gradient(circle at 50% 45%, rgba(77, 141, 255, 0.12), transparent 40%);
        transform: translateX(-120%);
        animation: glassSweep 7s ease-in-out infinite;
        pointer-events: none;
    }

    .voice-header {
        position: relative;
        z-index: 2;
        text-align: center;
        max-width: 780px;
        animation: riseIn 650ms ease both;
    }

    .voice-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 4px;
        padding: 7px 14px;
        border-radius: 999px;
        border: 1px solid rgba(120, 177, 255, 0.34);
        background: rgba(77, 141, 255, 0.1);
        color: var(--v-blue-2);
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 0.11em;
        text-transform: uppercase;
        box-shadow: 0 0 24px rgba(77, 141, 255, 0.12);
    }

    .voice-eyebrow span {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--v-cyan);
        box-shadow: 0 0 12px var(--v-cyan);
        animation: blinkDot 1.4s ease-in-out infinite;
    }

    .voice-title {
        margin: 0;
        display: flex;
        justify-content: center;
        gap: 12px;
        color: var(--v-text);
        font-size: clamp(34px, 4.2vw, 64px);
        line-height: 0.92;
        letter-spacing: -0.07em;
        font-weight: 950;
        text-shadow: 0 0 34px rgba(77, 141, 255, 0.2);
    }

    .voice-title span {
        display: inline-block;
        animation: titleFloat 4.5s ease-in-out infinite;
    }

    .voice-title span:nth-child(2) {
        animation-delay: -1.2s;
    }

    .voice-subtitle {
        max-width: 650px;
        margin: 8px auto 0;
        color: var(--v-muted);
        font-size: clamp(14px, 1.25vw, 18px);
        line-height: 1.2;
        font-weight: 750;
    }

    .voice-stage {
        position: relative;
        z-index: 2;
        width: min(620px, 100%);
        display: grid;
        grid-template-rows: auto auto auto auto;
        justify-items: center;
        align-content: center;
        gap: 8px;
        text-align: center;
        animation: riseIn 800ms ease 80ms both;
    }

    .voice-status-orbit {
        position: relative;
        z-index: 5;
    }

    .voice-badge {
        min-width: 105px;
        min-height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 7px 16px;
        border-radius: 999px;
        border: 1px solid var(--v-border);
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.10), rgba(255, 255, 255, 0.03)),
            rgba(255, 255, 255, 0.04);
        color: var(--v-muted);
        font-size: 14px;
        font-weight: 950;
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.08),
            0 10px 26px rgba(0, 0, 0, 0.24);
        transition: 260ms ease;
    }

    .voice-badge::before {
        content: "";
        width: 8px;
        height: 8px;
        margin-right: 8px;
        border-radius: 999px;
        background: currentColor;
        box-shadow: 0 0 14px currentColor;
    }

    .voice-badge-idle { color: #b9c5d9; }

    .voice-badge-listening,
    .voice-badge-processing {
        color: var(--v-cyan);
        border-color: rgba(86, 240, 255, 0.62);
        background: rgba(86, 240, 255, 0.12);
        box-shadow:
            0 0 0 6px rgba(86, 240, 255, 0.03),
            0 0 32px rgba(86, 240, 255, 0.22);
        animation: badgePop 1s ease-in-out infinite alternate;
    }

    .voice-badge-error {
        color: var(--v-red);
        border-color: rgba(255, 107, 122, 0.55);
        background: rgba(255, 107, 122, 0.1);
    }

    .voice-button {
        width: clamp(145px, 15vw, 220px);
        height: clamp(145px, 15vw, 220px);
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        border-radius: 999px;
        color: var(--v-text);
        cursor: pointer;
        outline: none;
        background:
            radial-gradient(circle at 50% 45%, rgba(86, 240, 255, 0.14), transparent 44%),
            linear-gradient(145deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.03)),
            #081226;
        box-shadow:
            inset 0 0 0 2px rgba(120, 177, 255, 0.72),
            inset 0 0 38px rgba(77, 141, 255, 0.18),
            0 0 0 12px rgba(77, 141, 255, 0.03),
            0 24px 60px rgba(0, 0, 0, 0.45),
            0 0 70px rgba(77, 141, 255, 0.18);
        transition: 260ms ease;
        animation: buttonBreath 3.2s ease-in-out infinite;
    }

    .voice-button:hover {
        transform: translateY(-3px) scale(1.025);
        box-shadow:
            inset 0 0 0 2px rgba(86, 240, 255, 0.92),
            inset 0 0 46px rgba(86, 240, 255, 0.22),
            0 0 0 14px rgba(86, 240, 255, 0.04),
            0 28px 72px rgba(0, 0, 0, 0.52),
            0 0 94px rgba(86, 240, 255, 0.26);
    }

    .voice-button:focus-visible {
        box-shadow:
            inset 0 0 0 4px #ffffff,
            0 0 0 8px rgba(86, 240, 255, 0.28),
            0 24px 60px rgba(0, 0, 0, 0.45);
    }

    .voice-button.listening {
        animation: listeningPower 1.25s ease-in-out infinite;
        box-shadow:
            inset 0 0 0 3px rgba(86, 240, 255, 1),
            inset 0 0 56px rgba(86, 240, 255, 0.28),
            0 0 0 16px rgba(86, 240, 255, 0.04),
            0 0 100px rgba(86, 240, 255, 0.38),
            0 28px 78px rgba(0, 0, 0, 0.58);
    }

    .voice-energy-ring {
        position: absolute;
        inset: -10px;
        border-radius: inherit;
        border: 1px solid rgba(120, 177, 255, 0.22);
        pointer-events: none;
    }

    .ring-one {
        animation: orbitSpin 9s linear infinite;
        border-left-color: var(--v-cyan);
        border-top-color: transparent;
    }

    .ring-two {
        inset: -18px;
        animation: orbitSpin 13s linear infinite reverse;
        border-right-color: var(--v-purple);
        border-bottom-color: transparent;
    }

    .ring-three {
        inset: -28px;
        opacity: 0.4;
        animation: orbitSpin 17s linear infinite;
        border-top-color: var(--v-blue-2);
        border-left-color: transparent;
    }

    .voice-core {
        position: relative;
        z-index: 5;
        width: 58%;
        height: 58%;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        background:
            radial-gradient(circle, rgba(86, 240, 255, 0.18), rgba(77, 141, 255, 0.05) 58%, rgba(255, 255, 255, 0.03)),
            rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.11);
        overflow: hidden;
    }

    .voice-core-glow {
        position: absolute;
        inset: -30%;
        background: conic-gradient(from 0deg, transparent, rgba(86, 240, 255, 0.42), transparent, rgba(156, 107, 255, 0.28), transparent);
        animation: coreSpin 3.2s linear infinite;
        opacity: 0.5;
    }

    .voice-mic-icon {
        position: relative;
        z-index: 2;
        width: 42%;
        height: 42%;
        fill: none;
        stroke: var(--v-cyan);
        stroke-width: 4.4;
        stroke-linecap: round;
        stroke-linejoin: round;
        filter:
            drop-shadow(0 0 8px rgba(86, 240, 255, 0.95))
            drop-shadow(0 0 20px rgba(77, 141, 255, 0.6));
        animation: micFloat 2.4s ease-in-out infinite;
    }

    .voice-particles {
        position: absolute;
        inset: -42px;
        border-radius: inherit;
        pointer-events: none;
        opacity: 0.55;
    }

    .voice-particles span {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 4px;
        height: 4px;
        border-radius: 999px;
        background: var(--v-cyan);
        box-shadow: 0 0 10px var(--v-cyan);
        transform:
            translate(-50%, -50%)
            rotate(calc(var(--i) * 12.86deg))
            translateY(calc(-86px - (var(--i) % 4) * 8px));
        animation: particleOrbit 4s linear infinite;
        animation-delay: calc(var(--i) * -0.13s);
        opacity: calc(0.25 + (var(--i) % 5) * 0.12);
    }

    .voice-waveform {
        position: absolute;
        inset: -20px;
        border-radius: inherit;
        pointer-events: none;
        opacity: 0.46;
        transition: opacity 220ms ease;
    }

    .voice-waveform span {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 2px;
        height: calc(8px + (var(--i) % 9) * 1.5px);
        border-radius: 999px;
        background: linear-gradient(to top, transparent, rgba(86, 240, 255, 0.95), transparent);
        transform:
            translate(-50%, -50%)
            rotate(calc(var(--i) * 5.625deg))
            translateY(-105px);
        transform-origin: center;
        opacity: calc(0.22 + (var(--i) % 6) * 0.08);
        animation: idleWave 2.5s ease-in-out infinite;
        animation-delay: calc(var(--i) * -0.04s);
    }

    .voice-button.listening .voice-waveform span {
        animation: activeWave 0.9s ease-in-out infinite;
        animation-delay: calc(var(--i) * -0.028s);
    }

    .voice-button-text {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
    }

    .voice-main-copy h2 {
        margin: 0;
        color: var(--v-text);
        font-size: clamp(22px, 2.6vw, 42px);
        line-height: 1;
        letter-spacing: -0.05em;
        font-weight: 950;
        text-shadow: 0 0 28px rgba(77, 141, 255, 0.18);
    }

    .voice-main-copy p {
        margin: 5px 0 0;
        color: var(--v-muted);
        font-size: clamp(13px, 1.05vw, 16px);
        line-height: 1.2;
        font-weight: 750;
    }

    .voice-language-pill {
        min-width: min(290px, 100%);
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(120, 177, 255, 0.20);
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
            rgba(255, 255, 255, 0.03);
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.2);
        animation: softFloat 4.4s ease-in-out infinite;
    }

    .voice-language-icon {
        color: var(--v-cyan);
        font-size: 16px;
        filter: drop-shadow(0 0 7px rgba(86, 240, 255, 0.75));
        animation: blinkDot 1.8s ease-in-out infinite;
    }

    .voice-language-select {
        width: 100%;
        min-height: 38px;
        border: 0;
        outline: none;
        background: transparent;
        color: var(--v-text);
        font-size: 14px;
        font-weight: 900;
        cursor: pointer;
    }

    .voice-language-select option {
        background: #081226;
        color: #ffffff;
    }

    .voice-response-card {
        position: relative;
        z-index: 2;
        width: min(720px, 100%);
        min-height: 68px;
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 16px;
        border-radius: 20px;
        border: 1px solid rgba(120, 177, 255, 0.22);
        background:
            linear-gradient(120deg, rgba(86, 240, 255, 0.08), rgba(156, 107, 255, 0.07), rgba(255, 255, 255, 0.03)),
            rgba(8, 15, 36, 0.72);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.07),
            0 14px 38px rgba(0, 0, 0, 0.24);
        overflow: hidden;
        animation: riseIn 900ms ease 160ms both, responseFloat 5s ease-in-out infinite;
    }

    .voice-response-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.10), transparent);
        transform: translateX(-120%);
        animation: cardSweep 3.8s ease-in-out infinite;
    }

    .voice-response-pulse {
        flex: 0 0 auto;
        width: 38px;
        height: 38px;
        border-radius: 14px;
        background:
            radial-gradient(circle, var(--v-cyan), var(--v-blue) 55%, rgba(77, 141, 255, 0.08));
        box-shadow:
            0 0 18px rgba(86, 240, 255, 0.5),
            0 0 34px rgba(77, 141, 255, 0.2);
        animation: responsePulse 1.6s ease-in-out infinite;
    }

    .voice-response-content {
        position: relative;
        z-index: 2;
    }

    .voice-response-label {
        display: block;
        margin-bottom: 3px;
        color: var(--v-soft);
        font-size: 10px;
        font-weight: 950;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .voice-response-card strong {
        display: block;
        color: var(--v-text);
        font-size: clamp(16px, 1.6vw, 24px);
        line-height: 1.08;
        letter-spacing: -0.03em;
        font-weight: 950;
        white-space: pre-line;
        word-break: break-word;
    }

    .voice-dynamic-grid,
    .voice-system-status {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 920px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
    }

    .voice-info-card,
    .voice-status-card {
        position: relative;
        border-radius: 18px;
        border: 1px solid rgba(120, 177, 255, 0.14);
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
            rgba(255, 255, 255, 0.025);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.06),
            0 10px 28px rgba(0, 0, 0, 0.18);
        overflow: hidden;
    }

    .voice-info-card::before,
    .voice-status-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 20% 0%, rgba(86, 240, 255, 0.12), transparent 48%);
        opacity: 0.7;
        pointer-events: none;
    }

    .voice-info-card {
        min-height: 70px;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        animation: cardFloat 5s ease-in-out infinite;
    }

    .card-two { animation-delay: -1.4s; }
    .card-three { animation-delay: -2.5s; }

    .voice-info-icon {
        width: 34px;
        height: 34px;
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        color: var(--v-cyan);
        border: 1px solid rgba(86, 240, 255, 0.4);
        background: rgba(86, 240, 255, 0.08);
        font-size: 12px;
        font-weight: 950;
        box-shadow: 0 0 18px rgba(86, 240, 255, 0.1);
    }

    .voice-info-card h3 {
        position: relative;
        margin: 0 0 2px;
        color: var(--v-text);
        font-size: 15px;
        line-height: 1.05;
        font-weight: 950;
    }

    .voice-info-card p {
        position: relative;
        margin: 0;
        color: var(--v-muted);
        font-size: 12px;
        line-height: 1.18;
        font-weight: 700;
    }

    .voice-status-card {
        min-height: 52px;
        padding: 9px 11px;
    }

    .voice-status-card span {
        position: relative;
        display: block;
        margin-bottom: 2px;
        color: var(--v-soft);
        font-size: 9px;
        font-weight: 950;
        letter-spacing: 0.09em;
        text-transform: uppercase;
    }

    .voice-status-card strong {
        position: relative;
        display: block;
        color: var(--v-text);
        font-size: 12px;
        line-height: 1.15;
        font-weight: 850;
        word-break: break-word;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    @keyframes auroraSpin { to { transform: rotate(360deg); } }
    @keyframes floatOrbOne { 0%,100%{transform:translate3d(0,0,0) scale(1);} 50%{transform:translate3d(80px,42px,0) scale(1.18);} }
    @keyframes floatOrbTwo { 0%,100%{transform:translate3d(0,0,0) scale(1);} 50%{transform:translate3d(-90px,-50px,0) scale(1.14);} }
    @keyframes floatOrbThree { 0%,100%{transform:translate3d(0,0,0) scale(1);} 50%{transform:translate3d(34px,-60px,0) scale(1.2);} }
    @keyframes scanLine { 0%,100%{transform:translateX(-12%) rotate(-9deg); opacity:0.05;} 50%{transform:translateX(12%) rotate(-9deg); opacity:0.18;} }
    @keyframes glassSweep { 0%,42%{transform:translateX(-130%);} 62%,100%{transform:translateX(130%);} }
    @keyframes riseIn { from { opacity:0; transform:translateY(18px) scale(0.98);} to {opacity:1; transform:translateY(0) scale(1);} }
    @keyframes blinkDot { 0%,100%{opacity:0.45; transform:scale(0.9);} 50%{opacity:1; transform:scale(1.18);} }
    @keyframes titleFloat { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-4px);} }
    @keyframes softFloat { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-3px);} }
    @keyframes buttonBreath { 0%,100%{transform:scale(1);} 50%{transform:scale(1.02);} }
    @keyframes listeningPower { 0%,100%{transform:scale(1.03);} 50%{transform:scale(1.06);} }
    @keyframes orbitSpin { to { transform: rotate(360deg); } }
    @keyframes coreSpin { to { transform: rotate(360deg); } }
    @keyframes micFloat { 0%,100%{transform:translateY(0) scale(1);} 50%{transform:translateY(-4px) scale(1.04);} }

    @keyframes particleOrbit {
        from {
            transform:
                translate(-50%, -50%)
                rotate(calc(var(--i) * 12.86deg))
                translateY(calc(-86px - (var(--i) % 4) * 8px));
        }
        to {
            transform:
                translate(-50%, -50%)
                rotate(calc((var(--i) * 12.86deg) + 360deg))
                translateY(calc(-86px - (var(--i) % 4) * 8px));
        }
    }

    @keyframes idleWave {
        0%, 100% { height: 8px; opacity: 0.24; }
        50% { height: 18px; opacity: 0.62; }
    }

    @keyframes activeWave {
        0%, 100% { height: 10px; opacity: 0.34; }
        50% { height: 38px; opacity: 1; }
    }

    @keyframes badgePop { from { transform: scale(1); } to { transform: scale(1.04); } }
    @keyframes cardSweep { 0%,38%{transform:translateX(-130%);} 70%,100%{transform:translateX(130%);} }
    @keyframes responsePulse { 0%,100%{transform:scale(0.94); opacity:0.7;} 50%{transform:scale(1.08); opacity:1;} }
    @keyframes responseFloat { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-3px);} }
    @keyframes cardFloat { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-4px);} }

    @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            animation-duration: 0.001ms !important;
            animation-iteration-count: 1 !important;
            scroll-behavior: auto !important;
            transition-duration: 0.001ms !important;
        }
    }

    @media (max-width: 1150px) {
       .voice-page {
    min-height: calc(100vh - 118px);
    height: auto;
    overflow: visible;
}

        .voice-shell {
    min-height: calc(100vh - 140px);
    height: auto;
    overflow: visible;
}

        .voice-dynamic-grid,
        .voice-system-status {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 640px) {
        .voice-page {
            padding: 6px;
        }

        .voice-shell {
            padding: 14px 12px;
            border-radius: 22px;
        }

        .voice-title {
            flex-direction: column;
            gap: 0;
            font-size: 36px;
        }

        .voice-subtitle {
            font-size: 14px;
        }

        .voice-button {
            width: 150px;
            height: 150px;
        }

        .voice-waveform span {
            transform:
                translate(-50%, -50%)
                rotate(calc(var(--i) * 5.625deg))
                translateY(-76px);
        }

        .voice-particles span {
            transform:
                translate(-50%, -50%)
                rotate(calc(var(--i) * 12.86deg))
                translateY(calc(-66px - (var(--i) % 4) * 6px));
        }

        .voice-response-card {
            width: 100%;
        }
    }
    html,
body {
    overflow-y: auto !important;
}

body {
    min-height: 100vh;
}

.voice-page {
    overflow-y: visible !important;
}

.voice-shell {
    overflow: visible !important;
}
</style>
{% endblock %}
{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggleBtn = document.getElementById('voiceToggleBtn');
            const toggleBtnText = document.getElementById('voiceToggleBtnText');
            const listeningStatus = document.getElementById('listeningStatus');
            const recognizedText = document.getElementById('recognizedText');
            const voiceResult = document.getElementById('voiceResult');
            const voiceStateBadge = document.getElementById('voiceStateBadge');
            const voiceLanguageSelect = document.getElementById('voiceLanguageSelect');
            const extensionStatus = document.getElementById('extensionStatus');
            const controlledPageStatus = document.getElementById('controlledPageStatus');

            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

            const VOICE_LANGUAGE_STORAGE_KEY = 'voiceAssistantLanguage';
            const VOICE_PENDING_FLOW_STORAGE_KEY = 'voiceAssistantPendingFlow';

            const SUPPORTED_VOICE_LANGUAGES = {
                english: 'en-US',
                anglais: 'en-US',

                french: 'fr-FR',
                francais: 'fr-FR',
                français: 'fr-FR',

                arabic: 'ar-SA',
                arabe: 'ar-SA',
                عربي: 'ar-SA',
                عربى: 'ar-SA',

                tunisian: 'ar-TN',
                tunisien: 'ar-TN',
                تونسي: 'ar-TN',
                تونسية: 'ar-TN',

                spanish: 'es-ES',
                espagnol: 'es-ES',

                italian: 'it-IT',
                italien: 'it-IT',

                german: 'de-DE',
                allemand: 'de-DE'
            };

            let recognition = null;
            let isListening = false;
            let hasSpeechSupport = !!SpeechRecognition;
            let extensionReady = false;

            let lastBrowserContext = {
                url: null,
                title: null,
                website: null,
                visibleText: null
            };

            function isTypingTarget(target) {
                if (!target) {
                    return false;
                }

                const tagName = target.tagName ? target.tagName.toLowerCase() : '';

                return (
                    tagName === 'input' ||
                    tagName === 'textarea' ||
                    tagName === 'select' ||
                    target.isContentEditable
                );
            }

            function normalizeText(text) {
                return String(text || '')
                    .toLowerCase()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .replace(/\s+/g, ' ')
                    .trim();
            }

            function getSavedVoiceLanguage() {
                return localStorage.getItem(VOICE_LANGUAGE_STORAGE_KEY) || 'en-US';
            }

            function saveVoiceLanguage(language) {
                localStorage.setItem(VOICE_LANGUAGE_STORAGE_KEY, language);

                if (voiceLanguageSelect) {
                    voiceLanguageSelect.value = language;
                }

                if (recognition) {
                    recognition.lang = language;
                }
            }

            function getCurrentVoiceLanguage() {
                if (voiceLanguageSelect && voiceLanguageSelect.value) {
                    return voiceLanguageSelect.value;
                }

                return getSavedVoiceLanguage();
            }

            function getLanguageLabel(language) {
                const labels = {
                    'en-US': 'English',
                    'fr-FR': 'Français',
                    'ar-TN': 'Tunisian Arabic',
                    'ar-SA': 'Arabic',
                    'es-ES': 'Español',
                    'it-IT': 'Italiano',
                    'de-DE': 'Deutsch'
                };

                return labels[language] || language;
            }

            function getLanguageChangeMessage(language) {
                const messages = {
                    'en-US': 'Voice language changed to English.',
                    'fr-FR': 'La langue vocale est maintenant le français.',
                    'ar-TN': 'تم تغيير لغة المساعد إلى التونسية.',
                    'ar-SA': 'تم تغيير لغة المساعد إلى العربية.',
                    'es-ES': 'El idioma de voz cambió a español.',
                    'it-IT': 'La lingua vocale è stata cambiata in italiano.',
                    'de-DE': 'Die Sprachsprache wurde auf Deutsch geändert.'
                };

                return messages[language] || ('Voice language changed to ' + getLanguageLabel(language) + '.');
            }

            function detectLanguageSetupCommand(text) {
                const normalized = normalizeText(text);

                const languagePatterns = [
                    'speak ',
                    'change language to ',
                    'set language to ',
                    'use ',
                    'talk in ',
                    'answer in ',

                    'parle ',
                    'reponds en ',
                    'réponds en ',
                    'changer la langue en ',
                    'change la langue en ',
                    'utilise ',

                    'تكلم ',
                    'احكي ',
                    'جاوبني ب ',
                    'بدل اللغة إلى ',
                    'بدل اللغة ل '
                ];

                for (const pattern of languagePatterns) {
                    if (normalized.includes(pattern)) {
                        const afterPattern = normalized.split(pattern).pop().trim();

                        for (const languageName in SUPPORTED_VOICE_LANGUAGES) {
                            if (afterPattern.includes(languageName)) {
                                return SUPPORTED_VOICE_LANGUAGES[languageName];
                            }
                        }
                    }
                }

                return null;
            }


            function setPendingVoiceFlow(flow) {
                if (flow) {
                    localStorage.setItem(VOICE_PENDING_FLOW_STORAGE_KEY, flow);
                    return;
                }

                localStorage.removeItem(VOICE_PENDING_FLOW_STORAGE_KEY);
            }

            function getPendingVoiceFlow() {
                return localStorage.getItem(VOICE_PENDING_FLOW_STORAGE_KEY) || '';
            }

            function updatePendingVoiceFlowFromResponse(data) {
                if (!data || data.intent !== 'EMAIL_ACTION') {
                    return;
                }

                if (data.mode === 'EMAIL_MISSING_BODY' || data.requiresEmailBody) {
                    setPendingVoiceFlow('EMAIL_BODY');
                    return;
                }

                if (data.mode === 'EMAIL_PREPARED_NEEDS_CONFIRMATION' || data.requiresConfirmation) {
                    setPendingVoiceFlow('EMAIL_CONFIRMATION');
                    return;
                }

                if (
                    data.mode === 'EMAIL_SEND_CONFIRMED' ||
                    data.mode === 'EMAIL_CANCELLED' ||
                    data.mode === 'EMAIL_NO_PENDING_MESSAGE'
                ) {
                    setPendingVoiceFlow(null);
                }
            }

            function looksLikeEmailConfirmationCommand(text) {
                const normalized = normalizeText(text);

                return (
                    normalized === 'confirm' ||
                    normalized === 'i confirm' ||
                    normalized === 'send it' ||
                    normalized.includes('confirm send email') ||
                    normalized.includes('send the pending email') ||
                    normalized.includes('yes send it') ||
                    normalized.includes('confirm it') ||
                    normalized.includes('i confirm send it') ||
                    normalized.includes('confirm send it') ||
                    normalized.includes('send it now') ||
                    normalized.includes('confirme l envoi') ||
                    normalized.includes('confirmer l envoi') ||
                    normalized.includes('ارسل الرسالة') ||
                    normalized.includes('ابعث الرسالة')
                );
            }

            function looksLikeEmailCancellationCommand(text) {
                const normalized = normalizeText(text);

                return (
                    normalized.includes('cancel') ||
                    normalized.includes('do not send') ||
                    normalized.includes("don't send") ||
                    normalized.includes('dont send') ||
                    normalized.includes('not confirming') ||
                    normalized.includes('no confirm') ||
                    normalized.includes('stop email') ||
                    normalized.includes('annuler') ||
                    normalized.includes('ne pas envoyer') ||
                    normalized.includes('الغاء') ||
                    normalized.includes('إلغاء') ||
                    normalized.includes('لا ترسل')
                );
            }

            function isHelpCommand(text) {
                const normalized = normalizeText(text);

                return (
                    normalized === 'help' ||
                    normalized === 'voice help' ||
                    normalized === 'show commands' ||
                    normalized === 'available commands' ||
                    normalized === 'what can i say' ||
                    normalized === 'what can i do' ||
                    normalized.includes('what can i say') ||
                    normalized.includes('show me commands') ||
                    normalized.includes('help me') ||
                    normalized === 'aide' ||
                    normalized.includes('que puis je dire') ||
                    normalized.includes('qu est ce que je peux dire') ||
                    normalized.includes('شنوة نجم نقول') ||
                    normalized.includes('مساعدة')
                );
            }

            function looksLikeAiCommand(text) {
                const normalized = normalizeText(text);

                return (
                    normalized.includes('youtube') ||
                    normalized.includes('google') ||
                    normalized.includes('facebook') ||
                    normalized.includes('gmail') ||
                    normalized.includes('mail') ||

                    normalized.includes('search') ||
                    normalized.includes('find') ||
                    normalized.includes('look for') ||
                    normalized.includes('open result') ||
                    normalized.includes('open the result') ||
                    normalized.includes('go to') ||
                    normalized.includes('open website') ||
                    normalized.includes('open ') ||

                    normalized.includes('send email') ||
                    normalized.includes('send an email') ||
                    normalized.includes('write email') ||
                    normalized.includes('write an email') ||
                    normalized.includes('compose email') ||
                    normalized.includes('compose an email') ||
                    normalized.startsWith('email ') ||
                    normalized.includes(' email ') ||
                    normalized.includes('confirm send email') ||
                    normalized.includes('send the pending email') ||
                    normalized.includes('yes send it') ||
                    normalized.includes('confirm it') ||
                    looksLikeEmailConfirmationCommand(normalized) ||
                    looksLikeEmailCancellationCommand(normalized) ||

                    normalized.includes('video') ||
                    normalized.includes('play') ||
                    normalized.includes('pause') ||
                    normalized.includes('mute') ||
                    normalized.includes('unmute') ||
                    normalized.includes('scroll') ||
                    normalized.includes('read this page') ||
                    normalized.includes('read page') ||
                    normalized.includes('click') ||
                    normalized.includes('go back') ||
                    normalized.includes('go forward') ||
                    normalized.includes('second') ||
                    normalized.includes('third') ||
                    normalized.includes('first result') ||
                    normalized.includes('take me back') ||
                    normalized.includes('back to assistant') ||
                    normalized.includes('return to assistant') ||
                    normalized.includes('voice assistant') ||

                    normalized.includes('cherche') ||
                    normalized.includes('recherche') ||
                    normalized.includes('trouve') ||
                    normalized.includes('chercher') ||
                    normalized.includes('email') ||
                    normalized.includes('e-mail') ||
                    normalized.includes('envoyer un email') ||
                    normalized.includes('envoie un email') ||
                    normalized.includes('ecris un email') ||
                    normalized.includes('ecrire un email') ||
                    normalized.includes('confirme l envoi') ||
                    normalized.includes('confirmer l envoi') ||
                    normalized.includes('video') ||
                    normalized.includes('joue') ||
                    normalized.includes('lance') ||
                    normalized.includes('mets') ||
                    normalized.includes('lis cette page') ||
                    normalized.includes('lire cette page') ||
                    normalized.includes('descends') ||
                    normalized.includes('descendre') ||
                    normalized.includes('monte') ||
                    normalized.includes('clique') ||
                    normalized.includes('retour') ||
                    normalized.includes('deuxieme') ||
                    normalized.includes('troisieme') ||
                    normalized.includes('premier resultat') ||

                    normalized.includes('جيميل') ||
                    normalized.includes('جميل') ||
                    normalized.includes('ايميل') ||
                    normalized.includes('إيميل') ||
                    normalized.includes('ابعث ايميل') ||
                    normalized.includes('ارسل ايميل') ||
                    normalized.includes('ابعت ايميل') ||
                    normalized.includes('اكتب ايميل') ||
                    normalized.includes('ابحث') ||
                    normalized.includes('فتش') ||
                    normalized.includes('دور') ||
                    normalized.includes('فيديو') ||
                    normalized.includes('شغل') ||
                    normalized.includes('وقف') ||
                    normalized.includes('اقرأ') ||
                    normalized.includes('انزل') ||
                    normalized.includes('اطلع') ||
                    normalized.includes('اضغط') ||
                    normalized.includes('ارجع') ||
                    normalized.includes('الثاني') ||
                    normalized.includes('الثالث') ||
                    normalized.includes('الأول')
                );
            }

            function announceText(message) {
                console.log('Assistant announcement:', message);
            }

            function speakText(message) {
                if (!('speechSynthesis' in window)) {
                    return;
                }

                window.speechSynthesis.cancel();

                const utterance = new SpeechSynthesisUtterance(message);
                utterance.lang = getCurrentVoiceLanguage();
                utterance.rate = 0.95;
                utterance.pitch = 1;
                utterance.volume = 1;

                window.speechSynthesis.speak(utterance);
            }

            function setListeningState(listening) {
                isListening = listening;
                toggleBtn.setAttribute('aria-pressed', listening ? 'true' : 'false');
                toggleBtn.classList.toggle('listening', listening);
                toggleBtnText.textContent = listening ? 'Stop Listening' : 'Start Listening';
                listeningStatus.textContent = listening ? 'Listening now. Speak your command.' : 'Voice assistant is idle.';

                voiceStateBadge.textContent = listening ? 'Listening' : 'Idle';
                voiceStateBadge.classList.remove('voice-badge-idle', 'voice-badge-listening', 'voice-badge-processing', 'voice-badge-error');
                voiceStateBadge.classList.add(listening ? 'voice-badge-listening' : 'voice-badge-idle');
            }

            function setAssistantStatus(message, speak = true, badgeState = 'idle') {
                voiceResult.textContent = message;
                announceText(message);

                voiceStateBadge.classList.remove('voice-badge-idle', 'voice-badge-listening', 'voice-badge-processing', 'voice-badge-error');

                if (badgeState === 'processing') {
                    voiceStateBadge.textContent = 'Processing';
                    voiceStateBadge.classList.add('voice-badge-processing');
                } else if (badgeState === 'error') {
                    voiceStateBadge.textContent = 'Error';
                    voiceStateBadge.classList.add('voice-badge-error');
                } else if (badgeState === 'listening') {
                    voiceStateBadge.textContent = 'Listening';
                    voiceStateBadge.classList.add('voice-badge-listening');
                } else {
                    voiceStateBadge.textContent = 'Idle';
                    voiceStateBadge.classList.add('voice-badge-idle');
                }

                if (speak) {
                    speakText(message);
                }
            }

            function sendCommandToChromeExtension(command) {
                window.postMessage({
                    source: 'VOICE_ASSISTANT_WEB',
                    type: 'EXECUTE_BROWSER_ACTION',
                    command: command
                }, window.location.origin);
            }

            function updateBrowserContext(context) {
                lastBrowserContext = {
                    url: context.url || null,
                    title: context.title || null,
                    website: context.website || null,
                    visibleText: context.visibleText || null
                };

                if (controlledPageStatus) {
                    controlledPageStatus.textContent = lastBrowserContext.title || lastBrowserContext.website || 'Browser page connected.';
                }
            }

            function checkExtensionConnection() {
                window.postMessage({
                    source: 'VOICE_ASSISTANT_WEB',
                    type: 'PING_EXTENSION'
                }, window.location.origin);

                setTimeout(function () {
                    if (!extensionReady && extensionStatus) {
                        extensionStatus.textContent = 'Not connected. Load the Chrome extension.';
                    }
                }, 1500);
            }

            window.addEventListener('message', function (event) {
                if (!event.data || event.data.source !== 'VOICE_ASSISTANT_EXTENSION') {
                    return;
                }

                if (event.data.type === 'EXTENSION_READY') {
                    extensionReady = true;

                    if (extensionStatus) {
                        extensionStatus.textContent = 'Connected';
                    }
                }

                if (event.data.type === 'BROWSER_CONTEXT') {
                    updateBrowserContext(event.data.context || {});
                }

                if (event.data.type === 'BROWSER_ACTION_RESULT') {
                    const result = event.data.result || {};
                    const message = result.message || 'Browser action completed.';

                    setAssistantStatus(message, true, result.success === false ? 'error' : 'idle');
                }
            });

            function executeWebsiteAction(data) {
                const action = String(data.action || '').toLowerCase();
                const extensionAction = action === 'search' ? 'SEARCH' : 'OPEN_URL';

                const command = data.extensionCommand || {
                    action: extensionAction,
                    website: data.website || null,
                    websiteName: data.websiteName || data.website || null,
                    url: data.url || null,
                    query: data.query || null,
                    target: null,
                    resultPosition: data.resultPosition || null,
                    nextAction: data.nextAction || null,
                    language: getCurrentVoiceLanguage(),
                    context: lastBrowserContext
                };

                const websiteName = data.websiteName || data.website || 'the website';
                const queryText = data.query ? ' for "' + data.query + '"' : '';
                const message = action === 'search'
                    ? 'Searching ' + websiteName + queryText + ' in the controlled browser tab.'
                    : 'Opening ' + websiteName + ' in the controlled browser tab.';

                setAssistantStatus(data.speech || data.message || message, true, 'idle');
                sendCommandToChromeExtension(command);
            }

            function handleEmailAction(data) {
                let message = data.speech || data.message || 'Email action completed.';

                if (data.emailPreview) {
                    message += '\n\nEmail preview:\n';
                    message += 'To: ' + (data.emailPreview.to || '') + '\n';
                    message += 'Subject: ' + (data.emailPreview.subject || '') + '\n';
                    message += 'Body: ' + (data.emailPreview.body || '');
                }

                if (data.connectUrl) {
                    message += '\n\nGmail connection required. Open: ' + data.connectUrl;
                }

                setAssistantStatus(message, true, data.success === false ? 'error' : 'idle');
            }

            function sendVoiceCommand(text) {
                const requestedLanguage = detectLanguageSetupCommand(text);

                if (requestedLanguage) {
                    saveVoiceLanguage(requestedLanguage);
                    setAssistantStatus(getLanguageChangeMessage(requestedLanguage), true, 'idle');
                    return;
                }

                if (isHelpCommand(text)) {
                    const helpMessage =
                        'Here are some commands you can say: open profile, show my files, go home, log out, open YouTube, search YouTube for cats, open the second video, pause the video, read this page, scroll down, go to Gmail, send an email to john@example.com saying hello, or confirm send email.';

                    setAssistantStatus(helpMessage, true, 'idle');
                    return;
                }

                const shouldUseAiEndpoint = getPendingVoiceFlow() !== '' || looksLikeAiCommand(text) || looksLikeEmailCancellationCommand(text);

                const endpoint = shouldUseAiEndpoint
                    ? '{{ path('api_voice_interpret') }}'
                    : '{{ path('voice_execute') }}';

                console.log('VOICE ENDPOINT:', endpoint);

                setAssistantStatus('Processing your command: ' + text, false, 'processing');

                fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        text: text,
                        language: getCurrentVoiceLanguage(),
                        browserContext: lastBrowserContext
                    })
                })
                    .then(function (response) {
                        return response.json();
                    })
                    .then(function (data) {
                        console.log('VOICE RESPONSE:', data);

                        if (data.intent === 'EMAIL_ACTION') {
                            updatePendingVoiceFlowFromResponse(data);
                            handleEmailAction(data);
                            return;
                        }

                        if (data.success && data.intent === 'WEBSITE_ACTION') {
                            executeWebsiteAction(data);
                            return;
                        }

                        if (data.success && data.intent === 'BROWSER_ACTION' && data.requiresExtension && data.extensionCommand) {
                            setAssistantStatus(data.speech || data.message || 'Executing browser action.', true, 'idle');
                            sendCommandToChromeExtension(data.extensionCommand);
                            return;
                        }

                        if (!data.success) {
                            const failMessage =
                                (data.speech || data.message || 'I could not match that to a supported action.') +
                                ' You can say "what can I say" to hear available commands.';

                            setAssistantStatus(failMessage, true, 'error');
                            return;
                        }

                        const spokenReply =
                            (data.execution && data.execution.speech) ||
                            data.speech ||
                            data.message ||
                            'Command completed successfully.';

                        setAssistantStatus(spokenReply, true, 'idle');

                        if (data.execution && data.execution.redirect) {
                            setTimeout(function () {
                                window.location.href = data.execution.redirect;
                            }, 1400);
                        }
                    })
                    .catch(function () {
                        setAssistantStatus(
                            'A connection error happened while processing your command. Please check the server and try again.',
                            true,
                            'error'
                        );
                    });
            }

            function startListening() {
                if (window.speechSynthesis) {
                    window.speechSynthesis.cancel();
                }

                if (!hasSpeechSupport) {
                    setAssistantStatus('Voice recognition is not supported in this browser. Please use Google Chrome.', true, 'error');
                    return;
                }

                if (!recognition) {
                    recognition = new SpeechRecognition();
                    recognition.interimResults = false;
                    recognition.continuous = false;

                    recognition.onstart = function () {
                        setListeningState(true);
                        voiceResult.textContent = 'Listening now. Please speak your command.';
                        announceText('Listening now. Please speak your command.');
                    };

                    recognition.onend = function () {
                        if (isListening) {
                            setListeningState(false);
                        }
                    };

                    recognition.onerror = function (event) {
                        setListeningState(false);

                        let message = 'A voice recognition error happened. Please try again.';

                        if (event.error === 'not-allowed') {
                            message = 'Microphone permission was denied. Please allow microphone access and try again.';
                        } else if (event.error === 'no-speech') {
                            message = 'I did not hear anything. Press Space or Start Listening and speak your command.';
                        } else if (event.error === 'audio-capture') {
                            message = 'No microphone was found. Please check your microphone.';
                        } else if (event.error === 'network') {
                            message = 'Speech recognition needs a network connection. Please check your internet and try again.';
                        }

                        setAssistantStatus(message, true, 'error');
                    };

                    recognition.onresult = function (event) {
                        const text = event.results[0][0].transcript.trim();
                        setListeningState(false);
                        recognizedText.textContent = text;
                        listeningStatus.textContent = 'Processing your command.';
                        sendVoiceCommand(text);
                    };
                }

                try {
                    recognition.lang = getCurrentVoiceLanguage();
                    recognition.start();
                } catch (error) {
                    setAssistantStatus('The microphone is already starting. Please wait a moment.', true, 'error');
                }
            }

            function stopListening() {
                if (recognition && isListening) {
                    recognition.stop();
                    setAssistantStatus('Listening stopped. Press Space when you want to speak again.', true, 'idle');
                }
            }

            function toggleListening() {
                if (isListening) {
                    stopListening();
                } else {
                    startListening();
                }
            }

            toggleBtn.addEventListener('click', function () {
                toggleListening();
            });

            document.addEventListener('keydown', function (event) {
                if (event.code === 'Space' && !event.ctrlKey && !event.altKey && !event.shiftKey && !event.metaKey) {
                    if (isTypingTarget(event.target)) {
                        return;
                    }

                    event.preventDefault();
                    toggleListening();
                }
            });

            saveVoiceLanguage(getSavedVoiceLanguage());

            if (voiceLanguageSelect) {
                voiceLanguageSelect.addEventListener('change', function () {
                    saveVoiceLanguage(voiceLanguageSelect.value);
                    setAssistantStatus(getLanguageChangeMessage(voiceLanguageSelect.value), true, 'idle');
                });
            }

            if (!hasSpeechSupport) {
                setAssistantStatus('Voice recognition is not supported in this browser. Please use Google Chrome.', false, 'error');
            } else {
                setAssistantStatus('Voice assistant ready. Press the main button or press Space.', true, 'idle');
            }

            checkExtensionConnection();
        });
    </script>
{% endblock %}