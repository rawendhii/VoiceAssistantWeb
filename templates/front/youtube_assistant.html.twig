{% extends 'front/layout.html.twig' %}

{% block front_content %}
    <div class="youtube-assistant-hero">
        <div>
            <span class="youtube-eyebrow">YouTube Voice Player</span>
            <h1>Search, select, and control videos by voice</h1>
            <p>
                This page uses YouTube search results and an embedded YouTube player so the user can stay inside the
                voice assistant experience instead of manually navigating the full YouTube website.
            </p>
        </div>
    </div>

    <section class="youtube-search-card">
        <h2>Current search</h2>

        {% if query %}
            <div class="youtube-query-box">
                <span>Search query</span>
                <strong>{{ query }}</strong>
            </div>
        {% else %}
            <div class="youtube-empty-state">
                Say something like <strong>search YouTube for relaxing music</strong> from the voice assistant.
            </div>
        {% endif %}
    </section>

    {% if youtubeError %}
        <section class="youtube-error-card">
            <h2>YouTube API error</h2>
            <p>{{ youtubeError }}</p>
        </section>
    {% endif %}

    {% if videos is defined and videos|length > 0 %}
        <section class="youtube-player-card">
            <div>
                <h2>Voice-controlled player</h2>
                <p>
                    Say: <strong>results</strong>, <strong>next</strong>, <strong>previous</strong>,
                    <strong>open this video</strong>, <strong>open second video</strong>,
                    <strong>open the video</strong>, <strong>play</strong>, <strong>pause</strong>,
                    <strong>stop it</strong>, <strong>volume up</strong>, <strong>volume down</strong>,
                    <strong>mute</strong>, or <strong>unmute</strong>.
                </p>
            </div>

            <div id="youtubePlayer" class="youtube-player-box"></div>

            <div class="youtube-player-controls">
                <button type="button" class="youtube-control-button" data-player-action="play">Play</button>
                <button type="button" class="youtube-control-button" data-player-action="pause">Pause</button>
                <button type="button" class="youtube-control-button" data-player-action="volume_up">Volume +</button>
                <button type="button" class="youtube-control-button" data-player-action="volume_down">Volume -</button>
                <button type="button" class="youtube-control-button" data-player-action="mute">Mute</button>
                <button type="button" class="youtube-control-button" data-player-action="unmute">Unmute</button>
            </div>

            <p id="youtubePlayerStatus" class="youtube-player-status" aria-live="polite">
                Select a video result to load the player.
            </p>
        </section>

        <section class="youtube-results-card">
            <div class="youtube-results-header">
                <div>
                    <h2>Video results</h2>
                    <p>
                        Use the buttons below or say “results”, “next”, “open first video”, “open this video”,
                        or say part of the video title.
                    </p>
                </div>
            </div>

            <div class="youtube-results-grid">
                {% for video in videos %}
                    <article class="youtube-video-card">
                        {% if video.thumbnail %}
                            <img src="{{ video.thumbnail }}" alt="Thumbnail for {{ video.title }}">
                        {% endif %}

                        <div class="youtube-video-content">
                            <span class="youtube-result-number">Result {{ loop.index }}</span>

                            <h3>{{ video.title }}</h3>

                            <p class="youtube-channel">{{ video.channelTitle }}</p>

                            {% if video.description %}
                                <p class="youtube-description">{{ video.description }}</p>
                            {% endif %}

                            <div class="youtube-video-actions">
                                <button
                                    type="button"
                                    class="youtube-open-button js-load-video"
                                    data-index="{{ loop.index0 }}"
                                >
                                    Load in assistant
                                </button>

                                <a href="{{ video.url }}" target="_blank" rel="noopener" class="youtube-secondary-button">
                                    Open on YouTube
                                </a>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>
    {% elseif query and not youtubeError %}
        <section class="youtube-empty-state">
            No videos were found for this search.
        </section>
    {% endif %}

    <style>
        .youtube-assistant-hero {
            background: linear-gradient(135deg, #fff1f2 0%, #ffffff 70%);
            border: 1px solid #e5e7eb;
            border-radius: 22px;
            padding: 30px;
            margin-bottom: 24px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
        }

        .youtube-eyebrow {
            display: inline-block;
            margin-bottom: 10px;
            padding: 6px 12px;
            border-radius: 999px;
            background: #fee2e2;
            color: #b91c1c;
            font-size: 13px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        .youtube-assistant-hero h1 {
            margin: 0;
            color: #111827;
            font-size: 34px;
            line-height: 1.15;
        }

        .youtube-assistant-hero p {
            max-width: 900px;
            margin: 12px 0 0;
            color: #6b7280;
            line-height: 1.7;
            font-size: 16px;
        }

        .youtube-search-card,
        .youtube-player-card,
        .youtube-results-card,
        .youtube-error-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.07);
            padding: 24px;
            margin-bottom: 20px;
        }

        .youtube-search-card h2,
        .youtube-player-card h2,
        .youtube-results-card h2,
        .youtube-error-card h2 {
            margin: 0 0 12px;
            color: #111827;
        }

        .youtube-player-card p,
        .youtube-results-header p,
        .youtube-error-card p {
            color: #6b7280;
            line-height: 1.6;
            margin: 0 0 18px;
        }

        .youtube-query-box {
            padding: 18px;
            border-radius: 16px;
            background: #f9fafb;
            border: 1px solid #e5e7eb;
        }

        .youtube-query-box span {
            display: block;
            color: #6b7280;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .youtube-query-box strong {
            display: block;
            color: #111827;
            font-size: 22px;
            line-height: 1.4;
        }

        .youtube-player-box {
            width: 100%;
            aspect-ratio: 16 / 9;
            background: #111827;
            border-radius: 18px;
            overflow: hidden;
            margin-bottom: 14px;
        }

        .youtube-player-controls {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 12px;
        }

        .youtube-control-button {
            border: none;
            border-radius: 12px;
            background: #111827;
            color: #ffffff;
            padding: 10px 14px;
            font-size: 14px;
            font-weight: 900;
            cursor: pointer;
        }

        .youtube-control-button:hover {
            background: #1f2937;
        }

        .youtube-player-status {
            color: #374151;
            font-weight: 800;
            margin: 0;
        }

        .youtube-results-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 18px;
        }

        .youtube-video-card {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: hidden;
            background: #ffffff;
        }

        .youtube-video-card-focused {
            outline: 4px solid #2563eb;
            outline-offset: 4px;
            box-shadow: 0 0 0 6px rgba(37, 99, 235, 0.18);
        }

        .youtube-video-card img {
            width: 100%;
            display: block;
            aspect-ratio: 16 / 9;
            object-fit: cover;
            background: #f3f4f6;
        }

        .youtube-video-content {
            padding: 16px;
        }

        .youtube-result-number {
            display: inline-block;
            margin-bottom: 8px;
            padding: 5px 9px;
            border-radius: 999px;
            background: #fee2e2;
            color: #991b1b;
            font-size: 12px;
            font-weight: 900;
        }

        .youtube-video-content h3 {
            margin: 0 0 8px;
            color: #111827;
            font-size: 16px;
            line-height: 1.4;
        }

        .youtube-channel {
            margin: 0 0 8px;
            color: #374151;
            font-size: 14px;
            font-weight: 800;
        }

        .youtube-description {
            margin: 0 0 14px;
            color: #6b7280;
            font-size: 13px;
            line-height: 1.5;
        }

        .youtube-video-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .youtube-open-button,
        .youtube-secondary-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            padding: 10px 13px;
            font-size: 14px;
            font-weight: 900;
            text-decoration: none;
            border: none;
            cursor: pointer;
        }

        .youtube-open-button {
            background: #dc2626;
            color: #ffffff;
        }

        .youtube-open-button:hover {
            background: #b91c1c;
        }

        .youtube-secondary-button {
            background: #f3f4f6;
            color: #111827;
        }

        .youtube-secondary-button:hover {
            background: #e5e7eb;
        }

        .youtube-empty-state {
            padding: 20px;
            border-radius: 16px;
            background: #f9fafb;
            border: 1px dashed #d1d5db;
            color: #6b7280;
            line-height: 1.6;
        }

        @media (max-width: 900px) {
            .youtube-results-grid {
                grid-template-columns: 1fr;
            }

            .youtube-assistant-hero h1 {
                font-size: 28px;
            }
        }
    </style>

    <script>
const youtubeVideos = {{ videos|default([])|json_encode|raw }};
const youtubeAutoplayPosition = {{ autoplay|default(0) }};
        let youtubePlayer = null;
        let selectedVideoIndex = null;
        let readableResultIndex = 0;
        let lastSpokenYoutubeMessage = '';

        function updateYoutubeStatus(message, speak = true) {
            lastSpokenYoutubeMessage = message;

            const status = document.getElementById('youtubePlayerStatus');

            if (status) {
                status.textContent = message;
            }

            if (typeof announceText === 'function') {
                announceText(message);
            }

            if (speak && typeof speakText === 'function') {
                speakText(message);
            }
        }

        function scrollAssistantPage(direction) {
            const amount = Math.round(window.innerHeight * 0.75);

            if (direction === 'down') {
                window.scrollBy({ top: amount, behavior: 'smooth' });
                updateYoutubeStatus('Scrolling down the page.', true);
                return true;
            }

            if (direction === 'up') {
                window.scrollBy({ top: -amount, behavior: 'smooth' });
                updateYoutubeStatus('Scrolling up the page.', true);
                return true;
            }

            return false;
        }

        function goToYoutubePlayer() {
            const playerCard = document.querySelector('.youtube-player-card');

            if (playerCard) {
                playerCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
                updateYoutubeStatus('Moving to the video player.', true);
                return true;
            }

            updateYoutubeStatus('The video player is not available yet.', true);
            return true;
        }

        function goToYoutubeResults() {
            const resultsCard = document.querySelector('.youtube-results-card');

            if (resultsCard) {
                resultsCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
                updateYoutubeStatus('Moving to the video results.', true);
                return true;
            }

            updateYoutubeStatus('There are no video results to show yet.', true);
            return true;
        }

        function describeVideoByIndex(index) {
            if (!youtubeVideos[index]) {
                updateYoutubeStatus('I could not find that result.', true);
                return true;
            }

            readableResultIndex = index;

            const video = youtubeVideos[index];

            const message =
                'Result ' + (index + 1) + '. Title: ' + video.title +
                '. Channel: ' + video.channelTitle +
                '. You can say open this video, next result, previous result, or read again.';

            updateYoutubeStatus(message, true);

            const cards = document.querySelectorAll('.youtube-video-card');

            if (cards[index]) {
                cards[index].scrollIntoView({ behavior: 'smooth', block: 'center' });
                cards[index].classList.add('youtube-video-card-focused');

                setTimeout(function () {
                    cards[index].classList.remove('youtube-video-card-focused');
                }, 2500);
            }

            return true;
        }

        function readYoutubeResultsSummary() {
            if (!youtubeVideos || youtubeVideos.length === 0) {
                updateYoutubeStatus('There are no YouTube results to read yet.', true);
                return true;
            }

            readableResultIndex = 0;

            const count = youtubeVideos.length;
            let message = 'I found ' + count + ' video results. ';

            youtubeVideos.slice(0, 3).forEach(function (video, index) {
                message += 'Result ' + (index + 1) + ': ' + video.title + '. ';
            });

            message += 'Say first result, next result, previous result, or open this video.';

            updateYoutubeStatus(message, true);
            return true;
        }

        function readNextYoutubeResult() {
            if (!youtubeVideos || youtubeVideos.length === 0) {
                updateYoutubeStatus('There are no results to read.', true);
                return true;
            }

            readableResultIndex = Math.min(readableResultIndex + 1, youtubeVideos.length - 1);
            return describeVideoByIndex(readableResultIndex);
        }

        function readPreviousYoutubeResult() {
            if (!youtubeVideos || youtubeVideos.length === 0) {
                updateYoutubeStatus('There are no results to read.', true);
                return true;
            }

            readableResultIndex = Math.max(readableResultIndex - 1, 0);
            return describeVideoByIndex(readableResultIndex);
        }

        function openCurrentlyReadVideo() {
            if (!youtubeVideos || youtubeVideos.length === 0) {
                updateYoutubeStatus('There is no selected result to open.', true);
                return true;
            }

            return loadVideoByIndex(readableResultIndex);
        }

        function repeatLastYoutubeMessage() {
            if (lastSpokenYoutubeMessage) {
                updateYoutubeStatus(lastSpokenYoutubeMessage, true);
                return true;
            }

            updateYoutubeStatus('There is nothing to repeat yet.', true);
            return true;
        }

       function onYouTubeIframeAPIReady() {
    youtubePlayer = new YT.Player('youtubePlayer', {
        height: '390',
        width: '640',
        videoId: youtubeVideos.length > 0 ? youtubeVideos[0].videoId : '',
        playerVars: {
            playsinline: 1,
            rel: 0,
            modestbranding: 1
        },
        events: {
            onReady: function () {
                if (youtubeVideos.length > 0) {
                    selectedVideoIndex = 0;

                    if (youtubeAutoplayPosition > 0) {
                        const autoplayIndex = youtubeAutoplayPosition - 1;

                        setTimeout(function () {
                            loadVideoByIndex(autoplayIndex);
                        }, 800);

                        updateYoutubeStatus(
                            'I found the results and I am opening result ' + youtubeAutoplayPosition + '.',
                            true
                        );
                    } else {
                        updateYoutubeStatus(
                            'The first result is ready. Say results, play, pause, or open another result.',
                            false
                        );
                    }
                }
            }
        }
    });
}
        function loadVideoByIndex(index) {
            if (!youtubeVideos[index]) {
                updateYoutubeStatus('I could not find that video result.', true);
                return true;
            }

            if (!youtubePlayer || typeof youtubePlayer.loadVideoById !== 'function') {
                updateYoutubeStatus('The YouTube player is still loading. Please try again in a moment.', true);
                return true;
            }

            selectedVideoIndex = index;
            readableResultIndex = index;

            youtubePlayer.loadVideoById(youtubeVideos[index].videoId);

            updateYoutubeStatus('Loading result ' + (index + 1) + ': ' + youtubeVideos[index].title, true);

            return true;
        }

        function controlYoutubePlayer(action) {
            if (!youtubePlayer) {
                updateYoutubeStatus('The YouTube player is not ready yet.', true);
                return true;
            }

            if (action === 'play') {
                youtubePlayer.playVideo();
                updateYoutubeStatus('Playing the selected video.', true);
                return true;
            }

            if (action === 'pause') {
                youtubePlayer.pauseVideo();
                updateYoutubeStatus('Video paused.', true);
                return true;
            }

            if (action === 'volume_up') {
                const currentVolume = youtubePlayer.getVolume ? youtubePlayer.getVolume() : 50;
                youtubePlayer.setVolume(Math.min(100, currentVolume + 10));
                updateYoutubeStatus('Volume increased.', true);
                return true;
            }

            if (action === 'volume_down') {
                const currentVolume = youtubePlayer.getVolume ? youtubePlayer.getVolume() : 50;
                youtubePlayer.setVolume(Math.max(0, currentVolume - 10));
                updateYoutubeStatus('Volume decreased.', true);
                return true;
            }

            if (action === 'mute') {
                youtubePlayer.mute();
                updateYoutubeStatus('Video muted.', true);
                return true;
            }

            if (action === 'unmute') {
                youtubePlayer.unMute();
                updateYoutubeStatus('Video unmuted.', true);
                return true;
            }

            if (action === 'restart') {
                youtubePlayer.seekTo(0, true);
                youtubePlayer.playVideo();
                updateYoutubeStatus('Restarting the selected video.', true);
                return true;
            }

            return false;
        }

        function normalizeVoiceText(text) {
            return text
                .toLowerCase()
                .replace(/[^\w\s]/g, ' ')
                .replace(/\s+/g, ' ')
                .trim();
        }

        function removeCommandWords(text) {
            const stopWords = [
                'open', 'play', 'load', 'choose', 'select', 'click', 'watch',
                'video', 'result', 'results', 'the', 'a', 'an', 'please',
                'can', 'you', 'could', 'me', 'for', 'to', 'it', 'this',
                'that', 'one'
            ];

            return normalizeVoiceText(text)
                .split(' ')
                .filter(function (word) {
                    return word && !stopWords.includes(word);
                })
                .join(' ')
                .trim();
        }

        function findBestVideoMatch(spokenText) {
            if (!youtubeVideos || youtubeVideos.length === 0) {
                return null;
            }

            const cleanedCommand = removeCommandWords(spokenText);

            if (!cleanedCommand) {
                return null;
            }

            const commandWords = cleanedCommand
                .split(' ')
                .filter(function (word) {
                    return word.length >= 3;
                });

            let bestMatch = null;
            let bestScore = 0;

            youtubeVideos.forEach(function (video, index) {
                const title = normalizeVoiceText(video.title || '');
                const channel = normalizeVoiceText(video.channelTitle || '');
                const searchableText = title + ' ' + channel;

                let score = 0;

                if (searchableText.includes(cleanedCommand)) {
                    score += 10;
                }

                commandWords.forEach(function (word) {
                    if (title.includes(word)) {
                        score += 3;
                    }

                    if (channel.includes(word)) {
                        score += 1;
                    }
                });

                if (score > bestScore) {
                    bestScore = score;
                    bestMatch = {
                        index: index,
                        score: score,
                        title: video.title
                    };
                }
            });

            if (bestMatch && bestMatch.score >= 3) {
                return bestMatch;
            }

            return null;
        }

        function parseResultPosition(text) {
            const normalized = normalizeVoiceText(text);

            const positionPatterns = [
                { index: 0, patterns: ['first', '1', 'one', 'number one', 'video one', 'result one', 'first result', 'first video'] },
                { index: 1, patterns: ['second', '2', 'two', 'number two', 'video two', 'result two', 'second result', 'second video'] },
                { index: 2, patterns: ['third', '3', 'three', 'number three', 'video three', 'result three', 'third result', 'third video'] },
                { index: 3, patterns: ['fourth', '4', 'four', 'number four', 'video four', 'result four', 'fourth result', 'fourth video'] },
                { index: 4, patterns: ['fifth', '5', 'five', 'number five', 'video five', 'result five', 'fifth result', 'fifth video'] },
                { index: 5, patterns: ['sixth', '6', 'six', 'number six', 'video six', 'result six', 'sixth result', 'sixth video'] }
            ];

            for (const item of positionPatterns) {
                for (const pattern of item.patterns) {
                    const regex = new RegExp('(^|\\s)' + pattern.replace(' ', '\\s+') + '(\\s|$)', 'i');

                    if (regex.test(normalized)) {
                        return item.index;
                    }
                }
            }

            return null;
        }
        function parseYoutubeSearchCommand(text) {
    const normalized = normalizeVoiceText(text);

    const hasSearchIntent =
        normalized.includes('search for') ||
        normalized.includes('search youtube for') ||
        normalized.includes('look for') ||
        normalized.includes('find') ||
        normalized.includes('look up');

    if (!hasSearchIntent) {
        return null;
    }

    let query = normalized;

    query = query.replace('search youtube for', '');
    query = query.replace('search for', '');
    query = query.replace('look for', '');
    query = query.replace('look up', '');
    query = query.replace('find', '');

    const autoplayPosition = parseResultPosition(normalized);

    const cutPatterns = [
        'and open first video',
        'and open second video',
        'and open third video',
        'and open fourth video',
        'and open fifth video',
        'and open sixth video',
        'and play first video',
        'and play second video',
        'and play third video',
        'and play fourth video',
        'and play fifth video',
        'and play sixth video',
        'and open the first video',
        'and open the second video',
        'and open the third video',
        'and play the first video',
        'and play the second video',
        'and play the third video',
        'open first video',
        'open second video',
        'open third video',
        'play first video',
        'play second video',
        'play third video',
        'open the first video',
        'open the second video',
        'open the third video',
        'play the first video',
        'play the second video',
        'play the third video'
    ];

    cutPatterns.forEach(function (pattern) {
        query = query.replace(pattern, '');
    });

    query = query
        .replace(/\band\b/g, ' ')
        .replace(/\bvideo\b/g, ' ')
        .replace(/\bvideos\b/g, ' ')
        .replace(/\bplease\b/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();

    if (query === '') {
        return null;
    }

    return {
        query: query,
        autoplayPosition: autoplayPosition !== null ? autoplayPosition + 1 : null
    };
}

        window.handlePageVoiceCommand = function (text) {
            const normalized = normalizeVoiceText(text);
            const searchCommand = parseYoutubeSearchCommand(normalized);

if (searchCommand !== null) {
    let url = '{{ path('front_youtube_assistant') }}?q=' + encodeURIComponent(searchCommand.query);

    if (searchCommand.autoplayPosition !== null) {
        url += '&autoplay=' + encodeURIComponent(searchCommand.autoplayPosition);
    }

    updateYoutubeStatus('Searching YouTube for ' + searchCommand.query + '.', true);

    setTimeout(function () {
        window.location.href = url;
    }, 600);

    return true;
}
            

            if (
                normalized === 'repeat' ||
                normalized === 'say that again' ||
                normalized === 'repeat that' ||
                normalized === 'read again'
            ) {
                return repeatLastYoutubeMessage();
            }

            if (
                normalized === 'scroll down' ||
                normalized === 'go down' ||
                normalized === 'move down' ||
                normalized === 'pull down' ||
                normalized === 'page down' ||
                normalized === 'down' ||
                normalized.includes('scroll down') ||
                normalized.includes('go down') ||
                normalized.includes('move down') ||
                normalized.includes('pull down')
            ) {
                return scrollAssistantPage('down');
            }

            if (
                normalized === 'scroll up' ||
                normalized === 'go up' ||
                normalized === 'move up' ||
                normalized === 'pull up' ||
                normalized === 'page up' ||
                normalized === 'up' ||
                normalized.includes('scroll up') ||
                normalized.includes('go up') ||
                normalized.includes('move up') ||
                normalized.includes('pull up')
            ) {
                return scrollAssistantPage('up');
            }

            if (
                normalized.includes('go to player') ||
                normalized.includes('show player') ||
                normalized.includes('move to player')
            ) {
                return goToYoutubePlayer();
            }

            if (
                normalized.includes('go to results') ||
                normalized.includes('show results') ||
                normalized.includes('move to results')
            ) {
                return goToYoutubeResults();
            }

            if (
                normalized === 'results' ||
                normalized === 'result' ||
                normalized === 'read results' ||
                normalized === 'read result' ||
                normalized === 'read video results' ||
                normalized === 'show results' ||
                normalized === 'show me results' ||
                normalized === 'what are the results' ||
                normalized === 'tell me the results' ||
                normalized.includes('read results') ||
                normalized.includes('show results') ||
                normalized.includes('tell me results') ||
                normalized.includes('video results') ||
                normalized.includes('the results') ||
                normalized.includes('eid results')
            ) {
                return readYoutubeResultsSummary();
            }

            if (
                normalized === 'next' ||
                normalized === 'next one' ||
                normalized.includes('read next') ||
                normalized.includes('next result') ||
                normalized.includes('next video') ||
                normalized.includes('go next') ||
                normalized.includes('move next')
            ) {
                return readNextYoutubeResult();
            }

            if (
                normalized === 'previous' ||
                normalized === 'back' ||
                normalized === 'previous one' ||
                normalized.includes('read previous') ||
                normalized.includes('previous result') ||
                normalized.includes('previous video') ||
                normalized.includes('go back one result') ||
                normalized.includes('go previous') ||
                normalized.includes('move previous')
            ) {
                return readPreviousYoutubeResult();
            }

            if (
                normalized === 'open this' ||
                normalized === 'play this' ||
                normalized === 'open it' ||
                normalized === 'play it' ||
                normalized === 'open the video' ||
                normalized === 'play the video' ||
                normalized === 'start the video' ||
                normalized === 'replay the video' ||
                normalized.includes('open this video') ||
                normalized.includes('play this video') ||
                normalized.includes('open current video') ||
                normalized.includes('play current video') ||
                normalized.includes('load this video')
            ) {
                return openCurrentlyReadVideo();
            }

            const position = parseResultPosition(normalized);

            const wantsVideoSelection =
                normalized.includes('open') ||
                normalized.includes('play') ||
                normalized.includes('load') ||
                normalized.includes('choose') ||
                normalized.includes('select') ||
                normalized.includes('click') ||
                normalized.includes('watch') ||
                normalized.includes('video') ||
                normalized.includes('result');

            if (position !== null && wantsVideoSelection) {
                return loadVideoByIndex(position);
            }

            if (wantsVideoSelection) {
                const titleMatch = findBestVideoMatch(normalized);

                if (titleMatch !== null) {
                    updateYoutubeStatus(
                        'I matched your command to result ' + (titleMatch.index + 1) + ': ' + titleMatch.title,
                        true
                    );

                    return loadVideoByIndex(titleMatch.index);
                }
            }

            if (
                normalized === 'play' ||
                normalized === 'play it' ||
                normalized === 'play video' ||
                normalized === 'play the video' ||
                normalized === 'start' ||
                normalized === 'start it' ||
                normalized === 'start video' ||
                normalized === 'start the video' ||
                normalized === 'resume' ||
                normalized === 'resume video' ||
                normalized === 'continue' ||
                normalized.includes('play this') ||
                normalized.includes('continue playing')
            ) {
                return controlYoutubePlayer('play');
            }

            if (
                normalized === 'pause' ||
                normalized === 'pause it' ||
                normalized === 'pause video' ||
                normalized === 'pause the video' ||
                normalized === 'stop' ||
                normalized === 'stop it' ||
                normalized === 'stop video' ||
                normalized === 'stop the video' ||
                normalized === 'hold on' ||
                normalized === 'wait' ||
                normalized.includes('pause this')
            ) {
                return controlYoutubePlayer('pause');
            }

            if (
                normalized === 'restart' ||
                normalized === 'restart video' ||
                normalized === 'restart the video' ||
                normalized === 'replay' ||
                normalized === 'replay video'
            ) {
                return controlYoutubePlayer('restart');
            }

            if (
                normalized.includes('volume up') ||
                normalized.includes('increase volume') ||
                normalized.includes('raise volume') ||
                normalized.includes('louder')
            ) {
                return controlYoutubePlayer('volume_up');
            }

            if (
                normalized.includes('volume down') ||
                normalized.includes('decrease volume') ||
                normalized.includes('lower volume') ||
                normalized.includes('quieter')
            ) {
                return controlYoutubePlayer('volume_down');
            }

            if (
                normalized.includes('unmute') ||
                normalized.includes('turn on sound')
            ) {
                return controlYoutubePlayer('unmute');
            }

            if (
                normalized === 'mute' ||
                normalized === 'mute it' ||
                normalized.includes('mute video') ||
                normalized.includes('turn off sound')
            ) {
                return controlYoutubePlayer('mute');
            }

            if (normalized.includes('search youtube for')) {
                const query = normalized.replace('search youtube for', '').trim();

                if (query !== '') {
                    window.location.href = '{{ path('front_youtube_assistant') }}?q=' + encodeURIComponent(query);
                    return true;
                }
            }

            if (normalized.includes('search for')) {
                const query = normalized.replace('search for', '').trim();

                if (query !== '') {
                    window.location.href = '{{ path('front_youtube_assistant') }}?q=' + encodeURIComponent(query);
                    return true;
                }
            }

            return false;
        };

        document.querySelectorAll('.js-load-video').forEach(function (button) {
            button.addEventListener('click', function () {
                const index = parseInt(button.dataset.index, 10);
                loadVideoByIndex(index);
            });
        });

        document.querySelectorAll('[data-player-action]').forEach(function (button) {
            button.addEventListener('click', function () {
                controlYoutubePlayer(button.dataset.playerAction);
            });
        });
    </script>

    <script src="https://www.youtube.com/iframe_api"></script>
{% endblock %}