{% extends 'base.html.twig' %}

{% block title %}Create New Password - Assistant Vocal{% endblock %}

{% block body %}
    <main class="reset-page">
        <section class="reset-card">
            <div class="reset-bg" aria-hidden="true">
                <span class="reset-orb reset-orb-one"></span>
                <span class="reset-orb reset-orb-two"></span>
            </div>

            <header class="reset-header">
                <div class="reset-icon reset-icon-success">
                    <i data-lucide="badge-check"></i>
                </div>

                <span class="reset-kicker">
                    <i data-lucide="shield-check"></i>
                    Secure Password
                </span>

                <h1>Create New Password</h1>

                <p>
                    Choose a strong password to secure your account.
                </p>
            </header>

            {{ form_start(resetForm, {'attr': {'class': 'reset-form'}}) }}
                <div class="reset-form-group">
                    <div class="reset-password-field">
                        {{ form_row(resetForm.plainPassword, {
                            label: false,
                            attr: {
                                class: 'reset-input reset-password-input'
                            }
                        }) }}
                    </div>
                </div>

                <button type="submit" class="reset-submit-btn reset-submit-success">
                    <i data-lucide="check"></i>
                    Reset Password
                </button>
            {{ form_end(resetForm) }}

            <div class="reset-back-row">
                <a href="{{ path('app_login') }}">
                    <i data-lucide="arrow-left"></i>
                    Back to Login
                </a>
            </div>
        </section>
    </main>

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background:
                radial-gradient(circle at 85% 5%, rgba(37, 99, 235, 0.14), transparent 32%),
                radial-gradient(circle at 35% 95%, rgba(56, 189, 248, 0.10), transparent 34%),
                linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
        }

        .reset-page,
        .reset-page * {
            box-sizing: border-box;
        }

        .reset-page {
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
            color: #0f172a;
        }

        .reset-card {
            position: relative;
            width: min(560px, 100%);
            overflow: hidden;
            border-radius: 30px;
            padding: clamp(26px, 4vw, 40px);
            background: #ffffff;
            border: 1px solid #e2e8f0;
            box-shadow: 0 28px 90px rgba(15, 23, 42, 0.16);
        }

        .reset-card::before {
            content: "";
            position: absolute;
            inset: 0;
            height: 220px;
            background:
                radial-gradient(circle at 78% 30%, rgba(37, 99, 235, 0.24), transparent 34%),
                linear-gradient(135deg, #071126 0%, #111827 52%, #172554 100%);
            pointer-events: none;
        }

        .reset-card::after {
            content: "";
            position: absolute;
            top: -45%;
            left: -45%;
            width: 190%;
            height: 430px;
            background:
                conic-gradient(from 0deg, transparent, rgba(59, 130, 246, 0.22), transparent, rgba(56, 189, 248, 0.16), transparent);
            filter: blur(80px);
            opacity: 0.72;
            animation: resetAurora 18s linear infinite;
            pointer-events: none;
        }

        .reset-bg {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .reset-orb {
            position: absolute;
            border-radius: 999px;
            filter: blur(12px);
            opacity: 0.38;
            mix-blend-mode: screen;
        }

        .reset-orb-one {
            width: 190px;
            height: 190px;
            right: 9%;
            top: 4%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.95), transparent 66%);
            animation: resetFloatOne 8s ease-in-out infinite;
        }

        .reset-orb-two {
            width: 130px;
            height: 130px;
            left: 9%;
            top: 70px;
            background: radial-gradient(circle, rgba(14, 165, 233, 0.8), transparent 68%);
            animation: resetFloatTwo 10s ease-in-out infinite;
        }

        .reset-header,
        .reset-form,
        .reset-back-row {
            position: relative;
            z-index: 1;
        }

        .reset-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .reset-icon {
            width: 92px;
            height: 92px;
            display: grid;
            place-items: center;
            margin: 0 auto 18px;
            border-radius: 28px;
            color: #ffffff;
            background:
                radial-gradient(circle at 35% 25%, rgba(125, 211, 252, 0.95), transparent 34%),
                linear-gradient(135deg, #2563eb, #1d4ed8);
            box-shadow:
                0 0 0 10px rgba(37, 99, 235, 0.18),
                0 22px 46px rgba(37, 99, 235, 0.38);
        }

        .reset-icon-success {
            background:
                radial-gradient(circle at 35% 25%, rgba(187, 247, 208, 0.95), transparent 34%),
                linear-gradient(135deg, #16a34a, #15803d);
            box-shadow:
                0 0 0 10px rgba(22, 163, 74, 0.16),
                0 22px 46px rgba(22, 163, 74, 0.28);
        }

        .reset-icon svg {
            width: 40px;
            height: 40px;
        }

        .reset-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
            margin-bottom: 14px;
            border-radius: 999px;
            color: #bfdbfe;
            background: rgba(37, 99, 235, 0.18);
            border: 1px solid rgba(147, 197, 253, 0.24);
            font-size: 11px;
            font-weight: 950;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .reset-kicker svg {
            width: 15px;
            height: 15px;
        }

        .reset-header h1 {
            margin: 0;
            color: #ffffff;
            font-size: clamp(36px, 5vw, 56px);
            line-height: 0.98;
            letter-spacing: -0.06em;
            font-weight: 950;
        }

        .reset-header p {
            margin: 12px 0 0;
            color: #cbd5e1;
            font-size: 17px;
            line-height: 1.5;
            font-weight: 650;
        }

        .reset-form {
            display: grid;
            gap: 18px;
            margin-top: 28px;
        }

        .reset-password-field input {
            width: 100%;
            min-height: 60px;
            padding: 0 16px;
            border-radius: 18px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            color: #0f172a;
            font-size: 16px;
            font-weight: 750;
            outline: 0;
            transition: 180ms ease;
        }

        .reset-password-field input:focus {
            background: #ffffff;
            border-color: #93c5fd;
            box-shadow:
                0 0 0 4px rgba(37, 99, 235, 0.10),
                0 14px 30px rgba(15, 23, 42, 0.07);
        }

        .reset-password-field label {
            display: block;
            margin-bottom: 8px;
            color: #334155;
            font-size: 14px;
            font-weight: 900;
        }

        .reset-password-field ul {
            margin: 8px 0 0;
            padding-left: 18px;
            color: #991b1b;
            font-size: 13px;
            font-weight: 700;
        }

        .reset-submit-btn {
            min-height: 58px;
            width: 100%;
            border: 0;
            border-radius: 18px;
            color: #ffffff;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            box-shadow: 0 18px 38px rgba(37, 99, 235, 0.30);
            font-size: 16px;
            font-weight: 950;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: 180ms ease;
        }

        .reset-submit-success {
            background: linear-gradient(135deg, #16a34a, #15803d);
            box-shadow: 0 18px 38px rgba(22, 163, 74, 0.24);
        }

        .reset-submit-btn:hover {
            transform: translateY(-2px);
        }

        .reset-submit-btn svg {
            width: 20px;
            height: 20px;
        }

        .reset-back-row {
            display: flex;
            justify-content: center;
            margin-top: 22px;
        }

        .reset-back-row a {
            min-height: 46px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0 14px;
            border-radius: 999px;
            color: #1d4ed8;
            background: #eff6ff;
            border: 1px solid #dbeafe;
            text-decoration: none;
            font-size: 14px;
            font-weight: 900;
        }

        .reset-back-row svg {
            width: 17px;
            height: 17px;
        }

        @keyframes resetAurora { to { transform: rotate(360deg); } }
        @keyframes resetFloatOne { 0%,100%{transform:translate3d(0,0,0) scale(1);} 50%{transform:translate3d(-34px,26px,0) scale(1.12);} }
        @keyframes resetFloatTwo { 0%,100%{transform:translate3d(0,0,0) scale(1);} 50%{transform:translate3d(38px,-18px,0) scale(1.14);} }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.lucide) {
                lucide.createIcons();
            }
        });
    </script>
{% endblock %}