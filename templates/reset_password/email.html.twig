<div style="margin:0; padding:0; background:#f8fafc; font-family:Arial, Helvetica, sans-serif;">
    <div style="max-width:620px; margin:0 auto; padding:32px 18px;">
        <div style="background:#ffffff; border:1px solid #e2e8f0; border-radius:24px; overflow:hidden; box-shadow:0 18px 45px rgba(15,23,42,0.10);">
            <div style="padding:34px; background:linear-gradient(135deg,#071126 0%,#111827 52%,#172554 100%); color:#ffffff;">
                <h2 style="margin:0; font-size:30px; line-height:1.05; letter-spacing:-0.04em; font-weight:900;">
                    Password Reset Request
                </h2>

                <p style="margin:12px 0 0; color:#cbd5e1; line-height:1.6; font-size:15px;">
                    Secure account recovery for your Assistant Vocal account.
                </p>
            </div>

            <div style="padding:34px;">
                <p style="margin:0 0 14px; color:#334155; line-height:1.7; font-size:16px;">
                    Hello,
                </p>

                <p style="margin:0 0 14px; color:#334155; line-height:1.7; font-size:16px;">
                    We received a request to reset the password for your Voice Assistant account.
                </p>

                <p style="margin:0 0 22px; color:#334155; line-height:1.7; font-size:16px;">
                    Click the button below to create a new password:
                </p>

                <p style="margin:0 0 24px;">
                    <a href="{{ url('app_reset_password', {token: resetToken.token}) }}"
                       style="display:inline-block; padding:14px 20px; background:#2563eb; color:#ffffff; text-decoration:none; border-radius:14px; font-weight:bold; font-size:15px;">
                        Reset My Password
                    </a>
                </p>

                <div style="padding:16px; background:#eff6ff; border:1px solid #dbeafe; border-radius:16px; margin-bottom:22px;">
                    <p style="margin:0; color:#1e40af; line-height:1.6; font-size:15px;">
                        This link will expire in
                        <strong>{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</strong>.
                    </p>
                </div>

                <p style="margin:0 0 16px; color:#64748b; line-height:1.7; font-size:15px;">
                    If you did not request this password reset, you can safely ignore this email.
                </p>

                <p style="margin:0; color:#334155; font-weight:bold;">
                    Assistant Vocal Support
                </p>
            </div>
        </div>
    </div>
</div>