{% extends 'base.html.twig' %}

{% block title %}Check Your Email - Assistant Vocal{% endblock %}

{% block body %}
    <main class="reset-page">
        <section class="reset-card">
            <div class="reset-bg" aria-hidden="true">
                <span class="reset-orb reset-orb-one"></span>
                <span class="reset-orb reset-orb-two"></span>
            </div>

            <header class="reset-header">
                <img
                    src="{{ asset('assets/images/assistant-vocal-logo.png') }}"
                    alt="Assistant Vocal logo"
                    class="reset-logo"
                >

                <span class="reset-kicker">
                    <i data-lucide="mail-check"></i>
                    Password Reset
                </span>

                <h1>Check Your Email</h1>

                <p>
                    If an account matching your email exists, then an email was sent with a secure reset link.
                </p>
            </header>

            <div class="reset-info-box">
                <div class="reset-info-icon">
                    <i data-lucide="clock"></i>
                </div>

                <div>
                    <strong>Reset link expiration</strong>
                    <p>
                        This link will expire in
                        <strong>{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</strong>.
                    </p>
                </div>
            </div>

            <p class="reset-note">
                If you do not receive an email, check your spam folder or try again.
            </p>

            <div class="reset-actions">
                <a href="{{ path('app_forgot_password_request') }}" class="reset-btn reset-btn-primary">
                    <i data-lucide="refresh-cw"></i>
                    Try Again
                </a>

                <a href="{{ path('app_login') }}" class="reset-btn reset-btn-secondary">
                    <i data-lucide="arrow-left"></i>
                    Back to Login
                </a>
            </div>
        </section>
    </main>

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background:
                radial-gradient(circle at 85% 5%, rgba(37, 99, 235, 0.14), transparent 32%),
                radial-gradient(circle at 35% 95%, rgba(56, 189, 248, 0.10), transparent 34%),
                linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
        }

        .reset-page,
        .reset-page * {
            box-sizing: border-box;
        }

        .reset-page {
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
            color: #0f172a;
        }

        .reset-card {
            position: relative;
            width: min(620px, 100%);
            overflow: hidden;
            border-radius: 32px;
            padding: clamp(28px, 5vw, 44px);
            background: #ffffff;
            border: 1px solid #e2e8f0;
            box-shadow: 0 28px 90px rgba(15, 23, 42, 0.16);
        }

        .reset-card::before {
            content: "";
            position: absolute;
            inset: 0;
            height: 240px;
            background:
                radial-gradient(circle at 78% 30%, rgba(37, 99, 235, 0.24), transparent 34%),
                linear-gradient(135deg, #071126 0%, #111827 52%, #172554 100%);
            pointer-events: none;
        }

        .reset-card::after {
            content: "";
            position: absolute;
            top: -45%;
            left: -45%;
            width: 190%;
            height: 450px;
            background:
                conic-gradient(from 0deg, transparent, rgba(59, 130, 246, 0.22), transparent, rgba(56, 189, 248, 0.16), transparent);
            filter: blur(80px);
            opacity: 0.72;
            animation: resetAurora 18s linear infinite;
            pointer-events: none;
        }

        .reset-bg {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .reset-orb {
            position: absolute;
            border-radius: 999px;
            filter: blur(12px);
            opacity: 0.38;
            mix-blend-mode: screen;
        }

        .reset-orb-one {
            width: 190px;
            height: 190px;
            right: 9%;
            top: 4%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.95), transparent 66%);
            animation: resetFloatOne 8s ease-in-out infinite;
        }

        .reset-orb-two {
            width: 130px;
            height: 130px;
            left: 9%;
            top: 76px;
            background: radial-gradient(circle, rgba(14, 165, 233, 0.8), transparent 68%);
            animation: resetFloatTwo 10s ease-in-out infinite;
        }

        .reset-header,
        .reset-info-box,
        .reset-note,
        .reset-actions {
            position: relative;
            z-index: 1;
        }

        .reset-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .reset-logo {
            width: 86px;
            height: 86px;
            object-fit: cover;
            border-radius: 26px;
            margin-bottom: 18px;
            box-shadow:
                0 0 0 10px rgba(37, 99, 235, 0.18),
                0 22px 46px rgba(37, 99, 235, 0.38);
        }

        .reset-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
            margin-bottom: 14px;
            border-radius: 999px;
            color: #bfdbfe;
            background: rgba(37, 99, 235, 0.18);
            border: 1px solid rgba(147, 197, 253, 0.24);
            font-size: 11px;
            font-weight: 950;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .reset-kicker svg {
            width: 15px;
            height: 15px;
        }

        .reset-header h1 {
            margin: 0;
            color: #ffffff;
            font-size: clamp(36px, 5vw, 56px);
            line-height: 0.98;
            letter-spacing: -0.06em;
            font-weight: 950;
        }

        .reset-header p {
            max-width: 520px;
            margin: 12px auto 0;
            color: #cbd5e1;
            font-size: 17px;
            line-height: 1.55;
            font-weight: 650;
        }

        .reset-info-box {
            display: flex;
            gap: 14px;
            align-items: flex-start;
            padding: 18px;
            border-radius: 20px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            margin-bottom: 18px;
        }

        .reset-info-icon {
            width: 46px;
            height: 46px;
            flex: 0 0 auto;
            display: grid;
            place-items: center;
            border-radius: 16px;
            color: #2563eb;
            background: #eff6ff;
            border: 1px solid #dbeafe;
        }

        .reset-info-icon svg {
            width: 22px;
            height: 22px;
        }

        .reset-info-box strong {
            color: #0f172a;
            font-weight: 950;
        }

        .reset-info-box p,
        .reset-note {
            margin: 7px 0 0;
            color: #64748b;
            font-size: 15px;
            line-height: 1.6;
            font-weight: 650;
        }

        .reset-note {
            text-align: center;
            margin: 18px 0 22px;
        }

        .reset-actions {
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .reset-btn {
            min-height: 52px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            padding: 0 18px;
            border-radius: 16px;
            text-decoration: none;
            font-size: 15px;
            font-weight: 950;
            transition: 180ms ease;
        }

        .reset-btn svg {
            width: 18px;
            height: 18px;
        }

        .reset-btn:hover {
            transform: translateY(-2px);
        }

        .reset-btn-primary {
            color: #ffffff;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            box-shadow: 0 16px 34px rgba(37, 99, 235, 0.28);
        }

        .reset-btn-secondary {
            color: #1d4ed8;
            background: #eff6ff;
            border: 1px solid #dbeafe;
        }

        @keyframes resetAurora { to { transform: rotate(360deg); } }
        @keyframes resetFloatOne { 0%,100%{transform:translate3d(0,0,0) scale(1);} 50%{transform:translate3d(-34px,26px,0) scale(1.12);} }
        @keyframes resetFloatTwo { 0%,100%{transform:translate3d(0,0,0) scale(1);} 50%{transform:translate3d(38px,-18px,0) scale(1.14);} }

        @media (max-width: 640px) {
            .reset-card {
                border-radius: 24px;
                padding: 24px 18px;
            }

            .reset-btn {
                width: 100%;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.lucide) {
                lucide.createIcons();
            }
        });
    </script>
{% endblock %}