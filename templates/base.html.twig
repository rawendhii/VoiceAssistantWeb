<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Voice Assistant{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        * {
            box-sizing: border-box;
        }

        :root {
            --bg: #f4f7fb;
            --surface: #ffffff;
            --surface-soft: #eef4ff;
            --text: #0f172a;
            --muted: #475569;
            --border: #cbd5e1;
            --primary: #0b5fff;
            --primary-dark: #0847c7;
            --danger: #c62828;
            --danger-dark: #8f1d1d;
            --success-bg: #dcfce7;
            --success-text: #166534;
            --error-bg: #fee2e2;
            --error-text: #991b1b;
            --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
            --radius: 16px;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 18px;
            line-height: 1.6;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }

        .card {
            background: var(--surface);
            border: 2px solid var(--border);
            border-radius: var(--radius);
            padding: 22px;
            margin-bottom: 20px;
            overflow-x: auto;
            box-shadow: var(--shadow);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            min-height: 52px;
            padding: 14px 20px;
            border-radius: 14px;
            border: none;
            cursor: pointer;
            background: var(--primary);
            color: white;
            font-weight: 700;
            font-size: 17px;
            box-shadow: 0 8px 18px rgba(11, 95, 255, 0.22);
            transition: 0.2s ease;
        }

        .btn:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
        }

        .btn-danger {
            background: var(--danger);
            color: white;
        }

        .btn-danger:hover {
            background: var(--danger-dark);
        }

        .btn-secondary {
            background: #475569;
            color: white;
        }

        .btn-secondary:hover {
            background: #334155;
        }

        .btn-voice {
            min-height: 64px;
            min-width: 240px;
            font-size: 20px;
            border-radius: 18px;
        }

        .btn-voice.listening {
            background: #b91c1c;
            animation: pulse 1.2s infinite;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(185, 28, 28, 0.35); }
            70% { box-shadow: 0 0 0 16px rgba(185, 28, 28, 0); }
            100% { box-shadow: 0 0 0 0 rgba(185, 28, 28, 0); }
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            min-width: 700px;
        }

        table th,
        table td {
            border: 1px solid #dbe2ea;
            padding: 14px;
            text-align: left;
            vertical-align: middle;
            font-size: 16px;
        }

        table th {
            background: #eaf1f8;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: #334155;
        }

        input,
        select,
        textarea {
            width: 100%;
            min-height: 52px;
            padding: 12px 14px;
            margin-top: 8px;
            margin-bottom: 14px;
            border: 2px solid var(--border);
            border-radius: 14px;
            background: white;
            color: var(--text);
            font-size: 17px;
        }

        textarea {
            min-height: 130px;
            resize: vertical;
        }

        label {
            font-weight: 700;
            display: inline-block;
            margin-top: 4px;
        }

        .help-text {
            color: var(--muted);
            font-size: 15px;
            margin-top: -6px;
            margin-bottom: 14px;
        }

        .flash {
            padding: 14px 18px;
            border-radius: 14px;
            margin-bottom: 16px;
            font-weight: 700;
            border: 2px solid transparent;
            transition: opacity 0.5s ease, transform 0.5s ease;
            opacity: 1;
        }

        .flash-success {
            background: var(--success-bg);
            color: var(--success-text);
            border-color: #86efac;
        }

        .flash-error {
            background: var(--error-bg);
            color: var(--error-text);
            border-color: #fca5a5;
        }

        .flash.hide {
            opacity: 0;
            transform: translateY(-10px);
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 24px;
        }

        .page-title {
            margin: 0;
            font-size: 34px;
            font-weight: 800;
            letter-spacing: -0.02em;
            color: #0f172a;
        }

        .page-subtitle {
            margin: 8px 0 0;
            color: #475569;
            font-size: 18px;
        }

        .status-panel {
            background: #f8fbff;
            border: 2px solid #bfdbfe;
            border-radius: 16px;
            padding: 18px;
        }

        .status-label {
            font-size: 14px;
            font-weight: 800;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: #1d4ed8;
            margin-bottom: 8px;
        }

        .status-value {
            font-size: 20px;
            font-weight: 700;
            color: #0f172a;
            min-height: 34px;
        }

        .voice-grid {
            display: grid;
            grid-template-columns: 1.1fr 1fr;
            gap: 18px;
            align-items: start;
        }

        .shortcut-box {
            background: #0f172a;
            color: white;
            border-radius: 16px;
            padding: 18px;
        }

        .shortcut-box h3 {
            margin-top: 0;
            margin-bottom: 8px;
            font-size: 20px;
        }

        .shortcut-box p {
            margin: 0 0 10px;
            color: #dbeafe;
        }

        .shortcut-key {
            display: inline-block;
            background: white;
            color: #0f172a;
            border-radius: 10px;
            padding: 6px 10px;
            font-weight: 800;
            margin-right: 6px;
            min-width: 48px;
            text-align: center;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card {
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            border: 2px solid #e2e8f0;
            border-radius: 18px;
            padding: 20px;
            box-shadow: var(--shadow);
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background: #eff6ff;
            margin-bottom: 12px;
        }

        .stat-icon svg {
            width: 22px;
            height: 22px;
            color: #2563eb;
        }

        .stat-label {
            font-size: 15px;
            font-weight: 700;
            color: #64748b;
            margin-bottom: 10px;
        }

        .stat-value {
            font-size: 34px;
            font-weight: 800;
            color: #0f172a;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 18px;
        }

        .chart-card canvas {
            margin-top: 10px;
        }

        .card-header h3 {
            margin: 0 0 6px;
            font-size: 22px;
        }

        .card-header p {
            margin: 0 0 12px;
            color: #64748b;
            font-size: 15px;
        }

        .quick-links {
            display: grid;
            gap: 12px;
        }

        .quick-link-card {
            display: block;
            padding: 16px;
            border-radius: 14px;
            background: #f8fafc;
            border: 2px solid #e2e8f0;
            transition: 0.2s ease;
            color: #0f172a;
        }

        .quick-link-card:hover {
            background: #eff6ff;
            border-color: #60a5fa;
            transform: translateY(-1px);
        }

        .quick-link-card span {
            display: block;
            font-size: 13px;
            color: #64748b;
            margin-bottom: 4px;
        }

        .quick-link-card strong {
            font-size: 16px;
        }

        .admin-shell,
        .front-shell {
            display: flex;
            min-height: 100vh;
            background: var(--bg);
        }

        .admin-sidebar,
        .front-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            color: white;
            padding: 24px 16px;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            z-index: 1000;
        }

        .admin-sidebar {
            width: 260px;
            background: linear-gradient(180deg, #081225 0%, #0b1730 100%);
            border-right: 1px solid rgba(255,255,255,0.06);
        }

        .front-sidebar {
            width: 250px;
            background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
        }

        .admin-brand,
        .front-brand {
            font-size: 28px;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 6px;
        }

        .admin-subtitle,
        .front-subtitle {
            font-size: 15px;
            color: #cbd5e1;
            margin-bottom: 28px;
        }

        .admin-nav,
        .front-nav {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .admin-link,
        .front-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 15px 16px;
            border-radius: 14px;
            color: #ffffff;
            background: rgba(255, 255, 255, 0.10);
            transition: 0.2s ease;
            font-size: 17px;
            font-weight: 700;
        }

        .admin-link svg,
        .front-link svg {
            width: 20px;
            height: 20px;
        }

        .admin-link:hover,
        .front-link:hover {
            background: rgba(255, 255, 255, 0.18);
        }

        .admin-link.active,
        .front-link.active {
            background: #2563eb;
        }

        .admin-sidebar-footer,
        .front-sidebar-footer {
            margin-top: auto;
            padding-top: 20px;
        }

        .logout-link {
            background: rgba(220, 38, 38, 0.20);
        }

        .logout-link:hover {
            background: rgba(220, 38, 38, 0.32);
        }

        .admin-main {
            margin-left: 260px;
            width: calc(100% - 260px);
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
        }

        .front-main {
            margin-left: 250px;
            width: calc(100% - 250px);
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
        }

        .admin-topbar,
        .front-topbar {
            height: 78px;
            background: white;
            border-bottom: 2px solid #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px;
            position: sticky;
            top: 0;
            z-index: 500;
        }

        .admin-topbar-title,
        .front-topbar-title {
            font-size: 24px;
            font-weight: 800;
        }

        .admin-topbar-user,
        .front-topbar-user {
            font-size: 15px;
            color: #334155;
            font-weight: 700;
        }

        .admin-content,
        .front-content {
            padding: 24px;
        }

        :focus-visible {
            outline: 4px solid #f59e0b;
            outline-offset: 3px;
        }

        @media (max-width: 1100px) {
            .dashboard-grid,
            .voice-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 900px) {
            .admin-shell,
            .front-shell {
                flex-direction: column;
            }

            .admin-sidebar,
            .front-sidebar {
                position: relative;
                width: 100%;
                height: auto;
                border-right: none;
            }

            .admin-main,
            .front-main {
                margin-left: 0;
                width: 100%;
            }

            .admin-topbar,
            .front-topbar {
                padding: 0 16px;
                height: auto;
                min-height: 72px;
            }

            .admin-content,
            .front-content {
                padding: 16px;
            }

            body {
                font-size: 17px;
            }
        }
        .page-wrapper {
    width: 100%;
    padding: 30px 40px;
}

/* TITLES */
.page-title {
    font-size: 22px;
    margin-bottom: 25px;
    color: #111827;
}

.danger-text {
    color: #b91c1c;
}

/* CARD */
.card {
    width: 100%;
    background: #fff;
    border: 1px solid #e5e7eb;
    padding: 25px;
    border-radius: 6px;
}

/* FORM */
.form-card {
    max-width: 600px; /* controlled width but NOT centered */
}

/* FORM GROUP */
.form-group {
    margin-bottom: 18px;
}

.form-group label {
    display: block;
    font-size: 14px;
    margin-bottom: 6px;
    color: #374151;
}

.form-group input {
    width: 100%;
    padding: 10px;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    font-size: 14px;
}

.form-group input:focus {
    outline: none;
    border-color: #2563eb;
}

/* BUTTONS */
.btn {
    padding: 10px;
    border-radius: 4px;
    border: none;
    font-size: 14px;
    cursor: pointer;
}

.full-width {
    width: 100%;
}

.btn-primary {
    background: #2563eb;
    color: #fff;
}
.btn-primary:hover {
    background: #1d4ed8;
}

.btn-danger {
    background: #dc2626;
    color: #fff;
}
.btn-danger:hover {
    background: #b91c1c;
}

/* DELETE */
.danger-description {
    margin-bottom: 20px;
    color: #4b5563;
}

.link-cancel {
    display: block;
    margin-top: 15px;
    color: #6b7280;
    text-decoration: none;
}
.link-cancel:hover {
    text-decoration: underline;
}
    </style>
</head>
<body>
    {% block body %}{% endblock %}
    {% block javascripts %}{% endblock %}
</body>
</html>