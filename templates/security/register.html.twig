{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-box auth-box-register">
        <div class="auth-left auth-left-form">
            <div class="auth-form-wrap">
                <h1 class="auth-title">Sign up</h1>

                {% for message in app.flashes('error') %}
                    <div class="auth-message auth-message-error">{{ message }}</div>
                {% endfor %}

                {% for message in app.flashes('success') %}
                    <div class="auth-message auth-message-success">{{ message }}</div>
                {% endfor %}

                <form method="post">
                    <div class="auth-input-row">
                        <span class="auth-input-icon">
                            <i data-lucide="user"></i>
                        </span>
                        <input type="text" name="fullName" placeholder="Your Name" required>
                    </div>

                    <div class="auth-input-row">
                        <span class="auth-input-icon">
                            <i data-lucide="mail"></i>
                        </span>
                        <input type="email" name="email" placeholder="Your Email" required>
                    </div>

                    <div class="auth-input-row">
                        <span class="auth-input-icon">
                            <i data-lucide="lock"></i>
                        </span>
                        <input type="password" name="password" placeholder="Password" required>
                    </div>

                    <div class="auth-input-row">
                        <span class="auth-input-icon">
                            <i data-lucide="lock"></i>
                        </span>
                        <input type="password" name="password_confirmation" placeholder="Repeat your password" required>
                    </div>

                    <label class="auth-remember auth-terms">
                        <input type="checkbox" name="terms" required>
                        <span>I agree all statements in <a href="#">Terms of service</a></span>
                    </label>

                    <button type="submit" class="auth-btn">Register</button>
                </form>
            </div>
        </div>

        <div class="auth-right auth-right-visual">
            <img
                src="{{ asset('assets/images/register-illustration.png') }}"
                alt="Register illustration"
                class="auth-illustration"
            >

            <a href="{{ path('app_login') }}" class="auth-footer-link auth-footer-link-no-underline">
                I am already member
            </a>
        </div>
    </div>
</div>

<style>
    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #ececec;
    }

    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .auth-box {
        width: 100%;
        max-width: 900px;
        min-height: 560px;
        background: #f8f8f8;
        border-radius: 28px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        overflow: hidden;
        box-shadow: 0 16px 45px rgba(0, 0, 0, 0.08);
    }

    .auth-left,
    .auth-right {
        position: relative;
        padding: 45px 50px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-left-form {
        justify-content: flex-start;
    }

    .auth-right-visual {
        flex-direction: column;
    }

    .auth-illustration {
        width: 100%;
        max-width: 300px;
        height: auto;
        object-fit: contain;
        display: block;
    }

    .auth-footer-link {
        position: absolute;
        bottom: 56px;
        left: 50%;
        transform: translateX(-50%);
        color: #111;
        font-size: 17px;
        text-decoration: underline;
    }

    .auth-footer-link-no-underline {
        text-decoration: none;
    }

    .auth-form-wrap {
        width: 100%;
        max-width: 340px;
    }

    .auth-title {
        margin: 0 0 50px;
        font-size: 48px;
        line-height: 1;
        font-weight: 800;
        color: #171717;
    }

    .auth-message {
        margin-bottom: 18px;
        padding: 12px 14px;
        border-radius: 10px;
        font-size: 14px;
    }

    .auth-message-error {
        background: #fee2e2;
        color: #991b1b;
    }

    .auth-message-success {
        background: #dcfce7;
        color: #166534;
    }

    .auth-input-row {
        display: flex;
        align-items: center;
        gap: 14px;
        border-bottom: 1px solid #9a9a9a;
        margin-bottom: 28px;
        padding-bottom: 10px;
    }

    .auth-input-icon {
        width: 22px;
        height: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #222;
        flex-shrink: 0;
    }

    .auth-input-icon svg {
        width: 18px;
        height: 18px;
        stroke-width: 2;
    }

    .auth-input-row input {
        width: 100%;
        border: none;
        outline: none;
        background: transparent;
        font-size: 18px;
        color: #1f1f1f;
        padding: 3px 0;
        box-shadow: none;
    }

    .auth-input-row input::placeholder {
        color: #9f9f9f;
    }

    .auth-remember {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin: 8px 0 34px;
        font-size: 16px;
        color: #111;
        cursor: pointer;
        line-height: 1.5;
    }

    .auth-remember input {
        width: 18px;
        height: 18px;
        margin: 2px 0 0;
        flex-shrink: 0;
    }

    .auth-terms a {
        color: #111;
        text-decoration: underline;
    }

    .auth-btn {
        width: 155px;
        height: 56px;
        border: none;
        border-radius: 8px;
        background: #6ea7dc;
        color: #fff;
        font-size: 18px;
        font-weight: 500;
        cursor: pointer;
        transition: 0.2s ease;
    }

    .auth-btn:hover {
        background: #5e99d1;
    }

    @media (max-width: 900px) {
        .auth-box {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .auth-left,
        .auth-right {
            padding: 35px 28px;
        }

        .auth-title {
            font-size: 40px;
            margin-bottom: 38px;
        }

        .auth-footer-link {
            position: static;
            transform: none;
            margin-top: 24px;
        }
    }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            lucide.createIcons();
        });
    </script>
{% endblock %}