{% extends 'base.html.twig' %}

{% block title %}Register - Assistant Vocal{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="auth-shell">
            <div class="auth-bg" aria-hidden="true">
                <span class="auth-orb auth-orb-one"></span>
                <span class="auth-orb auth-orb-two"></span>
                <span class="auth-line auth-line-one"></span>
                <span class="auth-line auth-line-two"></span>
            </div>

            <section class="auth-form-panel">
                <div class="auth-form-wrap">
                    <span class="auth-form-kicker">
                        <i data-lucide="user-plus"></i>
                        Create Access
                    </span>

                    <h1>Sign up</h1>

                    <p class="auth-subtitle">
                        Press <strong>Space</strong> to speak. Say “full name”, “email field”,
                        “password field”, “repeat password”, “accept terms”, or “register”.
                    </p>

                    {% for message in app.flashes('error') %}
                        <div class="auth-message auth-message-error">
                            <i data-lucide="triangle-alert"></i>
                            <span>{{ message }}</span>
                        </div>
                    {% endfor %}

                    {% for message in app.flashes('success') %}
                        <div class="auth-message auth-message-success">
                            <i data-lucide="circle-check"></i>
                            <span>{{ message }}</span>
                        </div>
                    {% endfor %}

                    <div id="registerVoiceStatus" class="auth-message auth-message-info" hidden>
                        <i data-lucide="info"></i>
                        <span></span>
                    </div>

                    <form method="post" class="auth-form">
                        <div class="auth-form-group">
                            <label for="fullName">Full name</label>

                            <div class="auth-input-row">
                                <span class="auth-input-icon">
                                    <i data-lucide="user"></i>
                                </span>

                                <input
                                    id="fullName"
                                    type="text"
                                    name="fullName"
                                    placeholder="Your name"
                                    required
                                    autocomplete="name"
                                >
                            </div>
                        </div>

                        <div class="auth-form-group">
                            <label for="email">Email address</label>

                            <div class="auth-input-row">
                                <span class="auth-input-icon">
                                    <i data-lucide="mail"></i>
                                </span>

                                <input
                                    id="email"
                                    type="email"
                                    name="email"
                                    placeholder="Your email"
                                    required
                                    autocomplete="email"
                                >
                            </div>
                        </div>

                        <div class="auth-form-group">
                            <label for="password">Password</label>

                            <div class="auth-input-row">
                                <span class="auth-input-icon">
                                    <i data-lucide="lock"></i>
                                </span>

                                <input
                                    id="password"
                                    type="password"
                                    name="password"
                                    placeholder="Password"
                                    required
                                    autocomplete="new-password"
                                >
                            </div>
                        </div>

                        <div class="auth-form-group">
                            <label for="password_confirmation">Repeat password</label>

                            <div class="auth-input-row">
                                <span class="auth-input-icon">
                                    <i data-lucide="badge-check"></i>
                                </span>

                                <input
                                    id="password_confirmation"
                                    type="password"
                                    name="password_confirmation"
                                    placeholder="Repeat your password"
                                    required
                                    autocomplete="new-password"
                                >
                            </div>
                        </div>

                        <label class="auth-remember auth-terms">
                            <input id="termsCheckbox" type="checkbox" name="terms" required>
                            <span>I agree all statements in <a href="#">Terms of service</a></span>
                        </label>

                        <button type="submit" class="auth-btn">
                            <i data-lucide="user-plus"></i>
                            Register
                        </button>
                    </form>
                </div>
            </section>

            <aside class="auth-brand-panel">
                <div class="auth-logo-wrap">
                    <img
                        src="{{ asset('assets/images/assistant-vocal-logo.png') }}"
                        alt="Assistant Vocal logo"
                        class="auth-logo"
                    >

                    <div>
                        <strong>Assistant Vocal</strong>
                        <span>Accessible Voice Assistant</span>
                    </div>
                </div>

                <div class="auth-visual">
                    <div class="auth-mic-orbit">
                        <span class="auth-ring auth-ring-one"></span>
                        <span class="auth-ring auth-ring-two"></span>

                        <div class="auth-mic-core">
                            <i data-lucide="mic"></i>
                        </div>
                    </div>
                </div>

                <div class="auth-brand-copy">
                    <span class="auth-kicker">
                        <i data-lucide="sparkles"></i>
                        Inclusive Technology
                    </span>

                    <h2>Designed for easier digital access.</h2>

                    <p>
                        Create your account with voice assistance. After registration, you can enable
                        Camera Login from your profile for easier future access.
                    </p>
                </div>

                <a href="{{ path('app_login') }}" class="auth-register-link">
                    <i data-lucide="log-in"></i>
                    I am already a member
                </a>
            </aside>
        </section>
    </main>

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background:
                radial-gradient(circle at 85% 5%, rgba(37, 99, 235, 0.14), transparent 32%),
                radial-gradient(circle at 35% 95%, rgba(56, 189, 248, 0.10), transparent 34%),
                linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
            color: #0f172a;
        }

        .auth-page,
        .auth-page * {
            box-sizing: border-box;
        }

        .auth-page {
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 8px;
            overflow: hidden;
        }

        .auth-shell {
            position: relative;
            width: min(1040px, 100%);
            height: min(610px, calc(100vh - 16px));
            min-height: 0;
            display: grid;
            grid-template-columns: minmax(390px, 1.05fr) minmax(330px, 0.95fr);
            overflow: hidden;
            border-radius: 26px;
            background: #ffffff;
            border: 1px solid rgba(226, 232, 240, 0.9);
            box-shadow: 0 22px 70px rgba(15, 23, 42, 0.14);
        }

        .auth-bg {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .auth-orb {
            position: absolute;
            border-radius: 999px;
            filter: blur(12px);
            opacity: 0.32;
            mix-blend-mode: screen;
            z-index: 1;
        }

        .auth-orb-one {
            width: 220px;
            height: 220px;
            right: 8%;
            top: 7%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.95), transparent 66%);
            animation: authFloatOne 8s ease-in-out infinite;
        }

        .auth-orb-two {
            width: 150px;
            height: 150px;
            right: 28%;
            bottom: 6%;
            background: radial-gradient(circle, rgba(14, 165, 233, 0.72), transparent 68%);
            animation: authFloatTwo 10s ease-in-out infinite;
        }

        .auth-line {
            position: absolute;
            right: -20%;
            width: 80%;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(147, 197, 253, 0.46), transparent);
            transform: rotate(-8deg);
            opacity: 0.16;
            z-index: 1;
        }

        .auth-line-one {
            top: 28%;
            animation: authScanLine 6s ease-in-out infinite;
        }

        .auth-line-two {
            top: 64%;
            animation: authScanLine 7s ease-in-out infinite reverse;
        }

        .auth-brand-panel {
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 14px;
            padding: 24px 28px;
            background:
                radial-gradient(circle at 78% 30%, rgba(37, 99, 235, 0.24), transparent 34%),
                linear-gradient(135deg, #071126 0%, #111827 52%, #172554 100%);
            color: #ffffff;
        }

        .auth-brand-panel::before {
            content: "";
            position: absolute;
            inset: -50%;
            background:
                conic-gradient(
                    from 0deg,
                    transparent,
                    rgba(59, 130, 246, 0.24),
                    transparent,
                    rgba(56, 189, 248, 0.17),
                    transparent,
                    rgba(96, 165, 250, 0.18),
                    transparent
                );
            filter: blur(80px);
            opacity: 0.72;
            animation: authAurora 18s linear infinite;
            pointer-events: none;
        }

        .auth-logo-wrap,
        .auth-visual,
        .auth-brand-copy,
        .auth-register-link {
            position: relative;
            z-index: 2;
        }

        .auth-logo-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .auth-logo {
            width: 50px;
            height: 50px;
            flex: 0 0 auto;
            border-radius: 16px;
            object-fit: cover;
            box-shadow:
                0 0 0 6px rgba(37, 99, 235, 0.14),
                0 12px 26px rgba(37, 99, 235, 0.30),
                0 0 24px rgba(56, 189, 248, 0.32);
        }

        .auth-logo-wrap strong {
            display: block;
            color: #ffffff;
            font-size: 20px;
            line-height: 1.05;
            font-weight: 950;
            letter-spacing: -0.04em;
        }

        .auth-logo-wrap span {
            display: block;
            margin-top: 3px;
            color: #cbd5e1;
            font-size: 12px;
            font-weight: 750;
        }

        .auth-visual {
            display: grid;
            place-items: center;
            min-height: 120px;
        }

        .auth-mic-orbit {
            position: relative;
            width: 108px;
            height: 108px;
            display: grid;
            place-items: center;
            border-radius: 999px;
            background:
                radial-gradient(circle at 50% 42%, rgba(14, 165, 233, 0.24), transparent 46%),
                rgba(15, 23, 42, 0.58);
            box-shadow:
                inset 0 0 0 2px rgba(147, 197, 253, 0.24),
                inset 0 0 42px rgba(59, 130, 246, 0.22),
                0 0 54px rgba(37, 99, 235, 0.28);
            animation: authMicBreath 3.2s ease-in-out infinite;
        }

        .auth-ring {
            position: absolute;
            border-radius: inherit;
            border: 1px solid rgba(147, 197, 253, 0.28);
        }

        .auth-ring-one {
            inset: -7px;
            border-left-color: #38bdf8;
            border-top-color: transparent;
            animation: authOrbitSpin 10s linear infinite;
        }

        .auth-ring-two {
            inset: -14px;
            border-right-color: #60a5fa;
            border-bottom-color: transparent;
            animation: authOrbitSpin 14s linear infinite reverse;
        }

        .auth-mic-core {
            position: relative;
            z-index: 2;
            width: 46%;
            height: 46%;
            display: grid;
            place-items: center;
            border-radius: 999px;
            background:
                radial-gradient(circle, rgba(56, 189, 248, 0.22), rgba(37, 99, 235, 0.12)),
                rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.12);
        }

        .auth-mic-core svg {
            width: 44%;
            height: 44%;
            color: #7dd3fc;
            filter: drop-shadow(0 0 18px rgba(125, 211, 252, 0.9));
            animation: authMicFloat 2.4s ease-in-out infinite;
        }

        .auth-kicker,
        .auth-form-kicker {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            width: max-content;
            padding: 5px 10px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 950;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .auth-kicker {
            color: #bfdbfe;
            background: rgba(37, 99, 235, 0.18);
            border: 1px solid rgba(147, 197, 253, 0.24);
            margin-bottom: 9px;
        }

        .auth-kicker svg,
        .auth-form-kicker svg {
            width: 14px;
            height: 14px;
        }

        .auth-brand-copy h2 {
            margin: 0;
            color: #ffffff;
            font-size: clamp(27px, 2.7vw, 36px);
            line-height: 1;
            letter-spacing: -0.06em;
            font-weight: 950;
        }

        .auth-brand-copy p {
            margin: 9px 0 0;
            color: #cbd5e1;
            font-size: 13px;
            line-height: 1.42;
            font-weight: 650;
        }

        .auth-register-link {
            min-height: 40px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: max-content;
            padding: 0 13px;
            border-radius: 13px;
            color: #ffffff;
            background: rgba(255, 255, 255, 0.10);
            border: 1px solid rgba(226, 232, 240, 0.16);
            text-decoration: none;
            font-size: 13px;
            font-weight: 900;
            transition: 180ms ease;
        }

        .auth-register-link:hover {
            transform: translateY(-2px);
            background: rgba(255, 255, 255, 0.16);
        }

        .auth-register-link svg {
            width: 16px;
            height: 16px;
        }

        .auth-form-panel {
            position: relative;
            display: grid;
            place-items: center;
            padding: 20px 34px;
            background:
                radial-gradient(circle at 95% 0%, rgba(37, 99, 235, 0.08), transparent 30%),
                #ffffff;
            overflow: hidden;
        }

        .auth-form-wrap {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 400px;
        }

        .auth-form-kicker {
            color: #2563eb;
            background: #eff6ff;
            border: 1px solid #dbeafe;
            margin-bottom: 8px;
        }

        .auth-form-wrap h1 {
            margin: 0;
            color: #0f172a;
            font-size: clamp(34px, 4vw, 44px);
            line-height: 1;
            letter-spacing: -0.065em;
            font-weight: 950;
        }

        .auth-subtitle {
            margin: 8px 0 12px;
            color: #64748b;
            font-size: 14px;
            line-height: 1.35;
            font-weight: 650;
        }

        .auth-message {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 9px 11px;
            margin-bottom: 9px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: 800;
            line-height: 1.3;
        }

        .auth-message svg {
            width: 17px;
            height: 17px;
            flex: 0 0 auto;
        }

        .auth-message-error {
            color: #991b1b;
            background: #fee2e2;
            border: 1px solid #fecaca;
        }

        .auth-message-success {
            color: #166534;
            background: #dcfce7;
            border: 1px solid #86efac;
        }

        .auth-message-info {
            color: #1d4ed8;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
        }

        .auth-form {
            display: grid;
            gap: 9px;
        }

        .auth-form-group {
            display: grid;
            gap: 4px;
        }

        .auth-form-group label {
            color: #334155;
            font-size: 12px;
            font-weight: 900;
        }

        .auth-input-row {
            min-height: 44px;
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 0 12px;
            border-radius: 14px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            transition: 180ms ease;
        }

        .auth-input-row:focus-within {
            background: #ffffff;
            border-color: #93c5fd;
            box-shadow:
                0 0 0 3px rgba(37, 99, 235, 0.10),
                0 10px 22px rgba(15, 23, 42, 0.06);
        }

        .auth-input-icon {
            display: grid;
            place-items: center;
            width: 18px;
            height: 18px;
            color: #2563eb;
            flex: 0 0 auto;
        }

        .auth-input-icon svg {
            width: 18px;
            height: 18px;
        }

        .auth-input-row input {
            width: 100%;
            min-height: 42px;
            border: 0;
            outline: 0;
            background: transparent;
            color: #0f172a;
            font-size: 14px;
            font-weight: 750;
            box-shadow: none;
        }

        .auth-input-row input::placeholder {
            color: #94a3b8;
        }

        .auth-remember {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            color: #334155;
            font-size: 12px;
            font-weight: 850;
            line-height: 1.35;
            cursor: pointer;
            margin: 0;
        }

        .auth-remember input {
            width: 16px;
            height: 16px;
            margin: 1px 0 0;
            flex: 0 0 auto;
            accent-color: #2563eb;
        }

        .auth-terms a {
            color: #1d4ed8;
            font-weight: 950;
            text-decoration: none;
        }

        .auth-terms a:hover {
            text-decoration: underline;
        }

        .auth-btn {
            min-height: 45px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            margin-top: 1px;
            border: 0;
            border-radius: 14px;
            color: #ffffff;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            box-shadow: 0 13px 28px rgba(37, 99, 235, 0.27);
            font-size: 14px;
            font-weight: 950;
            cursor: pointer;
            transition: 180ms ease;
        }

        .auth-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 34px rgba(37, 99, 235, 0.34);
        }

        .auth-btn svg {
            width: 17px;
            height: 17px;
        }

        @keyframes authAurora {
            to {
                transform: rotate(360deg);
            }
        }

        @keyframes authFloatOne {
            0%, 100% {
                transform: translate3d(0, 0, 0) scale(1);
            }

            50% {
                transform: translate3d(-38px, 28px, 0) scale(1.12);
            }
        }

        @keyframes authFloatTwo {
            0%, 100% {
                transform: translate3d(0, 0, 0) scale(1);
            }

            50% {
                transform: translate3d(42px, -22px, 0) scale(1.14);
            }
        }

        @keyframes authScanLine {
            0%, 100% {
                transform: translateX(-8%) rotate(-8deg);
            }

            50% {
                transform: translateX(8%) rotate(-8deg);
            }
        }

        @keyframes authMicBreath {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.035);
            }
        }

        @keyframes authOrbitSpin {
            to {
                transform: rotate(360deg);
            }
        }

        @keyframes authMicFloat {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-4px);
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.001ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.001ms !important;
                scroll-behavior: auto !important;
            }
        }

        @media (max-height: 720px) {
            .auth-shell {
                height: calc(100vh - 12px);
            }

            .auth-page {
                padding: 6px;
            }

            .auth-brand-panel {
                padding: 18px 24px;
                gap: 10px;
            }

            .auth-form-panel {
                padding: 16px 30px;
            }

            .auth-visual {
                min-height: 95px;
            }

            .auth-mic-orbit {
                width: 94px;
                height: 94px;
            }

            .auth-brand-copy h2 {
                font-size: 29px;
            }

            .auth-brand-copy p {
                font-size: 12px;
                line-height: 1.35;
            }

            .auth-form-wrap h1 {
                font-size: 38px;
            }

            .auth-subtitle {
                margin-bottom: 10px;
                font-size: 13px;
            }

            .auth-form {
                gap: 8px;
            }

            .auth-input-row {
                min-height: 42px;
            }

            .auth-input-row input {
                min-height: 40px;
            }

            .auth-btn {
                min-height: 42px;
            }
        }

        @media (max-width: 980px) {
            .auth-page {
                overflow: auto;
            }

            .auth-shell {
                height: auto;
                min-height: auto;
                grid-template-columns: 1fr;
            }

            .auth-brand-panel {
                min-height: auto;
            }
        }

        @media (max-width: 640px) {
            .auth-page {
                padding: 10px;
            }

            .auth-shell {
                border-radius: 22px;
            }

            .auth-brand-panel,
            .auth-form-panel {
                padding: 22px 18px;
            }

            .auth-logo-wrap strong {
                font-size: 20px;
            }

            .auth-visual {
                min-height: 110px;
            }

            .auth-mic-orbit {
                width: 104px;
                height: 104px;
            }

            .auth-brand-copy h2 {
                font-size: 30px;
            }

            .auth-form-wrap h1 {
                font-size: 36px;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.lucide) {
                lucide.createIcons();
            }

            const fullNameInput = document.getElementById('fullName');
            const emailInput = document.getElementById('email');
            const passwordInput = document.getElementById('password');
            const passwordConfirmationInput = document.getElementById('password_confirmation');
            const termsCheckbox = document.getElementById('termsCheckbox');
            const registerForm = document.querySelector('form.auth-form');
            const submitButton = registerForm ? registerForm.querySelector('button[type="submit"]') : null;
            const loginLink = document.querySelector('.auth-register-link');
            const voiceStatus = document.getElementById('registerVoiceStatus');

            let registerRecognition = null;
            let registerIsListening = false;
            let activeVoiceField = null;

            function setVoiceStatus(message, isError = false) {
                if (!voiceStatus) {
                    return;
                }

                const span = voiceStatus.querySelector('span');

                if (span) {
                    span.textContent = message;
                }

                voiceStatus.hidden = false;
                voiceStatus.classList.toggle('auth-message-error', !!isError);
                voiceStatus.classList.toggle('auth-message-info', !isError);
            }

            function speakRegister(text) {
                if (!('speechSynthesis' in window)) {
                    return;
                }

                window.speechSynthesis.cancel();

                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = navigator.language || 'en-US';
                utterance.rate = 0.95;
                utterance.pitch = 1;
                utterance.volume = 1;

                window.speechSynthesis.speak(utterance);
            }

            function normalizeVoiceText(text) {
                return String(text || '')
                    .toLowerCase()
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .replace(/[^\p{L}\p{N}@._\-\s]/gu, ' ')
                    .replace(/\s+/g, ' ')
                    .trim();
            }

            function spokenEmailToEmail(text) {
                let value = String(text || '')
                    .toLowerCase()
                    .replace(/\s+at\s+/g, '@')
                    .replace(/\s+arobase\s+/g, '@')
                    .replace(/\s+dot\s+/g, '.')
                    .replace(/\s+point\s+/g, '.')
                    .replace(/\s+underscore\s+/g, '_')
                    .replace(/\s+dash\s+/g, '-')
                    .replace(/\s+hyphen\s+/g, '-')
                    .replace(/\s+/g, ' ')
                    .trim();

                const domainMap = {
                    gmail: 'gmail.com',
                    'gmail com': 'gmail.com',
                    googlemail: 'gmail.com',
                    hotmail: 'hotmail.com',
                    'hotmail com': 'hotmail.com',
                    outlook: 'outlook.com',
                    'outlook com': 'outlook.com',
                    yahoo: 'yahoo.com',
                    'yahoo com': 'yahoo.com'
                };

                if (!value.includes('@')) {
                    for (const spokenDomain in domainMap) {
                        if (value.endsWith(' ' + spokenDomain)) {
                            const localPart = value.slice(0, -spokenDomain.length).trim().replace(/\s+/g, '');
                            return localPart + '@' + domainMap[spokenDomain];
                        }
                    }
                }

                return value.replace(/\s+/g, '');
            }

            function extractDictatedText(originalText) {
                const patterns = [
                    /^write\s+(.+)$/i,
                    /^type\s+(.+)$/i,
                    /^enter\s+(.+)$/i,
                    /^put\s+(.+)$/i,
                    /^my name is\s+(.+)$/i,
                    /^name is\s+(.+)$/i,
                    /^my full name is\s+(.+)$/i,
                    /^full name is\s+(.+)$/i,
                    /^my email is\s+(.+)$/i,
                    /^email is\s+(.+)$/i,
                    /^my password is\s+(.+)$/i,
                    /^password is\s+(.+)$/i
                ];

                for (const pattern of patterns) {
                    const match = String(originalText || '').match(pattern);

                    if (match && match[1]) {
                        return match[1].trim();
                    }
                }

                return null;
            }

            function setInputValue(input, value) {
                if (!input) {
                    return;
                }

                input.value = value;
                input.dispatchEvent(new Event('input', { bubbles: true }));
                input.dispatchEvent(new Event('change', { bubbles: true }));
            }

            function focusFullNameField() {
                activeVoiceField = 'fullName';
                fullNameInput.focus();
                setVoiceStatus('Full name field selected. Press Space and say: write your full name.');
                speakRegister('Full name field selected. Press Space and say, write your full name.');
            }

            function focusEmailField() {
                activeVoiceField = 'email';
                emailInput.focus();
                setVoiceStatus('Email field selected. Press Space and say: write your email address.');
                speakRegister('Email field selected. Press Space and say, write your email address.');
            }

            function focusPasswordField() {
                activeVoiceField = 'password';
                passwordInput.focus();
                setVoiceStatus('Password field selected. Press Space and say: write your password.');
                speakRegister('Password field selected. Press Space and say, write your password.');
            }

            function focusRepeatPasswordField() {
                activeVoiceField = 'repeatPassword';
                passwordConfirmationInput.focus();
                setVoiceStatus('Repeat password field selected. Press Space and say: write your password again.');
                speakRegister('Repeat password field selected. Press Space and say, write your password again.');
            }

            function typeIntoActiveField(originalText) {
                const dictatedText = extractDictatedText(originalText);

                if (!dictatedText) {
                    return false;
                }

                if (activeVoiceField === 'fullName' || document.activeElement === fullNameInput) {
                    setInputValue(fullNameInput, dictatedText);
                    setVoiceStatus('Full name written. Say email field next.');
                    speakRegister('Full name written. Say email field next.');
                    return true;
                }

                if (activeVoiceField === 'email' || document.activeElement === emailInput) {
                    const email = spokenEmailToEmail(dictatedText);
                    setInputValue(emailInput, email);
                    setVoiceStatus('Email written: ' + email + '. Say password field next.');
                    speakRegister('Email written. Say password field next.');
                    return true;
                }

                if (activeVoiceField === 'password' || document.activeElement === passwordInput) {
                    const password = dictatedText.replace(/\s+/g, '');
                    setInputValue(passwordInput, password);
                    setVoiceStatus('Password written. Say repeat password next.');
                    speakRegister('Password written. Say repeat password next.');
                    return true;
                }

                if (activeVoiceField === 'repeatPassword' || document.activeElement === passwordConfirmationInput) {
                    const password = dictatedText.replace(/\s+/g, '');
                    setInputValue(passwordConfirmationInput, password);
                    setVoiceStatus('Repeated password written. Say accept terms, then say register.');
                    speakRegister('Repeated password written. Say accept terms, then say register.');
                    return true;
                }

                return false;
            }

            function acceptTerms() {
                termsCheckbox.checked = true;
                termsCheckbox.dispatchEvent(new Event('change', { bubbles: true }));
                setVoiceStatus('Terms accepted. Say register to create your account.');
                speakRegister('Terms accepted. Say register to create your account.');
            }

            function submitRegistration() {
                if (!fullNameInput.value.trim()) {
                    focusFullNameField();
                    return;
                }

                if (!emailInput.value.trim()) {
                    focusEmailField();
                    return;
                }

                if (!passwordInput.value.trim()) {
                    focusPasswordField();
                    return;
                }

                if (!passwordConfirmationInput.value.trim()) {
                    focusRepeatPasswordField();
                    return;
                }

                if (passwordInput.value !== passwordConfirmationInput.value) {
                    setVoiceStatus('The two passwords do not match. Please repeat the password again.', true);
                    speakRegister('The two passwords do not match. Please repeat the password again.');
                    focusRepeatPasswordField();
                    return;
                }

                if (!termsCheckbox.checked) {
                    acceptTerms();
                    return;
                }

                setVoiceStatus('Creating your account.');
                speakRegister('Creating your account.');
                submitButton.click();
            }

            function openLoginPage() {
                if (!loginLink) {
                    setVoiceStatus('Login link was not found.', true);
                    speakRegister('Login link was not found.');
                    return;
                }

                speakRegister('Opening login page.');
                window.location.href = loginLink.href;
            }

            function readRegisterHelp() {
                const message =
                    'You are on the registration page. Press Space to speak. ' +
                    'Say full name, then say write your full name. ' +
                    'Say email field, then say write your email address. For example, write abbott gmail. ' +
                    'Say password field, then say write your password. ' +
                    'Say repeat password, then say write your password again. ' +
                    'Say accept terms. Then say register. ' +
                    'Say login page if you already have an account.';

                setVoiceStatus(message);
                speakRegister(message);
            }

            function handleRegisterVoiceCommand(text) {
                const normalized = normalizeVoiceText(text);

                console.log('REGISTER VOICE COMMAND:', normalized);

                if (!normalized) {
                    speakRegister('I did not hear a command. Press Space and try again.');
                    return;
                }

                if (typeIntoActiveField(text)) {
                    return;
                }

                if (
                    normalized === 'help' ||
                    normalized === 'what can i say' ||
                    normalized === 'read page' ||
                    normalized === 'read this page' ||
                    normalized === 'instructions'
                ) {
                    readRegisterHelp();
                    return;
                }

                if (
                    normalized.includes('full name') ||
                    normalized.includes('name field') ||
                    normalized === 'name'
                ) {
                    focusFullNameField();
                    return;
                }

                if (
                    normalized.includes('email field') ||
                    normalized.includes('select email') ||
                    normalized.includes('focus email') ||
                    normalized === 'email'
                ) {
                    focusEmailField();
                    return;
                }

                if (
                    normalized.includes('repeat password') ||
                    normalized.includes('confirm password') ||
                    normalized.includes('password confirmation')
                ) {
                    focusRepeatPasswordField();
                    return;
                }

                if (
                    normalized.includes('password field') ||
                    normalized.includes('select password') ||
                    normalized.includes('focus password') ||
                    normalized === 'password'
                ) {
                    focusPasswordField();
                    return;
                }

                if (
                    normalized.includes('accept terms') ||
                    normalized.includes('agree terms') ||
                    normalized.includes('i agree') ||
                    normalized.includes('terms')
                ) {
                    acceptTerms();
                    return;
                }

                if (
                    normalized === 'register' ||
                    normalized === 'sign up' ||
                    normalized === 'create account' ||
                    normalized === 'submit registration' ||
                    normalized.includes('create my account')
                ) {
                    submitRegistration();
                    return;
                }

                if (
                    normalized.includes('login page') ||
                    normalized.includes('go to login') ||
                    normalized.includes('already have account') ||
                    normalized.includes('i am already a member')
                ) {
                    openLoginPage();
                    return;
                }

                setVoiceStatus('I heard: "' + text + '". Say help to hear registration commands.');
                speakRegister('I heard ' + text + '. Say help to hear registration commands.');
            }

            function startRegisterVoiceListening() {
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

                if (!SpeechRecognition) {
                    setVoiceStatus('Voice recognition is not supported in this browser. Please use Chrome or Edge.', true);
                    speakRegister('Voice recognition is not supported in this browser.');
                    return;
                }

                if (registerIsListening) {
                    return;
                }

                if (!registerRecognition) {
                    registerRecognition = new SpeechRecognition();
                    registerRecognition.lang = navigator.language || 'en-US';
                    registerRecognition.interimResults = false;
                    registerRecognition.continuous = false;

                    registerRecognition.onstart = function () {
                        registerIsListening = true;
                        setVoiceStatus('Listening now. Say full name, email field, password field, accept terms, register, or help.');
                    };

                    registerRecognition.onend = function () {
                        registerIsListening = false;
                    };

                    registerRecognition.onerror = function (event) {
                        registerIsListening = false;

                        let message = 'Voice recognition error. Please press Space and try again.';

                        if (event && event.error === 'not-allowed') {
                            message = 'Microphone permission is blocked. Please allow microphone access for this site.';
                        }

                        if (event && event.error === 'no-speech') {
                            message = 'I did not hear anything. Press Space and try again.';
                        }

                        if (event && event.error === 'audio-capture') {
                            message = 'No microphone was found. Please check your microphone.';
                        }

                        if (event && event.error === 'network') {
                            message = 'Voice recognition needs an internet connection.';
                        }

                        setVoiceStatus(message, true);
                        speakRegister(message);
                    };

                    registerRecognition.onresult = function (event) {
                        const text = event.results[0][0].transcript.trim();

                        setVoiceStatus('I heard: ' + text);
                        handleRegisterVoiceCommand(text);
                    };
                }

                try {
                    window.speechSynthesis?.cancel();
                    registerRecognition.lang = navigator.language || 'en-US';
                    registerRecognition.start();
                } catch (error) {
                    setVoiceStatus('The microphone is already starting. Please wait a moment.');
                }
            }

            function stopRegisterVoiceListening() {
                if (registerRecognition && registerIsListening) {
                    registerRecognition.stop();
                }
            }

            function toggleRegisterVoiceListening() {
                if (registerIsListening) {
                    stopRegisterVoiceListening();
                } else {
                    startRegisterVoiceListening();
                }
            }

            document.addEventListener('keydown', function (event) {
                const isPlainSpace =
                    event.code === 'Space' &&
                    !event.ctrlKey &&
                    !event.altKey &&
                    !event.shiftKey &&
                    !event.metaKey;

                if (!isPlainSpace) {
                    return;
                }

                event.preventDefault();
                event.stopPropagation();

                toggleRegisterVoiceListening();
            }, true);

            setVoiceStatus('Press Space to speak. Say “help” to hear registration commands.');
        });
    </script>
{% endblock %}